{% assign s = block.settings %}
{% assign asset_src = shop.logo_src | default: s.logo %}

{% comment %} --- Wrapper Classes --- {% endcomment %}
{% assign classes = 'flex items-center justify-center relative z-content group-hover:opacity-100 text-primary' %}

{% if s.surface_override %}
  {% assign classes = classes | push: "surface-{{ s.surface_id | default: 'default' }}" %}
{% endif %}

{% assign block_classes = classes | join: ' ' %}

{% comment %} --- Text Fallback Styles --- {% endcomment %}
{% assign _is_custom_text = false %}
{% if s.text_role == 'custom' %}{% assign _is_custom_text = true %}{% endif %}
{% assign styles = blank %}

{% assign styles = styles | push_if: '--text: {{ s.text_role_custom }}', _is_custom_text %}
{% assign text_styles = styles | join: ';' %}

{% comment %} --- Component Render --- {% endcomment %}
<a
  href="/"
  class="{{ block_classes }}"
  {{ context.attached_attributes }}
>
  {% if asset_src != blank %}
    <div
      class="transition-opacity duration-300 block"
      style="width: {{ s.logo_width }}rem;"
    >
      {% render 'media', src: asset_src, ratio: 'auto', fit: 'contain', class: 'bg-transparent', loading: 'eager' %}
    </div>
  {% else %}
    <span
      class="text-xl font-bold font-heading tracking-widest whitespace-nowrap"
      style="{{ text_styles }}"
    >
      {{ shop.name }}
    </span>
  {% endif %}
</a>

{% schema %}
{
  "name": "Brand Logo",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo", "conditional": "shop.logo_src == blank" },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Width",
      "min": 3,
      "max": 25,
      "step": 0.5,
      "default": 3,
      "unit": "rem"
    },
    {
      "type": "header",
      "content": "Style",
      "conditional": "shop.logo_src == blank"
    },
    {
      "type": "select",
      "id": "text_role",
      "label": "Text Color Role",
      "default": "primary",
      "options": [
        { "value": "primary",    "label": "Primary" },
        { "value": "secondary",  "label": "Secondary" },
        { "value": "subtle",     "label": "Subtle" },
        { "value": "emphasis",   "label": "Emphasis" },
        { "value": "on-accent",  "label": "On Accent" },
        { "value": "on-button",  "label": "On Button" },
        { "value": "on-control", "label": "On Control" },
        { "value": "custom",     "label": "Custom" }
      ],
      "conditional": "shop.logo_src == blank"
    },
    {
      "type": "color",
      "id": "text_role_custom",
      "label": "Custom Text",
      "info": "Free hex. Used only when Text role = Custom.",
      "conditional": "setting.text_role == 'custom' and shop.logo_src == blank"
    },
    {
      "type": "header",
      "content": "Overrides",
      "conditional": "shop.logo_src == blank"
    },
    {
      "type": "checkbox",
      "id": "surface_override",
      "label": "Override Color Scheme",
      "default": false,
      "conditional": "shop.logo_src == blank"
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Color Scheme",
      "default": "default",
      "conditional": "shop.logo_src == blank and setting.surface_override == true"
    }
    ]
}
{% endschema %}
