{% assign s = block.settings %}

{% comment %} --- Layout & Alignment Logic --- {% endcomment %}
{% assign layout_class = 'flex' %}
{% assign align_class = blank %}
{% assign justify_class = blank %}

{% if s.layout_mode == 'grid' %}
  {% assign layout_class = 'grid grid-cols-[repeat(auto-fit,minmax(min(var(--width-grid-col),100%),1fr))]' %}

  {% case s.vertical_align %}
    {% when 'top' %}
      {% assign align_class = 'align-items-start' %}
    {% when 'middle' %}
      {% assign align_class = 'align-items-center' %}
    {% when 'bottom' %}
      {% assign align_class = 'align-items-end' %}
    {% else %}
      {% assign align_class = 'align-items-stretch' %}
  {% endcase %}

  {% case s.content_align %}
    {% when 'left' %}
      {% assign justify_class = 'justify-content-start' %}
    {% when 'center' %}
      {% assign justify_class = 'justify-content-center' %}
    {% when 'right' %}
      {% assign justify_class = 'justify-content-end' %}
    {% when 'between' %}
      {% assign justify_class = 'justify-content-between' %}
  {% endcase %}

{% else %}
  {% if s.direction == 'responsive' %}
    {% assign layout_class = layout_class | append: ' flex-col md:flex-row' %}
  {% elsif s.direction == 'row' %}
    {% assign layout_class = layout_class | append: ' flex-row' %}
  {% else %}
    {% assign layout_class = layout_class | append: ' flex-col' %}
  {% endif %}

  {% if s.direction == 'row' or s.direction == 'responsive' %}
    {% case s.content_align %}
      {% when 'center' %}
        {% assign justify_class = 'justify-content-center' %}
      {% when 'right' %}
        {% assign justify_class = 'justify-content-end' %}
      {% when 'between' %}
        {% assign justify_class = 'justify-content-between' %}
      {% else %}
        {% assign justify_class = 'justify-content-start' %}
    {% endcase %}
    {% case s.vertical_align %}
      {% when 'top' %}
        {% assign align_class = 'align-items-start' %}
      {% when 'middle' %}
        {% assign align_class = 'align-items-center' %}
      {% when 'bottom' %}
        {% assign align_class = 'align-items-end' %}
      {% else %}
        {% assign align_class = 'align-items-stretch' %}
    {% endcase %}
  {% else %}
    {% comment %} Strict Column: vertical_align = vertical (justify), content_align = horizontal (items) {% endcomment %}
    {% case s.vertical_align %}
      {% when 'middle' %}
        {% assign justify_class = 'justify-content-center' %}
      {% when 'bottom' %}
        {% assign justify_class = 'justify-content-end' %}
      {% when 'between' %}
        {% assign justify_class = 'justify-content-between' %}
      {% else %}
        {% assign justify_class = 'justify-content-start' %}
    {% endcase %}
    {% case s.content_align %}
      {% when 'left' %}
        {% assign align_class = 'align-items-start' %}
      {% when 'center' %}
        {% assign align_class = 'align-items-center' %}
      {% when 'right' %}
        {% assign align_class = 'align-items-end' %}
      {% else %}
        {% assign align_class = 'align-items-stretch' %}
    {% endcase %}
  {% endif %}
{% endif %}

{% comment %} --- Class Array Building --- {% endcomment %}
{% assign classes = 'group-block transition-all rounded-global rotate-custom block-limit-width'
  | push: layout_class
  | push: justify_class
  | push: align_class
  | push: 'text-align-{{ s.text_align }}'
  | push: 'height-{{ s.height }}'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
  | push: 'gap-{{ s.gap }}'
  | push: 'margin-my-{{ s.margin_vertical }}'
  | push: 'margin-mx-{{ s.margin_horizontal }}'
  | push: 'aspect-{{ s.aspect_ratio }}'
  | push: 'cursor-{{ s.cursor }}'
  | push_if: 'float', s.animate_float
  | push_if: 'scale-in', s.animate_scale_in
  | push_if: 'stagger-load', s.animate_stagger
  | push_if: 'hover-shadow', s.animate_shadow_hover
  | push_if: 'shadow-lg', s.shadow
  | push_if: 'overflow-hidden', s.overflow_hidden
  | push_if: 'backdrop-blur-md bg-opacity-80 border border-white/10', s.enable_glass
%}

{% if s.layout_mode != 'grid' %}
  {% assign classes = classes | push: 'direction-{{ s.direction }}' | push_if: 'flex-wrap', s.wrap_content %}

  {% if s.grow_content %}
    {% assign classes = classes | push: 'flex-grow' %}
  {% else %}
    {% assign classes = classes | push: 'flex-initial' %}
  {% endif %}
{% endif %}

{% if s.animate_fade != 'none' %}
  {% assign classes = classes | push: 'fade-{{ s.animate_fade }}' %}
{% endif %}

{% comment %} Borders {% endcomment %}
{% unless s.border_mode == 'none' %}
  {% assign classes = classes
    | push: 'group-border-{{ s.border_mode }}'
    | push: 'group-border-size-{{ s.border_size }}'
  %}
  {% if s.border_mode == 'custom' %}
    {% assign classes = classes
      | push_if: 'group-border-custom-left', s.border_custom_left
      | push_if: 'group-border-custom-right', s.border_custom_right
      | push_if: 'group-border-custom-top', s.border_custom_top
      | push_if: 'group-border-custom-bottom', s.border_custom_bottom
    %}
  {% endif %}
{% endunless %}

{% comment %} Layout & Styling Flags {% endcomment %}
{% unless s.grow_content %}{% assign classes = classes | push: 'width-{{ s.width_scheme }}' %}{% endunless %}
{% unless s.inherit_styles %}
  {% assign classes = classes | push: "color-{{ s.color_scheme | default: 'none' }}" | push: 'bg-surface' %}
{% endunless %}

{% if s.position == 'absolute' %}
  {% assign classes = classes | push: 'absolute' | push: 'anchor-{{ s.inset }}' %}
{% elsif s.position == 'relative' %}
  {% assign classes = classes | push: 'relative' %}
{% endif %}

{% comment %} Finalize Class Output {% endcomment %}
{% assign block_classes = classes | join: ' ' %}

{% comment %} --- Styles Array Building --- {% endcomment %}
{% assign styles = blank %}

{% if s.padding_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.padding_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}

{% if s.margin_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-mt: {{ s.margin_vertical_custom_top }}rem'
    | push: '--space-mb: {{ s.margin_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.margin_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-ml: {{ s.margin_horizontal_custom_left }}rem'
    | push: '--space-mr: {{ s.margin_horizontal_custom_right }}rem'
  %}
{% endif %}

{% if s.gap == 'custom' %}{% assign styles = styles | push: '--space-gap: {{ s.gap_custom }}rem' %}{% endif %}
{% if s.layout_mode == 'grid' %}
  {% assign styles = styles | push: '--width-grid-col: {{ s.min_column_width }}rem' %}
{% endif %}

{% unless s.border_mode == 'none' %}
  {% assign styles = styles
    | push_if: '--color-border: {{ s.border_color }}', s.border_color_override
    | push: '--border-style: {{ s.border_style }}'
  %}
{% endunless %}

{% assign styles = styles | push: '--rotation: {{ s.rotation }}deg' %}

{% unless s.inherit_styles %}
  {% assign styles = styles
    | push_if: '--radius-global: {{ s.border_radius }}px', s.border_radius_override
    | push_if: '--color-surface: {{ s.bg_color }}', s.bg_color_override
    | push_if: '--color-shadow: {{ s.shadow_color }}', s.shadow_color_override
  %}
{% endunless %}

{% comment %} Finalize Style Output {% endcomment %}
{% assign block_styles = styles | join: ';' %}

{% comment %} --- Content Generation --- {% endcomment %}
{% capture content %}
  {% content_for 'blocks' %}
  {% if s.enable_overlay %}
    <div
      class="rounded-global absolute inset-0 pointer-events-none"
      style="background: {{ s.overlay_color }}; opacity: {{ s.overlay_opacity | divided_by: 100.0 }};"
    ></div>
  {% endif %}
{% endcapture %}

{% comment %} --- Component Render --- {% endcomment %}
{% if s.trigger == 'link' and s.link %}
  <a
    class="isolate {{ block_classes }}"
    style="{{ block_styles }}"
    href="{{ s.link }}"
    {% if s.link_target == '_blank' %}
      target="_blank" rel="noopener"
    {% endif %}
    {{ context.attached_attributes }}
  >
    {{ content }}
  </a>
{% else %}
  <div
    class="isolate {{ block_classes }}"
    style="{{ block_styles }}"
    {{ context.attached_attributes }}
    {% if s.trigger == 'action' %}
      data-action="{{ s.action | escape }}"
      {% if s.action_args != blank %}data-action-args="{{ s.action_args | escape }}"{% endif %}
    {% endif %}
  >
    {{ content }}
  </div>
{% endif %}

{% schema %}
{
  "name": "Group",
  "settings": [
    { "type": "header", "content": "Layout Mode" },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Mode",
      "options": [
        { "value": "flex", "label": "Flex (Standard)" },
        { "value": "grid", "label": "CSS Grid (Auto-Fit)" }
      ],
      "default": "flex"
    },
    {
      "type": "range",
      "id": "min_column_width",
      "label": "Min Item Width (Grid Only)",
      "min": 6,
      "max": 32,
      "step": 0.5,
      "default": 16,
      "unit": "rem",
      "conditional": "setting.layout_mode == 'grid'"
    },
    { "type": "header", "content": "Flex Settings", "conditional": "setting.layout_mode == 'flex'" },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        { "value": "column", "label": "Vertical (Column)" },
        { "value": "row", "label": "Horizontal (Row)" },
        { "value": "responsive", "label": "Responsive" }
      ],
      "default": "column",
      "conditional": "setting.layout_mode == 'flex'"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Horizontal Alignment",
      "options": [
        { "value": "left", "label": "Left / Start" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right / End" },
        { "value": "between", "label": "Space Between" },
        { "value": "stretch", "label": "Stretch" }
      ]
    },
    {
      "type": "select",
      "id": "vertical_align",
      "label": "Vertical Alignment",
      "options": [
        { "value": "top", "label": "Top / Start" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom / End" },
        { "value": "between", "label": "Space Between" },
        { "value": "stretch", "label": "Stretch" }
      ]
    },
    {
      "type": "checkbox",
      "id": "wrap_content",
      "label": "Wrap Content",
      "default": false,
      "conditional": "setting.layout_mode == 'flex'"
    },
    {
      "type": "checkbox",
      "id": "grow_content",
      "label": "Grow Content",
      "default": false,
      "conditional": "setting.layout_mode == 'flex'"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect Ratio",
      "options": [
        { "value": "auto", "label": "Natural" },
        { "value": "square", "label": "Square (1:1)" },
        { "value": "video", "label": "Video (16:9)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "landscape", "label": "Landscape (4:3)" }
      ],
      "default": "auto"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Position Type",
      "options": [
        { "value": "relative", "label": "Relative" },
        { "value": "absolute", "label": "Absolute" }
      ],
      "default": "relative"
    },
    {
      "type": "select",
      "id": "inset",
      "label": "Anchor",
      "options": [
        { "value": "top-left", "label": "Top Left" },
        { "value": "top-right", "label": "Top Right" },
        { "value": "top-center", "label": "Top Center" },
        { "value": "bottom-left", "label": "Bottom Left" },
        { "value": "bottom-right", "label": "Bottom Right" },
        { "value": "bottom-center", "label": "Bottom Center" },
        { "value": "center", "label": "Center" },
        { "value": "center-right", "label": "Center Right" },
        { "value": "center-left", "label": "Center Left" },
        { "value": "cover", "label": "Cover" }
      ],
      "default": "top-left",
      "conditional": "setting.position == 'absolute'"
    },
    { "type": "header", "content": "Action Trigger" },
    {
      "type": "select",
      "id": "trigger",
      "label": "Trigger",
      "default": "none",
      "options": [
        { "value": "link", "label": "Link" },
        { "value": "action", "label": "Action" },
        { "value": "none", "label": "None" }
      ]
    },
    { "type": "url", "id": "link", "label": "Link", "conditional": "setting.trigger == 'link'" },
    {
      "type": "select",
      "id": "link_target",
      "label": "Open link in",
      "options": [
        { "value": "_blank", "label": "New Tab" },
        { "value": "_self", "label": "Current Tab" }
      ],
      "default": "_self",
      "conditional": "setting.trigger == 'link'"
    },
    { "type": "text", "id": "action", "label": "Action Type", "conditional": "setting.trigger == 'action'" },
    { "type": "text", "id": "action_args", "label": "Action Arguments", "conditional": "setting.trigger == 'action'" },
    { "type": "header", "content": "General Styles" },
    {
      "type": "select",
      "subtype": "cursor",
      "id": "cursor",
      "label": "Cursor",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "pointer", "label": "Pointer" },
        { "value": "not-allowed", "label": "Not Allowed" },
        { "value": "help", "label": "Help" },
        { "value": "none", "label": "None" },
        { "value": "inherit", "label": "Inherit" }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "width_scheme",
      "id": "width_scheme",
      "label": "Max Content Width",
      "default": "full"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "full", "label": "Full Height" }
      ],
      "default": "auto"
    },
    { "type": "header", "content": "Padding/Margins" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "XL" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "XL" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "select",
      "id": "margin_vertical",
      "label": "Vertical margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "auto", "label": "Auto" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_top",
      "label": "Custom Top margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_bottom",
      "label": "Custom Bottom margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "select",
      "id": "margin_horizontal",
      "label": "Horizontal margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "auto", "label": "Auto" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_left",
      "label": "Custom Left margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_right",
      "label": "Custom Right margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "select",
      "id": "gap",
      "label": "Gap",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "XL" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "gap_custom",
      "label": "Custom Gap",
      "min": 0,
      "max": 6,
      "step": 0.25,
      "default": 1,
      "unit": "rem",
      "conditional": "setting.gap == 'custom'"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    { "type": "checkbox", "id": "animate_float", "label": "Float", "default": false },
    { "type": "checkbox", "id": "animate_scale_in", "label": "Scale In", "default": false },
    { "type": "checkbox", "id": "animate_stagger", "label": "Stagger", "default": false },
    { "type": "checkbox", "id": "animate_shadow_hover", "label": "Hover Shadow", "default": false },
    {
      "type": "select",
      "id": "animate_fade",
      "label": "Fade Animation",
      "default": "none",
      "options": [
        { "value": "in", "label": "In" },
        { "value": "up", "label": "Up" },
        { "value": "none", "label": "None" }
      ]
    },
    {
      "type": "header",
      "content": "Style"
    },
    { "type": "checkbox", "id": "inherit_styles", "label": "Inherit Theme Styles", "default": true },
    { "type": "checkbox", "id": "shadow", "label": "Show Shadow", "default": false },
    { "type": "checkbox", "id": "enable_glass", "label": "Glass Effect", "default": false },
    { "type": "checkbox", "id": "overflow_hidden", "label": "Clip Content", "default": false },
    {
      "type": "range",
      "id": "rotation",
      "label": "Rotation",
      "min": 0,
      "max": 90,
      "step": 1,
      "default": 0,
      "unit": "deg"
    },
    {
      "type": "header",
      "content": "Borders"
    },
    {
      "type": "select",
      "id": "border_mode",
      "label": "Border",
      "default": "none",
      "options": [
        { "value": "custom", "label": "Custom" },
        { "value": "full", "label": "Full" },
        { "value": "none", "label": "None" }
      ]
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border Style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "dotted", "label": "Dotted" },
        { "value": "double", "label": "Double" }
      ]
    },
    {
      "type": "checkbox",
      "id": "border_custom_left",
      "label": "Border Left",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_right",
      "label": "Border Right",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_top",
      "label": "Border Top",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_bottom",
      "label": "Border Bottom",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "select",
      "id": "border_size",
      "label": "Border Size",
      "options": [
        { "value": "xxs", "label": "XXS", "info": "1px" },
        { "value": "xs", "label": "XS", "info": "2px" },
        { "value": "sm", "label": "Small", "info": "4px" },
        { "value": "md", "label": "Medium", "info": "6px" },
        { "value": "lg", "label": "Large", "info": "8px" }
      ],
      "default": "md",
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "header",
      "content": "Overlay Style"
