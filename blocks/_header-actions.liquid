{% assign s = block.settings %}

{% assign scheme_class = blank %}

{% if s.surface_override %}
  {% assign scheme_class = "surface-{{ s.surface_id | default: 'default' }}" %}
{% endif %}

{% assign text_color_class = blank %}
{% if s.text_role != blank and s.text_role != 'inherit' %}
  {% assign text_color_class = 'text-' | append: s.text_role %}
{% endif %}

{% assign actions_classes = 'header-actions flex'
  | push: 'direction-{{ s.direction }}'
  | push: 'gap-{{ s.gap }}'
  | push: scheme_class
  | push: text_color_class
%}
{% if s.vertical_align != blank %}
  {% assign actions_classes = actions_classes | push: 'vertical-{{ s.vertical_align }}' %}
{% endif %}
{% if s.content_align != blank %}
  {% assign actions_classes = actions_classes | push: 'content-{{ s.content_align }}' %}
{% endif %}

<div
  class='{{ actions_classes | join: ' ' }}'
  style='{% if s.gap == 'custom' %}--space-gap: {{ s.gap_custom }}rem;{% endif %}'
  {{ context.attached_attributes }}
>
  <div class='header-actions-children'>
    {% content_for 'blocks' %}
  </div>
</div>

{% schema %}
{
  "name": "Header Actions",
  "settings": [
    {
      "type": "header",
      "content": "Theme"
    },
    {
      "type": "select",
      "id": "text_role",
      "label": "Text Color Role",
      "info": "Defaults to inheriting the header section's text role.",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Inherit from Header" },
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "subtle", "label": "Subtle" },
        { "value": "emphasis", "label": "Emphasis" },
        { "value": "on-accent", "label": "On Accent" },
        { "value": "on-button", "label": "On Button" },
        { "value": "on-control", "label": "On Control" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        {
          "value": "row",
          "label": "Row"
        },
        {
          "value": "column",
          "label": "Column"
        },
        {
          "value": "responsive",
          "label": "Responsive"
        }
      ],
      "default": "row"
    },
    {
      "type": "select",
      "id": "vertical_align",
      "label": "Vertical Align",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "middle",
          "label": "Middle"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        },
        {
          "value": "stretch",
          "label": "Stretch"
        }
      ],
      "default": "middle"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content Align",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "between",
          "label": "Space Between"
        }
      ],
      "default": "left"
    },
    {
      "type": "space",
      "id": "gap",
      "label": "Gap",
      "default": "sm"
    },
    {
      "type": "range",
      "id": "gap_custom",
      "label": "Custom Gap",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 1,
      "unit": "rem",
      "conditional": "setting.gap == 'custom'"
    },
    {
      "type": "header",
      "content": "Overrides"
    },
    {
      "type": "checkbox",
      "id": "surface_override",
      "label": "Override Color Scheme",
      "default": false
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Color Scheme",
      "default": "default",
      "conditional": "setting.surface_override == true"
    }
  ],
  "blocks": [
    {
      "type": "button"
    },
    {
      "type": "group"
    }
  ],
  "presets": [
    {
      "name": "Action Button",
      "settings": {},
      "blocks": {},
      "block_order": []
    }
  ]
}
{% endschema %}
