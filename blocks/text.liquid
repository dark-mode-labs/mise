{% assign s = block.settings %}

{% comment %} --- Wrapper Classes --- {% endcomment %}
{% assign wrapper_classes = 'text-align-{{ s.text_align }}'
  | push: 'margin-my-{{ s.margin_vertical }}'
  | push: 'margin-mx-{{ s.margin_horizontal }}'
%}

{% if s.numeric == 'tabular' %}
  {% assign wrapper_classes = wrapper_classes | push: 'tabular-nums min-w-[3ch]' %}
{% endif %}

{% if s.surface_override == false and s.surface_override == true %}
  {% assign wrapper_classes = wrapper_classes | push: "surface-{{ s.surface_id | default: 'default' }}" %}
{% endif %}

{% assign wrapper_class_str = wrapper_classes | join: ' ' %}

{% comment %} --- Styles Array Building --- {% endcomment %}
{% assign styles = blank %}

{% if s.margin_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-mt: {{ s.margin_vertical_custom_top }}rem'
    | push: '--space-mb: {{ s.margin_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.margin_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-pl: {{ s.margin_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.margin_horizontal_custom_right }}rem'
  %}
{% endif %}

{% if s.text_tracking == 'custom' %}
  {% assign styles = styles | push: '--text-tracking: {{ s.text_tracking_custom }}em' %}
{% endif %}

{% if s.text_leading == 'custom' %}
  {% assign styles = styles | push: '--text-leading: {{ s.text_leading_custom | divided_by: 100.0 }}' %}
{% endif %}

{% unless s.surface_override == false %}
  {% assign styles = styles | push_if: '--text: {{ s.text_color }}', s.text_color_override %}
{% endunless %}

{% assign wrapper_style_str = styles | join: ';' %}

{% comment %} --- Typography Utilities --- {% endcomment %}
{% assign utilities = blank | push_if: 'italic', s.italic | push_if: 'hyphens-auto', s.enable_hyphens %}

{% unless s.text_transform == 'none' %}
  {% assign utilities = utilities | push: s.text_transform %}
{% endunless %}

{% case s.text_wrap %}
  {% when 'nowrap' -%}
    {%- assign utilities = utilities | push: 'whitespace-nowrap' %}
  {% when 'balance' -%}
    {%- assign utilities = utilities | push: 'text-balance' %}
{% endcase %}

{% case s.overflow_behavior %}
  {% when 'hidden' -%}
    {%- assign utilities = utilities | push: 'overflow-hidden' %}
  {% when 'ellipsis' -%}
    {%- assign utilities = utilities | push: 'truncate' %}
{% endcase %}

{% assign utility_classes = utilities | join: ' ' %}

{% comment %} --- Font & Color Logic --- {% endcomment %}
{% assign font_family = blank %}
{% if s.font_family_override and s.font_scheme != blank %}
  {% assign font_family = s.font_scheme %}
{% endif %}

{% assign color_role = s.text_role %}
{% unless s.surface_override == false %}
  {% if s.text_color_override %}
    {% assign color_role = 'primary' %}
  {% endif %}
{% endunless %}

{% comment %} --- Component Render --- {% endcomment %}
<div
  class="{{ wrapper_class_str }}"
  style="{{ wrapper_style_str }}"
  {{ context.attached_attributes }}
>
  {% render 'typography',
    text: s.content,
    tag: s.tag,
    display_size: s.display_size,
    weight: s.font_weight,
    class: utility_classes,
    tracking: s.text_tracking,
    leading: s.text_leading,
    family: font_family,
    color_role: color_role
  %}
</div>

{% schema %}
{
  "name": "Text",
  "settings": [
    {
      "type": "textarea",
      "id": "content",
      "label": "Content",
      "default": "Locally sourced ingredients."
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "tag",
      "label": "HTML Tag",
      "default": "div",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "p", "label": "Paragraph" },
        { "value": "div", "label": "Div" },
        { "value": "span", "label": "Span" }
      ]
    },
    {
      "type": "select",
      "id": "display_size",
      "label": "Size",
      "default": "base",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "display", "label": "Display" },
        { "value": "body", "label": "Body" },
        { "value": "caption", "label": "Caption" },
        { "value": "small", "label": "Small" },
        { "value": "jumbo", "label": "Jumbo" },
        { "value": "base", "label": "Base" }
      ]
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Alignment",
      "options": [
        { "value": "", "label": "Inherit" },
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": ""
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Weight",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "medium", "label": "Medium" },
        { "value": "bold", "label": "Bold" },
        { "value": "extrabold", "label": "Extra Bold" },
        { "value": "black", "label": "Black" }
      ],
      "default": "normal"
    },
    {
      "type": "select",
      "id": "numeric",
      "label": "Number Style",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "tabular", "label": "Tabular" }
      ]
    },
    {
      "type": "select",
      "id": "text_tracking",
      "label": "Tracking",
      "options": [
        { "value": "tighter", "label": "Tighter" },
        { "value": "tight", "label": "Tight" },
        { "value": "normal", "label": "Normal" },
        { "value": "wide", "label": "Wide" },
        { "value": "wider", "label": "Wider" },
        { "value": "widest", "label": "Widest" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "normal"
    },
    {
      "type": "range",
      "id": "text_tracking_custom",
      "label": "Custom Tracking",
      "min": -0.1,
      "max": 0.5,
      "step": 0.025,
      "default": 0,
      "unit": "em",
      "conditional": "setting.text_tracking == 'custom'"
    },
    {
      "type": "select",
      "id": "text_leading",
      "label": "Leading",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "tight", "label": "Tight" },
        { "value": "snug", "label": "Snug" },
        { "value": "normal", "label": "Normal" },
        { "value": "relaxed", "label": "Relaxed" },
        { "value": "loose", "label": "Loose" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "normal"
    },
    {
      "type": "range",
      "id": "text_leading_custom",
      "label": "Custom Leading",
      "min": 80,
      "max": 200,
      "step": 5,
      "default": 100,
      "unit": "%",
      "conditional": "setting.text_leading == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "italic",
      "label": "Italic",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_hyphens",
      "label": "Hyphenate",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "font_family_override",
      "label": "Override Font",
      "default": false
    },
    {
      "type": "font_scheme",
      "id": "font_scheme",
      "label": "Font",
      "default": "",
      "conditional": "setting.font_family_override == true"
    },
    {
      "type": "header",
      "content": "Layout & Style"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text Transform",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" },
        { "value": "lowercase", "label": "Lowercase" }
      ]
    },
    {
      "type": "select",
      "id": "text_wrap",
      "label": "Text Wrapping",
      "default": "wrap",
      "options": [
        { "value": "wrap", "label": "Wrap" },
        { "value": "nowrap", "label": "No Wrap" },
        { "value": "balance", "label": "Balance" }
      ]
    },
    {
      "type": "select",
      "id": "overflow_behavior",
      "label": "Overflow",
      "default": "visible",
      "options": [
        { "value": "visible", "label": "Visible" },
        { "value": "hidden", "label": "Hidden (Clip)" },
        { "value": "ellipsis", "label": "Ellipsis (Truncate)" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "margin_vertical",
      "label": "Vertical margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "auto", "label": "Auto" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_top",
      "label": "Custom Top margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_bottom",
      "label": "Custom Bottom margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "select",
      "id": "margin_horizontal",
      "label": "Horizontal margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "auto", "label": "Auto" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_left",
      "label": "Custom Left margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_right",
      "label": "Custom Right margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "text_role",
      "label": "Text Color Role",
      "default": "primary",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "subtle", "label": "Subtle" },
        { "value": "accent", "label": "Accent" }
      ]
    },
    {
      "type": "header",
      "content": "Overrides",
      "conditional": "true"
    },
    {
      "type": "checkbox",
      "id": "surface_override",
      "label": "Override Color Scheme",
      "default": false,
      "conditional": "true"
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Color Scheme",
      "default": "default",
      "conditional": "setting.surface_override == true"
    },
    {
      "type": "checkbox",
      "id": "text_color_override",
      "label": "Override Text Color",
      "default": false,
      "conditional": "true"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Custom Color",
      "default": "#ffffff",
      "conditional": "true and setting.text_color_override"
    }
  ]
}
{% endschema %}
