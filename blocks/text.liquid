{% assign s = block.settings %}

{% comment %} --- Wrapper Classes --- {% endcomment %}
{% assign wrapper_classes = '' | push: 'margin-my-{{ s.margin_vertical }}' | push: 'margin-mx-{{ s.margin_horizontal }}' %}
{% if s.text_align != blank %}
  {% assign wrapper_classes = wrapper_classes | push: 'text-align-{{ s.text_align }}' %}
{% endif %}

{% if s.numeric == 'tabular' %}
  {% assign wrapper_classes = wrapper_classes | push: 'tabular-nums min-w-[3ch]' %}
{% endif %}

{% if s.surface_override %}
  {% assign wrapper_classes = wrapper_classes | push: "surface-{{ s.surface_id | default: 'default' }}" %}
{% endif %}

{% assign wrapper_class_str = wrapper_classes | join: ' ' %}

{% comment %} --- Styles Array Building --- {% endcomment %}
{% assign text_color_value = blank %}
{% if s.text_role == 'palette' and s.text_role_palette != blank %}
  {% assign text_color_value = 'var(--palette-{{ s.text_role_palette }})' %}
{% elsif s.text_role == 'custom' and s.text_role_custom != blank %}
  {% assign text_color_value = s.text_role_custom %}
{% endif %}
{% assign styles = blank %}

{% if s.margin_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-mt: {{ s.margin_vertical_custom_top }}rem'
    | push: '--space-mb: {{ s.margin_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.margin_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-ml: {{ s.margin_horizontal_custom_left }}rem'
    | push: '--space-mr: {{ s.margin_horizontal_custom_right }}rem'
  %}
{% endif %}

{% if text_color_value != blank %}
  {% assign styles = styles | push: '--text: {{ text_color_value }}' %}
{% endif %}
{% assign wrapper_style_str = styles | join: ';' %}

{% comment %} --- Typography Utilities --- {% endcomment %}
{% assign utilities = blank | push_if: 'italic', s.italic | push_if: 'hyphens-auto', s.enable_hyphens %}

{% case s.text_wrap %}
  {% when 'nowrap' -%}
    {%- assign utilities = utilities | push: 'whitespace-nowrap' %}
  {% when 'balance' -%}
    {%- assign utilities = utilities | push: 'text-balance' %}
{% endcase %}

{% case s.overflow_behavior %}
  {% when 'hidden' -%}
    {%- assign utilities = utilities | push: 'overflow-hidden' %}
  {% when 'ellipsis' -%}
    {%- assign utilities = utilities | push: 'truncate' %}
{% endcase %}

{% assign utility_classes = utilities | join: ' ' %}

{% assign color_role = s.text_role %}
{% if s.text_role == 'custom' or s.text_role == 'palette' %}
  {% comment %} Both routes paint via `var(--text)` (set inline above). {% endcomment %}
  {% assign color_role = 'primary' %}
{% endif %}
{% comment %} --- Component Render --- {% endcomment %}
<div
  class="{{ wrapper_class_str }}"
  style="{{ wrapper_style_str }}"
  {{ context.attached_attributes }}
>
  {% render 'typography',
    text: s.content,
    tag: s.tag,
    type_style: s.type_style,
    class: utility_classes,
    color_role: color_role
  %}
</div>

{% schema %}
{
  "name": "Text",
  "settings": [
    {
      "type": "textarea",
      "id": "content",
      "label": "Content",
      "default": "Locally sourced ingredients."
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "type_style",
      "id": "type_style",
      "label": "Type Style",
      "info": "References a Tier-2 type-style entry \u2014 bundles font family, size, weight, tracking, leading, transform into one named treatment.",
      "default": "body"
    },
    {
      "type": "select",
      "id": "tag",
      "label": "HTML Tag",
      "default": "div",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        },
        {
          "value": "p",
          "label": "Paragraph"
        },
        {
          "value": "div",
          "label": "Div"
        },
        {
          "value": "span",
          "label": "Span"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Alignment",
      "options": [
        {
          "value": "",
          "label": "Inherit"
        },
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": ""
    },
    {
      "type": "select",
      "id": "numeric",
      "label": "Number Style",
      "default": "default",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "tabular",
          "label": "Tabular"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "italic",
      "label": "Italic",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_hyphens",
      "label": "Hyphenate",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout & Style"
    },
    {
      "type": "select",
      "id": "text_wrap",
      "label": "Text Wrapping",
      "default": "wrap",
      "options": [
        {
          "value": "wrap",
          "label": "Wrap"
        },
        {
          "value": "nowrap",
          "label": "No Wrap"
        },
        {
          "value": "balance",
          "label": "Balance"
        }
      ]
    },
    {
      "type": "select",
      "id": "overflow_behavior",
      "label": "Overflow",
      "default": "visible",
      "options": [
        {
          "value": "visible",
          "label": "Visible"
        },
        {
          "value": "hidden",
          "label": "Hidden (Clip)"
        },
        {
          "value": "ellipsis",
          "label": "Ellipsis (Truncate)"
        }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "space",
      "id": "margin_vertical",
      "label": "Vertical margin",
      "default": "none"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_top",
      "label": "Custom Top margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_bottom",
      "label": "Custom Bottom margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "space",
      "id": "margin_horizontal",
      "label": "Horizontal margin",
      "default": "none"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_left",
      "label": "Custom Left margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_right",
      "label": "Custom Right margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "text_role",
      "label": "Text Color Role",
      "default": "primary",
      "options": [
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "secondary",
          "label": "Secondary"
        },
        {
          "value": "subtle",
          "label": "Subtle"
        },
        {
          "value": "emphasis",
          "label": "Emphasis"
        },
        {
          "value": "on-accent",
          "label": "On Accent"
        },
        {
          "value": "on-button",
          "label": "On Button"
        },
        {
          "value": "on-control",
          "label": "On Control"
        },
        {
          "value": "palette",
          "label": "Base Palette"
        },
        {
          "value": "custom",
          "label": "Raw Color"
        }
      ]
    },
    {
      "type": "palette",
      "id": "text_role_palette",
      "label": "Text Palette Token",
      "info": "Picks a named brand-palette token. Updates follow palette edits.",
      "default": "brand",
      "conditional": "setting.text_role == 'palette'"
    },
    {
      "type": "color",
      "id": "text_role_custom",
      "label": "Raw Text Color",
      "conditional": "setting.text_role == 'custom'"
    },
    {
      "type": "header",
      "content": "Overrides",
      "conditional": "true"
    },
    {
      "type": "checkbox",
      "id": "surface_override",
      "label": "Override Color Scheme",
      "default": false,
      "conditional": "true"
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Color Scheme",
      "default": "default",
      "conditional": "setting.surface_override == true"
    }
  ]
}
{% endschema %}
