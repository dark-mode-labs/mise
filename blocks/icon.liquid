{% assign s = block.settings %}

{% comment %} --- Wrapper Classes --- {% endcomment %}
{% assign classes = 'icon icon-size inline-flex items-center justify-center flex-shrink-0 text-body'
  | push: 'margin-my-{{ s.margin_vertical }}'
  | push: 'margin-mx-{{ s.margin_horizontal }}'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
%}

{% if s.inherit_styles == false and s.color_scheme_override == true %}
  {% assign classes = classes | push: "color-{{ s.color_scheme | default: 'none' }}" %}
{% endif %}

{% assign block_classes = classes | join: ' ' %}

{% comment %} --- Styles Array Building --- {% endcomment %}
{% assign styles = blank %}

{% if s.padding_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.padding_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}

{% if s.margin_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-mt: {{ s.margin_vertical_custom_top }}rem'
    | push: '--space-mb: {{ s.margin_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.margin_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-ml: {{ s.margin_horizontal_custom_left }}rem'
    | push: '--space-mr: {{ s.margin_horizontal_custom_right }}rem'
  %}
{% endif %}

{% assign styles = styles | push: '--icon-size: {{ s.icon_size }}rem' %}

{% unless s.inherit_styles %}
  {% assign styles = styles | push_if: '--color-text: {{ s.text_color }}', s.text_color_override %}
{% endunless %}

{% assign block_styles = styles | join: ';' %}

{% comment %} --- Component Render --- {% endcomment %}
<div
  class="{{ block_classes }}"
  style="{{ block_styles }}"
  {{ context.attached_attributes }}
>
  {{ s.svg }}
</div>

{% schema %}
{
  "name": "Icon",
  "settings": [
    {
      "type": "textarea",
      "id": "svg",
      "label": "SVG",
      "default": "<svg fill=\"currentColor\" stroke=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z\" clip-rule=\"evenodd\"/></svg>"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Size",
      "min": 0.75,
      "max": 8,
      "step": 0.25,
      "default": 1.5,
      "unit": "rem"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "select",
      "id": "margin_vertical",
      "label": "Vertical Margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "auto", "label": "Auto" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_top",
      "label": "Custom Top Margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_bottom",
      "label": "Custom Bottom Margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "select",
      "id": "margin_horizontal",
      "label": "Horizontal Margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "auto", "label": "Auto" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_left",
      "label": "Custom Left Margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_right",
      "label": "Custom Right Margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "checkbox",
      "id": "inherit_styles",
      "label": "Inherit Theme Colors",
      "default": true
    },
    {
      "type": "header",
      "content": "Overrides",
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "checkbox",
      "id": "color_scheme_override",
      "label": "Override Color Scheme",
      "default": false,
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "default",
      "conditional": "setting.inherit_styles != true and setting.color_scheme_override == true"
    },
    {
      "type": "checkbox",
      "id": "text_color_override",
      "label": "Override Icon Color",
      "default": false,
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Custom Color",
      "default": "#000000",
      "conditional": "setting.inherit_styles != true and setting.text_color_override"
    }
  ]
}
{% endschema %}
