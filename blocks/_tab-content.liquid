{% assign s = block.settings %}

{% assign hide_class = 'aria-[expanded=false]:hidden' %}
{% if s.mode == 'spy' %}{% assign hide_class = '' %}{% endif %}

<div
  {{ context.attached_attributes }}
  class='tab-content scroll-mt-40 {{ hide_class }}'
  data-behavior='tab-content'
  data-action-args='{{ s.tab_id }}'
  data-tab-group='{{ section.id }}'
  {% if s.mode == 'spy' %}
    data-spy-target='{{ s.tab_id }}'
  {% endif %}
  aria-expanded='false'
>
  {% content_for 'blocks' %}
</div>
{% schema %}
{
  "name": "Tab Content",
  "settings": [
    {
      "type": "type_style",
      "id": "type_style",
      "label": "Type Style",
      "default": "body"
    },
    {
      "type": "header",
      "content": "Binding"
    },
    {
      "type": "text",
      "id": "tab_id",
      "label": "Tab Identifier",
      "default": "{{ context.item.uuid }}"
    },
    {
      "type": "select",
      "id": "mode",
      "label": "Visibility Mode",
      "default": "tab",
      "info": "Tab: only the active tab's content is visible. Spy: all content stays visible; the matching head highlights as this content scrolls into view.",
      "options": [
        {
          "value": "tab",
          "label": "Tab (hide when inactive)"
        },
        {
          "value": "spy",
          "label": "Scroll Spy (always visible)"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    }
  ],
  "presets": [
    {
      "name": "Tab Content",
      "settings": {},
      "blocks": {
        "items-in-collection": {
          "type": "group",
          "settings": {
            "layout_mode": "grid",
            "gap": "md"
          },
          "blocks": {
            "menu-card-full": {
              "type": "menu-card-full",
              "settings": {
                "bind_to": "parent.items",
                "gap": "none",
                "shadow": true
              },
              "blocks": {
                "menu-card-header": {
                  "type": "group",
                  "name": "Heading",
                  "static": true,
                  "settings": {
                    "gap": "none",
                    "padding_vertical": "none",
                    "padding_horizontal": "none"
                  },
                  "blocks": {
                    "img": {
                      "type": "media",
                      "settings": {
                        "image": "{{ context.item.asset.url }}",
                        "object_fit": "cover",
                        "aspect_ratio": "landscape"
                      }
                    }
                  },
                  "block_order": ["img"]
                },
                "menu-card-content": {
                  "type": "group",
                  "name": "Content",
                  "static": true,
                  "settings": {
                    "gap": "sm",
                    "padding_vertical": "xs",
                    "padding_horizontal": "md",
                    "grow_content": true
                  },
                  "blocks": {
                    "desc": {
                      "type": "text",
                      "settings": {
                        "content": "{{ context.item.description }}",
                        "text_align": "left",
                        "type_style": "caption"
                      }
                    },
                    "info": {
                      "type": "group",
                      "blocks": {
                        "price": {
                          "type": "text",
                          "settings": {
                            "tag": "span",
                            "content": "{{ context.item.formatted_price }}",
                            "text_align": "right",
                            "type_style": "body"
                          }
                        },
                        "title": {
                          "type": "text",
                          "settings": {
                            "tag": "h3",
                            "content": "{{ context.item.name }}",
                            "text_wrap": "balance",
                            "text_align": "left",
                            "type_style": "body"
                          }
                        }
                      },
                      "settings": {
                        "gap": "xs",
                        "width": "full",
                        "direction": "row",
                        "content_align": "between",
                        "vertical_align": "top",
                        "padding_vertical": "xs",
                        "padding_horizontal": "none"
                      },
                      "block_order": ["title", "price"]
                    }
                  },
                  "block_order": ["info", "desc"]
                },
                "menu-card-footer": {
                  "type": "group",
                  "name": "Footer",
                  "static": true,
                  "settings": {
                    "gap": "xs",
                    "padding_vertical": "xs",
                    "padding_horizontal": "md"
                  },
                  "blocks": {
                    "btn": {
                      "type": "button",
                      "settings": {
                        "label": "Order Now",
                        "width": "full",
                        "content_align": "center",
                        "trigger": "action",
                        "action": "add-item"
                      }
                    }
                  },
                  "block_order": ["btn"]
                }
              },
              "block_order": ["menu-card-header", "menu-card-content", "menu-card-footer"]
            }
          },
          "block_order": ["menu-card-full"]
        }
      },
      "block_order": ["items-in-collection"]
    }
  ]
}
{% endschema %}
