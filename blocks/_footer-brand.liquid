{% assign s = block.settings %}

{% assign scheme_class = blank %}

{% if s.inherit_styles == false and s.color_scheme_override == true %}
  {% assign scheme_class="color-{{ s.color_scheme | default: 'none' }}" %}
{% endif %}

<div
  class="footer-block flex flex-col gap-6 items-start {{ scheme_class }}"
  {{ context.attached_attributes }}
>
  {% content_for 'blocks' %}
</div>

{% schema %}
{
  "name": "Brand & Socials",
  "blocks": [{ "type": "@theme" }],
  "settings": [
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "checkbox",
      "id": "inherit_styles",
      "label": "Inherit Styles",
      "default": true
    },
    {
      "type": "header",
      "content": "Overrides",
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "checkbox",
      "id": "color_scheme_override",
      "label": "Override Color Scheme",
      "default": false,
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "default",
      "conditional": "setting.inherit_styles != true and setting.color_scheme_override == true"
    }
  ]
}
{% endschema %}
