{% assign s = block.settings %}

{% comment %} --- Wrapper Classes --- {% endcomment %}
{% assign classes = 'flex-col hidden group-open:flex md:flex' | push: 'gap-{{ s.gap }}' %}

{% if s.surface_override %}
  {% assign classes = classes | push: "surface-{{ s.surface_id | default: 'default' }}" %}
{% endif %}

{% assign block_classes = classes | join: ' ' %}

{% comment %} --- Styles Array Building --- {% endcomment %}
{% assign _is_custom_text = false %}
{% if s.text_role == 'custom' %}{% assign _is_custom_text = true %}{% endif %}
{% assign styles = blank %}

{% if s.gap == 'custom' %}
  {% assign styles = styles | push: '--space-gap: {{ s.gap_custom }}rem' %}
{% endif %}

{% assign styles = styles | push_if: '--text: {{ s.text_role_custom }}', _is_custom_text %}

{% assign block_styles = styles | join: ';' %}

{% comment %} --- Typography Utilities --- {% endcomment %}
{% assign utilities = blank %}

{% case s.text_wrap %}
  {% when 'nowrap' %}
    {% assign utilities = utilities | push: 'whitespace-nowrap' %}
  {% when 'balance' %}
    {% assign utilities = utilities | push: 'text-balance' %}
{% endcase %}

{% if s.text_transform != 'none' %}
  {% assign utilities = utilities | push: s.text_transform %}
{% endif %}

{% assign utility_classes = utilities | join: ' ' %}

{% comment %} --- Font Family --- {% endcomment %}
{% assign font_family = 'btn' %}
{% if s.font_family_override and s.font_scheme != blank %}
  {% assign font_family = s.font_scheme %}
{% endif %}

{% comment %} --- Component Render --- {% endcomment %}
{% assign color_role = s.text_role %}
{% if s.text_role == 'custom' %}{% assign color_role = 'primary' %}{% endif %}
<ul
  class="{{ block_classes }}"
  style="{{ block_styles }}"
  {{ context.attached_attributes }}
>
  {% for link in s.nav.links %}
    <li>
      <a
        href="{{ link.url }}"
        class="hover:opacity-70 transition-opacity block"
      >
        {% render 'typography',
          text: link.title,
          display_size: s.display_size,
          weight: s.font_weight,
          family: font_family,
          class: utility_classes,
          color_role: color_role
        %}
      </a>
    </li>
  {% endfor %}
</ul>

{% schema %}
{
  "name": "Nav",
  "settings": [
    { "type": "link_list", "id": "nav", "label": "Menu", "default": "footer" },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "display_size",
      "label": "Size",
      "default": "body",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "display", "label": "Display" },
        { "value": "body", "label": "Body" },
        { "value": "caption", "label": "Caption" },
        { "value": "small", "label": "Small" },
        { "value": "jumbo", "label": "Jumbo" }
      ]
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Weight",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "medium", "label": "Medium" },
        { "value": "bold", "label": "Bold" },
        { "value": "extrabold", "label": "Extra Bold" },
        { "value": "black", "label": "Black" }
      ],
      "default": "normal"
    },
    {
      "type": "select",
      "id": "text_wrap",
      "label": "Text Wrapping",
      "default": "nowrap",
      "options": [
        { "value": "wrap", "label": "Wrap" },
        { "value": "nowrap", "label": "No Wrap" },
        { "value": "balance", "label": "Balance" }
      ]
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text Transform",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" },
        { "value": "lowercase", "label": "Lowercase" }
      ]
    },
    {
      "type": "select",
      "id": "text_role",
      "label": "Text Color Role",
      "default": "button",
      "options": [
        { "value": "primary",    "label": "Primary" },
        { "value": "secondary",  "label": "Secondary" },
        { "value": "subtle",     "label": "Subtle" },
        { "value": "emphasis",   "label": "Emphasis" },
        { "value": "on-accent",  "label": "On Accent" },
        { "value": "on-button",  "label": "On Button" },
        { "value": "on-control", "label": "On Control" },
        { "value": "custom",     "label": "Custom" }
      ]
    },
    {
      "type": "color",
      "id": "text_role_custom",
      "label": "Custom Text",
      "info": "Free hex or CSS gradient. Used only when Text role = Custom.",
      "conditional": "setting.text_role == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "font_family_override",
      "label": "Override Font",
      "default": false
    },
    {
      "type": "font_scheme",
      "id": "font_scheme",
      "label": "Font",
      "default": "",
      "conditional": "setting.font_family_override == true"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "gap",
      "label": "Gap",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "XL" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "xs"
    },
    {
      "type": "range",
      "id": "gap_custom",
      "label": "Custom Gap",
      "min": 0,
      "max": 6,
      "step": 0.25,
      "default": 1,
      "unit": "rem",
      "conditional": "setting.gap == 'custom'"
    },
    {
      "type": "header",
      "content": "Style"
    },
        {
      "type": "header",
      "content": "Overrides",
      "conditional": "true"
    },
    {
      "type": "checkbox",
      "id": "surface_override",
      "label": "Override Color Scheme",
      "default": false,
      "conditional": "true"
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Color Scheme",
      "default": "default",
      "conditional": "setting.surface_override == true"
    }
  ]
}
{% endschema %}
