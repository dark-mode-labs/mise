{% assign s = block.settings %}

{% comment %} --- Color tokens --- {% endcomment %}
{% assign text_color_value = blank %}
{% if s.text_role == 'palette' and s.text_role_palette != blank %}
  {% assign text_color_value = 'var(--palette-{{ s.text_role_palette }})' %}
{% elsif s.text_role == 'custom' and s.text_role_custom != blank %}
  {% assign text_color_value = s.text_role_custom %}
{% endif %}
{% assign bg_color_value = blank %}
{% if s.bg_role == 'palette' and s.bg_role_palette != blank %}
  {% assign bg_color_value = 'var(--palette-{{ s.bg_role_palette }})' %}
{% elsif s.bg_role == 'gradient' and s.bg_role_gradient != blank %}
  {% assign bg_color_value = 'var(--gradient-{{ s.bg_role_gradient }})' %}
{% elsif s.bg_role == 'custom' and s.bg_role_custom != blank %}
  {% assign bg_color_value = s.bg_role_custom %}
{% endif %}
{% assign border_color_value = blank %}
{% if s.border_role == 'palette' and s.border_role_palette != blank %}
  {% assign border_color_value = 'var(--palette-{{ s.border_role_palette }})' %}
{% elsif s.border_role == 'custom' and s.border_role_custom != blank %}
  {% assign border_color_value = s.border_role_custom %}
{% endif %}

{% assign radius_class = 'rounded-global' %}
{% if s.border_radius_override %}
  {% assign radius_class = 'rounded-custom' %}
{% endif %}

{% comment %} --- Wrapper classes --- {% endcomment %}
{% assign wrapper_classes = 'select-block relative inline-flex'
  | push: radius_class
  | push: 'width-{{ s.width }}'
  | push: 'margin-my-{{ s.margin_vertical }}'
  | push: 'margin-mx-{{ s.margin_horizontal }}'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
%}

{% if s.bg_role and s.bg_role != 'none' and s.bg_role != 'custom' and s.bg_role != 'palette' and s.bg_role != 'gradient' %}
  {% assign wrapper_classes = wrapper_classes | push: 'bg-{{ s.bg_role }}' %}
{% endif %}

{% if s.surface_override %}
  {% assign wrapper_classes = wrapper_classes | push: "surface-{{ s.surface_id | default: 'default' }}" %}
{% endif %}

{% unless s.border_mode == 'none' %}
  {% assign wrapper_classes = wrapper_classes
    | push: 'group-border-{{ s.border_mode }}'
    | push: 'group-border-size-{{ s.border_size }}'
  %}
  {% if s.border_role
    and s.border_role != 'none'
    and s.border_role != 'custom'
    and s.border_role != 'palette'
  %}
    {% assign wrapper_classes = wrapper_classes | push: 'border-{{ s.border_role }}' %}
  {% endif %}
{% endunless %}

{% assign wrapper_class_str = wrapper_classes | join: ' ' %}

{% comment %} --- Wrapper styles --- {% endcomment %}
{% assign styles = blank %}
{% if s.padding_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}
{% if s.padding_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}
{% if s.margin_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-mt: {{ s.margin_vertical_custom_top }}rem'
    | push: '--space-mb: {{ s.margin_vertical_custom_bottom }}rem'
  %}
{% endif %}
{% if s.margin_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-ml: {{ s.margin_horizontal_custom_left }}rem'
    | push: '--space-mr: {{ s.margin_horizontal_custom_right }}rem'
  %}
{% endif %}
{% if s.border_radius_override %}
  {% assign styles = styles | push: '--radius-custom: {{ s.border_radius }}px' %}
{% endif %}
{% unless s.border_mode == 'none' %}
  {% assign styles = styles | push: '--border-style: {{ s.border_style }}' %}
  {% if border_color_value != blank %}
    {% assign styles = styles | push: '--border: {{ border_color_value }}' %}
  {% endif %}
{% endunless %}
{% if text_color_value != blank %}
  {% assign styles = styles | push: '--text: {{ text_color_value }}' %}
{% endif %}
{% if bg_color_value != blank %}
  {% assign styles = styles | push: 'background: {{ bg_color_value }}' %}
{% endif %}
{% assign wrapper_style_str = styles | join: ';' %}

{% comment %} --- Render --- {% endcomment %}
<div
  class='{{ wrapper_class_str }}'
  style='{{ wrapper_style_str }}'
  {{ context.attached_attributes }}
>
  <select
    class='ts-{{ s.type_style }} w-full bg-transparent border-0 focus:outline-none cursor-pointer appearance-none pr-6'
    {% if s.aria_label != blank %}aria-label='{{ s.aria_label }}'{% endif %}
    {% if s.trigger == 'action' %}
      data-behavior='select-action'
      data-action='{{ s.action | escape }}'
      {% if s.action_group != blank %}data-action-group='{{ s.action_group | escape }}'{% endif %}
    {% endif %}
  >
    {% if s.placeholder != blank %}
      <option value='' disabled selected>{{ s.placeholder }}</option>
    {% endif %}
    {% content_for 'blocks' %}
  </select>
  {% render 'icon',
    name: 'chevron-down',
    class: 'absolute right-2 top-1/2 -translate-y-1/2 w-4 h-4 pointer-events-none'
  %}
</div>

{% schema %}
{
  "name": "Select",
  "settings": [
    {
      "type": "type_style",
      "id": "type_style",
      "label": "Type Style",
      "default": "body"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility Label"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder",
      "info": "Optional. Renders a disabled-selected first option."
    },
    {
      "type": "header",
      "content": "Trigger"
    },
    {
      "type": "select",
      "id": "trigger",
      "label": "Trigger",
      "default": "action",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "action",
          "label": "Action"
        }
      ]
    },
    {
      "type": "text",
      "id": "action",
      "label": "Action Type",
      "info": "Event dispatched on change (e.g. 'tab-switch'). Handled by select-action.js.",
      "conditional": "setting.trigger == 'action'"
    },
    {
      "type": "text",
      "id": "action_group",
      "label": "Action Group",
      "info": "Grouping id passed alongside the action (e.g. tab group id).",
      "conditional": "setting.trigger == 'action'"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "width",
      "id": "width",
      "label": "Width",
      "default": "fit"
    },
    {
      "type": "space",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "default": "xs"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "space",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "default": "sm"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "space",
      "id": "margin_vertical",
      "label": "Vertical Margin",
      "default": "none"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_top",
      "label": "Custom Top Margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_bottom",
      "label": "Custom Bottom Margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "space",
      "id": "margin_horizontal",
      "label": "Horizontal Margin",
      "default": "none"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_left",
      "label": "Custom Left Margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_right",
      "label": "Custom Right Margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "bg_role",
      "label": "Background",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "body", "label": "Body" },
        { "value": "body-alt", "label": "Body (alt)" },
        { "value": "surface", "label": "Surface" },
        { "value": "surface-alt", "label": "Surface (alt)" },
        { "value": "accent", "label": "Accent" },
        { "value": "control", "label": "Control" },
        { "value": "palette", "label": "Base Palette" },
        { "value": "custom", "label": "Raw Color" },
        { "value": "gradient", "label": "Gradient" }
      ]
    },
    {
      "type": "palette",
      "id": "bg_role_palette",
      "label": "Background Palette Token",
      "default": "brand",
      "conditional": "setting.bg_role == 'palette'"
    },
    {
      "type": "color",
      "id": "bg_role_custom",
      "label": "Raw Background",
      "conditional": "setting.bg_role == 'custom'"
    },
    {
      "type": "gradient",
      "id": "bg_role_gradient",
      "label": "Background Gradient",
      "conditional": "setting.bg_role == 'gradient'"
    },
    {
      "type": "select",
      "id": "text_role",
      "label": "Text Color",
      "default": "primary",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "subtle", "label": "Subtle" },
        { "value": "emphasis", "label": "Emphasis" },
        { "value": "palette", "label": "Base Palette" },
        { "value": "custom", "label": "Raw Color" }
      ]
    },
    {
      "type": "palette",
      "id": "text_role_palette",
      "label": "Text Palette Token",
      "default": "brand",
      "conditional": "setting.text_role == 'palette'"
    },
    {
      "type": "color",
      "id": "text_role_custom",
      "label": "Raw Text Color",
      "conditional": "setting.text_role == 'custom'"
    },
    {
      "type": "header",
      "content": "Borders"
    },
    {
      "type": "select",
      "id": "border_mode",
      "label": "Border",
      "default": "full",
      "options": [
        { "value": "full", "label": "Full" },
        { "value": "none", "label": "None" }
      ]
    },
    {
      "type": "select",
      "id": "border_role",
      "label": "Border Color",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "emphasis", "label": "Emphasis" },
        { "value": "palette", "label": "Base Palette" },
        { "value": "custom", "label": "Raw Color" }
      ],
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "palette",
      "id": "border_role_palette",
      "label": "Border Palette Token",
      "default": "brand",
      "conditional": "setting.border_role == 'palette' and setting.border_mode != 'none'"
    },
    {
      "type": "color",
      "id": "border_role_custom",
      "label": "Raw Border",
      "conditional": "setting.border_role == 'custom' and setting.border_mode != 'none'"
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border Style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "dotted", "label": "Dotted" }
      ],
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "select",
      "id": "border_size",
      "label": "Border Size",
      "default": "xxs",
      "options": [
        { "value": "xxs", "label": "XXS", "info": "1px" },
        { "value": "xs", "label": "XS", "info": "2px" },
        { "value": "sm", "label": "Small", "info": "4px" }
      ],
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "header",
      "content": "Overrides",
      "conditional": "true"
    },
    {
      "type": "checkbox",
      "id": "surface_override",
      "label": "Override Color Scheme",
      "default": false,
      "conditional": "true"
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Color Scheme",
      "default": "default",
      "conditional": "setting.surface_override == true"
    },
    {
      "type": "checkbox",
      "id": "border_radius_override",
      "label": "Override Border Radius",
      "default": false,
      "conditional": "true"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 1000,
      "label": "Radius",
      "default": 0,
      "unit": "px",
      "conditional": "setting.border_radius_override"
    }
  ],
  "blocks": [
    {
      "type": "_option"
    },
    {
      "type": "repeater"
    }
  ],
  "presets": [
    {
      "name": "Select",
      "settings": {
        "trigger": "none"
      },
      "blocks": {}
    }
  ]
}
{% endschema %}
