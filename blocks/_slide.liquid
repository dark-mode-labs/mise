{% assign s = block.settings %}

{% assign bg_color_value = blank %}
{% if s.bg_role == 'palette' and s.bg_role_palette != blank %}
  {% assign bg_color_value = 'var(--palette-{{ s.bg_role_palette }})' %}
{% elsif s.bg_role == 'gradient' and s.bg_role_gradient != blank %}
  {% assign bg_color_value = 'var(--gradient-{{ s.bg_role_gradient }})' %}
{% elsif s.bg_role == 'custom' and s.bg_role_custom != blank %}
  {% assign bg_color_value = s.bg_role_custom %}
{% endif %}
{% comment %} --- Slide Wrapper Classes --- {% endcomment %}
{% assign classes = 'slide-block w-[var(--slide-width)] md:w-[var(--slide-width-md)] flex-shrink-0 snap-start relative overflow-hidden' %}

{% comment %}
  Background layer: scheme-driven via .bg-<role>. Escape-hatch
  (bg_color_override) is rendered as inline style further down.
{% endcomment %}
{% if s.bg_role and s.bg_role != 'none' and s.bg_role != 'custom' and s.bg_role != 'palette' %}
  {% assign classes = classes | push: 'bg-{{ s.bg_role }}' %}
{% endif %}

{% assign classes = classes | push_if: "surface-{{ s.surface_id | default: 'default' }}", s.surface_override %}
{% assign slide_classes = classes | join: ' ' %}

{% comment %} --- Slide-level inline styles (bg escape-hatch + alpha) --- {% endcomment %}
{% assign slide_styles = blank %}
{% if bg_color_value != blank %}
  {% assign slide_styles = slide_styles | push: 'background: {{ bg_color_value }}' %}
{% endif %}
{% assign slide_style_str = slide_styles | join: ';' %}

{% comment %} --- Content Wrapper Classes --- {% endcomment %}
{% assign content_classes = 'wrapper absolute inset-0 z-content flex flex-col flex-auto gap-4'
  | push: 'section-align-content-{{ s.content_align }}'
  | push: 'section-align-v-{{ s.vertical_align }}'
  | push: 'section-align-text-{{ s.text_align }}'
%}

{% assign content_class_str = content_classes | join: ' ' %}

{% comment %} --- Media Placeholder --- {% endcomment %}
{% assign placeholder_name = '' %}
{% if s.show_placeholder %}
  {% assign placeholder_name = 'scene-1' %}
{% endif %}

{% comment %} --- Component Render --- {% endcomment %}
<div
  class="{{ slide_classes }}"
  style="{{ slide_style_str }}"
  {{ context.attached_attributes }}
>
  <div class="absolute inset-0 z-media">
    {% render 'media',
      src: s.image,
      src_mobile: s.image_mobile,
      video: s.video_url,
      fit: 'cover',
      placeholder: placeholder_name,
      animate: s.enable_zoom
    %}

    {% render 'bg-overlay',
      role: s.overlay_role,
      alpha: s.overlay_alpha,
      palette_token: s.overlay_role_palette,
      custom_color: s.overlay_role_custom,
      gradient_token: s.overlay_role_gradient
    %}
  </div>

  <div class="{{ content_class_str }}">
    {% content_for 'blocks' %}
  </div>
</div>

{% schema %}
{
  "name": "Slide",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4)"
    },
    {
      "type": "checkbox",
      "id": "show_placeholder",
      "label": "Show Placeholder",
      "default": true,
      "info": "Show a pattern when no image is selected."
    },
    {
      "type": "checkbox",
      "id": "enable_zoom",
      "label": "Enable Ken Burns (Zoom)",
      "default": false
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "select",
      "id": "overlay_role",
      "label": "Overlay",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "body",
          "label": "Body"
        },
        {
          "value": "body-alt",
          "label": "Body (alt)"
        },
        {
          "value": "surface",
          "label": "Surface"
        },
        {
          "value": "surface-alt",
          "label": "Surface (alt)"
        },
        {
          "value": "accent",
          "label": "Accent"
        },
        {
          "value": "button",
          "label": "Button"
        },
        {
          "value": "control",
          "label": "Control"
        },
        {
          "value": "palette",
          "label": "Base Palette"
        },
        {
          "value": "custom",
          "label": "Raw Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        }
      ]
    },
    {
      "type": "palette",
      "id": "overlay_role_palette",
      "label": "Overlay Palette Token",
      "info": "Picks a named brand-palette token. Updates follow palette edits.",
      "default": "brand",
      "conditional": "setting.overlay_role == 'palette'"
    },
    {
      "type": "color",
      "id": "overlay_role_custom",
      "label": "Raw Overlay",
      "conditional": "setting.overlay_role == 'custom'"
    },
    {
      "type": "gradient",
      "id": "overlay_role_gradient",
      "label": "Overlay Gradient",
      "info": "Picks a named gradient token from the site's gradient set.",
      "conditional": "setting.overlay_role == 'gradient'"
    },
    {
      "type": "range",
      "id": "overlay_alpha",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "%",
      "conditional": "setting.overlay_role != 'none' and setting.overlay_role != 'custom'"
    },
    {
      "type": "header",
      "content": "Alignment"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_align",
      "label": "Vertical Alignment",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "middle",
          "label": "Middle"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "middle"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "bg_role",
      "label": "Background",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "body",
          "label": "Body"
        },
        {
          "value": "body-alt",
          "label": "Body (alt)"
        },
        {
          "value": "surface",
          "label": "Surface"
        },
        {
          "value": "surface-alt",
          "label": "Surface (alt)"
        },
        {
          "value": "accent",
          "label": "Accent"
        },
        {
          "value": "button",
          "label": "Button"
        },
        {
          "value": "control",
          "label": "Control"
        },
        {
          "value": "palette",
          "label": "Base Palette"
        },
        {
          "value": "custom",
          "label": "Raw Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        }
      ]
    },
    {
      "type": "palette",
      "id": "bg_role_palette",
      "label": "Background Palette Token",
      "info": "Picks a named brand-palette token. Updates follow palette edits.",
      "default": "brand",
      "conditional": "setting.bg_role == 'palette'"
    },
    {
      "type": "color",
      "id": "bg_role_custom",
      "label": "Raw Background",
      "conditional": "setting.bg_role == 'custom'"
    },
    {
      "type": "gradient",
      "id": "bg_role_gradient",
      "label": "Background Gradient",
      "info": "Picks a named gradient token from the site's gradient set.",
      "conditional": "setting.bg_role == 'gradient'"
    },
    {
      "type": "header",
      "content": "Overrides",
      "conditional": "true"
    },
    {
      "type": "checkbox",
      "id": "surface_override",
      "label": "Override Color Scheme",
      "default": false,
      "conditional": "true"
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Color Scheme",
      "default": "default",
      "conditional": "setting.surface_override == true"
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    }
  ],
  "presets": [
    {
      "name": "Slide",
      "blocks": {
        "heading": {
          "type": "text",
          "settings": {
            "content": "New Slide",
            "display_size": "display",
            "tag": "h1",
            "font_weight": "bold"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "label": "View Menu",
            "style": "primary"
          }
        }
      },
      "block_order": [
        "heading",
        "button"
      ]
    }
  ]
}
{% endschema %}
