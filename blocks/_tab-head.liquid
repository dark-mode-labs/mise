{% assign s = block.settings %}

{% assign border_color_value = blank %}
{% if s.border_role == 'palette' and s.border_role_palette != blank %}
  {% assign border_color_value = 'var(--palette-{{ s.border_role_palette }})' %}
{% elsif s.border_role == 'gradient' and s.border_role_gradient != blank %}
  {% assign border_color_value = 'var(--gradient-{{ s.border_role_gradient }})' %}
{% elsif s.border_role == 'custom' and s.border_role_custom != blank %}
  {% assign border_color_value = s.border_role_custom %}
{% endif %}
{% assign overlay_color_value = blank %}
{% if s.overlay_role == 'palette' and s.overlay_role_palette != blank %}
  {% assign overlay_color_value = 'var(--palette-{{ s.overlay_role_palette }})' %}
{% elsif s.overlay_role == 'gradient' and s.overlay_role_gradient != blank %}
  {% assign overlay_color_value = 'var(--gradient-{{ s.overlay_role_gradient }})' %}
{% elsif s.overlay_role == 'custom' and s.overlay_role_custom != blank %}
  {% assign overlay_color_value = s.overlay_role_custom %}
{% endif %}
{% assign overlay_color_inactive_value = blank %}
{% if s.overlay_role_inactive == 'palette' and s.overlay_role_inactive_palette != blank %}
  {% assign overlay_color_inactive_value = 'var(--palette-{{ s.overlay_role_inactive_palette }})' %}
{% elsif s.overlay_role_inactive == 'gradient' and s.overlay_role_inactive_gradient != blank %}
  {% assign overlay_color_inactive_value = 'var(--gradient-{{ s.overlay_role_inactive_gradient }})' %}
{% elsif s.overlay_role_inactive == 'custom' and s.overlay_role_inactive_custom != blank %}
  {% assign overlay_color_inactive_value = s.overlay_role_inactive_custom %}
{% endif %}
{% comment %} Slot roles emit a class (text-{role}); palette/custom/gradient override --text inline. {% endcomment %}
{% assign text_color_value = blank %}
{% if s.text_role == 'palette' and s.text_role_palette != blank %}
  {% assign text_color_value = 'var(--palette-{{ s.text_role_palette }})' %}
{% elsif s.text_role == 'gradient' and s.text_role_gradient != blank %}
  {% assign text_color_value = 'var(--gradient-{{ s.text_role_gradient }})' %}
{% elsif s.text_role == 'custom' and s.text_role_custom != blank %}
  {% assign text_color_value = s.text_role_custom %}
{% endif %}
{% assign text_color_inactive_value = blank %}
{% if s.text_role_inactive == 'palette' and s.text_role_inactive_palette != blank %}
  {% assign text_color_inactive_value = 'var(--palette-{{ s.text_role_inactive_palette }})' %}
{% elsif s.text_role_inactive == 'gradient' and s.text_role_inactive_gradient != blank %}
  {% assign text_color_inactive_value = 'var(--gradient-{{ s.text_role_inactive_gradient }})' %}
{% elsif s.text_role_inactive == 'custom' and s.text_role_inactive_custom != blank %}
  {% assign text_color_inactive_value = s.text_role_inactive_custom %}
{% endif %}
{% assign classes = '' %}
{% assign styles = '' %}
{% assign active_state_classes = '' %}
{% assign active_state_styles = '' %}
{% assign inactive_state_classes = '' %}
{% assign inactive_state_styles = '' %}

{% assign classes = classes | push_if: "surface-{{ s.surface_id | default: 'default' }}", s.surface_override %}
{% if s.border_radius_override %}
  {% assign classes = classes | push: 'rounded-custom' %}
  {% assign styles = styles | push: '--radius-custom: {{ s.border_radius }}px' %}
{% else %}
  {% assign classes = classes | push: 'rounded-global' %}
{% endif %}
{% if border_color_value != blank %}
  {% assign styles = styles | push: '--border: {{ border_color_value }}' %}
{% endif %}
{% unless s.border_mode_inactive == 'none' %}
  {% assign inactive_state_classes = inactive_state_classes
    | push: 'group-border-{{ s.border_mode_inactive }}'
    | push: 'group-border-size-{{ s.border_size_inactive }}'
  %}
  {% assign inactive_state_styles = inactive_state_styles | push: '--border-style:{{ s.border_style_inactive }}' %}
  {% if s.border_mode_inactive == 'custom' %}
    {% assign inactive_state_classes = inactive_state_classes
      | push_if: 'group-border-custom-left', s.border_custom_left_inactive
      | push_if: 'group-border-custom-right', s.border_custom_right_inactive
      | push_if: 'group-border-custom-top', s.border_custom_top_inactive
      | push_if: 'group-border-custom-bottom', s.border_custom_bottom_inactive
    %}
  {% endif %}
{% endunless %}

{% if s.enable_overlay_inactive %}
  {% comment %}
    Custom color/gradient encodes its own alpha — don't
    multiply with --overlay-opacity. Opacity stays 1.
  {% endcomment %}
  {% assign inactive_state_styles = inactive_state_styles | push: '--overlay-opacity:1' %}
  {% if overlay_color_inactive_value != blank -%}
    {%- assign inactive_state_styles = inactive_state_styles
      | push: '--overlay-bg:{{ overlay_color_inactive_value }}'
    -%}
  {%- endif %}
{% endif %}

{% if text_color_inactive_value != blank %}
  {% assign inactive_state_classes = inactive_state_classes | push: 'text-primary' %}
  {% assign inactive_state_styles = inactive_state_styles | push: '--text:{{ text_color_inactive_value }}' %}
{% elsif s.text_role_inactive != blank and s.text_role_inactive != 'none' %}
  {% assign inactive_state_classes = inactive_state_classes | push: 'text-{{ s.text_role_inactive }}' %}
{% endif %}

{% unless s.border_mode == 'none' %}
  {% assign active_state_classes = active_state_classes
    | push: 'group-border-{{ s.border_mode }}'
    | push: 'group-border-size-{{ s.border_size }}'
  %}
  {% assign active_state_styles = active_state_styles | push: '--border-style:{{ s.border_style }}' %}
  {% if s.border_mode == 'custom' %}
    {% assign active_state_classes = active_state_classes
      | push_if: 'group-border-custom-left', s.border_custom_left
      | push_if: 'group-border-custom-right', s.border_custom_right
      | push_if: 'group-border-custom-top', s.border_custom_top
      | push_if: 'group-border-custom-bottom', s.border_custom_bottom
    %}
  {% endif %}
{% endunless %}

{% if s.enable_overlay %}
  {% comment %}
    Custom color/gradient encodes its own alpha — don't
    multiply with --overlay-opacity. Opacity stays 1.
  {% endcomment %}
  {% assign active_state_styles = active_state_styles | push: '--overlay-opacity:1' %}
  {% if overlay_color_value != blank -%}
    {%- assign active_state_styles = active_state_styles | push: '--overlay-bg:{{ overlay_color_value }}' -%}
  {%- endif %}
{% endif %}

{% if text_color_value != blank %}
  {% assign active_state_classes = active_state_classes | push: 'text-primary' %}
  {% assign active_state_styles = active_state_styles | push: '--text:{{ text_color_value }}' %}
{% elsif s.text_role != blank and s.text_role != 'none' %}
  {% assign active_state_classes = active_state_classes | push: 'text-{{ s.text_role }}' %}
{% endif %}

<div
  {{ context.attached_attributes }}
  class="tab-head cursor-pointer relative {{ classes | join: ' ' }}"
  style="{{ styles | join: ';' }}"
  data-behavior="tab-head"
  data-tab-active-class="{{ active_state_classes | join: ' ' }}"
  data-tab-active-styles="{{ active_state_styles | join: ';' }}"
  data-tab-inactive-class="{{ inactive_state_classes | join: ' ' }}"
  data-tab-inactive-styles="{{ inactive_state_styles | join: ';' }}"
  data-tab-group="{{ section.id }}"
  data-action="tab-switch"
  data-action-args="{{ s.tab_id }}"
  role="tab"
>
  {% comment %} Wrapping blocks in z-10 so they sit above the absolute overlay {% endcomment %}
  <div class="relative z-10">
    {% content_for 'blocks' %}
  </div>

  {% if s.enable_overlay or s.enable_overlay_inactive %}
    <div
      class="rounded-global absolute inset-0 pointer-events-none transition-all duration-200"
      style="background: var(--overlay-bg, transparent); opacity: var(--overlay-opacity, 0);"
    ></div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Tab Head",
  "settings": [
    {
      "type": "header",
      "content": "Binding"
    },
    {
      "type": "text",
      "id": "tab_id",
      "label": "Tab Identifier",
      "default": "{{ context.item.uuid }}"
    },
    {
      "type": "header",
      "content": "Activated Style"
    },
    {
      "type": "select",
      "id": "border_mode",
      "label": "Border",
      "default": "none",
      "options": [
        {
          "value": "custom",
          "label": "Custom"
        },
        {
          "value": "full",
          "label": "Full"
        },
        {
          "value": "none",
          "label": "None"
        }
      ]
    },
    {
      "type": "select",
      "id": "border_role",
      "label": "Border Color",
      "default": "default",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "emphasis",
          "label": "Emphasis"
        },
        {
          "value": "palette",
          "label": "Base Palette"
        },
        {
          "value": "custom",
          "label": "Raw Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        }
      ],
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "palette",
      "id": "border_role_palette",
      "label": "Border Palette Token",
      "info": "Picks a named brand-palette token. Updates follow palette edits.",
      "default": "brand",
      "conditional": "setting.border_role == 'palette' and setting.border_mode != 'none'"
    },
    {
      "type": "color",
      "id": "border_role_custom",
      "label": "Raw Border",
      "conditional": "setting.border_role == 'custom' and setting.border_mode != 'none'"
    },
    {
      "type": "gradient",
      "id": "border_role_gradient",
      "label": "Border Gradient",
      "info": "Picks a named gradient token from the site's gradient set.",
      "conditional": "setting.border_role == 'gradient'"
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border Style",
      "default": "solid",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "dashed",
          "label": "Dashed"
        },
        {
          "value": "dotted",
          "label": "Dotted"
        },
        {
          "value": "double",
          "label": "Double"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "border_custom_left",
      "label": "Border Left",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_right",
      "label": "Border Right",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_top",
      "label": "Border Top",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_bottom",
      "label": "Border Bottom",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "select",
      "id": "border_size",
      "label": "Border Size",
      "options": [
        {
          "value": "xxs",
          "label": "XXS",
          "info": "1px"
        },
        {
          "value": "xs",
          "label": "XS",
          "info": "2px"
        },
        {
          "value": "sm",
          "label": "Small",
          "info": "4px"
        },
        {
          "value": "md",
          "label": "Medium",
          "info": "6px"
        },
        {
          "value": "lg",
          "label": "Large",
          "info": "8px"
        }
      ],
      "default": "md",
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "Use Overlay",
      "default": false
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacity",
      "min": 0,
      "max": 100,
      "default": 100,
      "conditional": "setting.enable_overlay == true"
    },
    {
      "type": "select",
      "id": "overlay_role",
      "label": "Overlay",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "body", "label": "Body" },
        { "value": "body-alt", "label": "Body (alt)" },
        { "value": "surface", "label": "Surface" },
        { "value": "surface-alt", "label": "Surface (alt)" },
        { "value": "accent", "label": "Accent" },
        { "value": "button", "label": "Button" },
        { "value": "control", "label": "Control" },
        { "value": "palette", "label": "Base Palette" },
        { "value": "custom", "label": "Raw Color" },
        { "value": "gradient", "label": "Gradient" }
      ],
      "conditional": "setting.enable_overlay == true"
    },
    {
      "type": "palette",
      "id": "overlay_role_palette",
      "label": "Overlay Palette Token",
      "info": "Picks a named brand-palette token. Updates follow palette edits.",
      "default": "brand",
      "conditional": "setting.overlay_role == 'palette'"
    },
    {
      "type": "color",
      "id": "overlay_role_custom",
      "label": "Overlay Color",
      "conditional": "setting.overlay_role == 'custom'"
    },
    {
      "type": "gradient",
      "id": "overlay_role_gradient",
      "label": "Overlay Gradient",
      "info": "Picks a named gradient token from the site's gradient set.",
      "conditional": "setting.overlay_role == 'gradient'"
    },
    {
      "type": "select",
      "id": "text_role",
      "label": "Text Color",
      "default": "none",
      "info": "Text color when this tab is active. Inherited by child text/icon blocks via --text.",
      "options": [
        { "value": "none", "label": "Inherit" },
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "subtle", "label": "Subtle" },
        { "value": "emphasis", "label": "Emphasis" },
        { "value": "on-accent", "label": "On Accent" },
        { "value": "on-button", "label": "On Button" },
        { "value": "on-control", "label": "On Control" },
        { "value": "palette", "label": "Base Palette" },
        { "value": "custom", "label": "Raw Color" },
        { "value": "gradient", "label": "Gradient" }
      ]
    },
    {
      "type": "palette",
      "id": "text_role_palette",
      "label": "Text Palette Token",
      "info": "Picks a named brand-palette token.",
      "default": "brand",
      "conditional": "setting.text_role == 'palette'"
    },
    {
