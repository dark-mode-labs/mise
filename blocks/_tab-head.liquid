      "label": "Raw Text Color",
      "conditional": "setting.text_role == 'custom'"
    },
    {
      "type": "gradient",
      "id": "text_role_gradient",
      "label": "Text Gradient",
      "conditional": "setting.text_role == 'gradient'"
    },
    {
      "type": "header",
      "content": "Deactivated Style"
    },
    {
      "type": "select",
      "subtype": "border_mode",
      "id": "border_mode_inactive",
      "label": "Border",
      "default": "none",
      "options": [
        {
          "value": "custom",
          "label": "Custom"
        },
        {
          "value": "full",
          "label": "Full"
        },
        {
          "value": "none",
          "label": "None"
        }
      ]
    },
    {
      "type": "select",
      "subtype": "border_style",
      "id": "border_style_inactive",
      "label": "Border Style",
      "default": "solid",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "dashed",
          "label": "Dashed"
        },
        {
          "value": "dotted",
          "label": "Dotted"
        },
        {
          "value": "double",
          "label": "Double"
        }
      ]
    },
    {
      "type": "checkbox",
      "subtype": "border_custom_left",
      "id": "border_custom_left_inactive",
      "label": "Border Left",
      "default": false,
      "conditional": "setting.border_mode_inactive == 'custom'"
    },
    {
      "type": "checkbox",
      "subtype": "border_custom_right",
      "id": "border_custom_right_inactive",
      "label": "Border Right",
      "default": false,
      "conditional": "setting.border_mode_inactive == 'custom'"
    },
    {
      "type": "checkbox",
      "subtype": "border_custom_top",
      "id": "border_custom_top_inactive",
      "label": "Border Top",
      "default": false,
      "conditional": "setting.border_mode_inactive == 'custom'"
    },
    {
      "type": "checkbox",
      "subtype": "border_custom_bottom",
      "id": "border_custom_bottom_inactive",
      "label": "Border Bottom",
      "default": false,
      "conditional": "setting.border_mode_inactive == 'custom'"
    },
    {
      "type": "select",
      "subtype": "border_size",
      "id": "border_size_inactive",
      "label": "Border Size",
      "options": [
