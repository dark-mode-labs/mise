{% assign s = block.settings %}

{% comment %} --- Class Array Building --- {% endcomment %}
{% assign classes = 'carousel-block transition-all rounded-global rotate-custom block-limit-width'
  | push: 'height-{{ s.height }}'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
  | push: 'margin-my-{{ s.margin_vertical }}'
  | push: 'margin-mx-{{ s.margin_horizontal }}'
  | push: 'aspect-{{ s.aspect_ratio }}'
  | push_if: 'float', s.animate_float
  | push_if: 'scale-in', s.animate_scale_in
  | push_if: 'stagger-load', s.animate_stagger
  | push_if: 'shadow-lg', s.shadow
  | push_if: 'overflow-hidden', s.overflow_hidden
%}

{% comment %}
  Background layer: scheme-driven via .bg-<role>. Escape-hatch
  (bg_color_override) is rendered as inline style further down.
{% endcomment %}
{% if s.bg_role and s.bg_role != 'none' and s.bg_role != 'custom' and s.bg_role != 'palette' %}
  {% assign classes = classes | push: 'bg-{{ s.bg_role }}' %}
{% endif %}

{% if s.animate_fade != 'none' %}
  {% assign classes = classes | push: 'fade-{{ s.animate_fade }}' %}
{% endif %}

{% unless s.grow_content %}
  {% assign classes = classes | push: 'width-{{ s.width }}' %}
{% endunless %}

{% assign classes = classes | push_if: "surface-{{ s.surface_id | default: 'default' }}", s.surface_override %}
{% if s.position == 'absolute' %}
  {% assign classes = classes | push: 'absolute' | push: 'anchor-{{ s.inset }}' %}
{% elsif s.position == 'relative' %}
  {% assign classes = classes | push: 'relative' %}
{% endif %}

{% comment %} Borders {% endcomment %}
{% unless s.border_mode == 'none' %}
  {% assign classes = classes
    | push: 'group-border-{{ s.border_mode }}'
    | push: 'group-border-size-{{ s.border_size }}'
  %}
  {% if s.border_mode == 'custom' %}
    {% assign classes = classes
      | push_if: 'group-border-custom-left', s.border_custom_left
      | push_if: 'group-border-custom-right', s.border_custom_right
      | push_if: 'group-border-custom-top', s.border_custom_top
      | push_if: 'group-border-custom-bottom', s.border_custom_bottom
    %}
  {% endif %}
  {% if s.border_role and s.border_role != 'none' and s.border_role != 'custom' and s.border_role != 'palette' and s.border_role != 'gradient' %}
    {% assign classes = classes | push: 'border-{{ s.border_role }}' %}
  {% endif %}
{% endunless %}

{% assign block_classes = classes | join: ' ' %}

{% comment %} --- Styles Array Building --- {% endcomment %}
{% assign text_color_value = blank %}
{% if s.text_role == 'palette' and s.text_role_palette != blank %}
  {% assign text_color_value = 'var(--palette-{{ s.text_role_palette }})' %}
{% elsif s.text_role == 'custom' and s.text_role_custom != blank %}
  {% assign text_color_value = s.text_role_custom %}
{% endif %}
{% assign bg_color_value = blank %}
{% if s.bg_role == 'palette' and s.bg_role_palette != blank %}
  {% assign bg_color_value = 'var(--palette-{{ s.bg_role_palette }})' %}
{% elsif s.bg_role == 'gradient' and s.bg_role_gradient != blank %}
  {% assign bg_color_value = 'var(--gradient-{{ s.bg_role_gradient }})' %}
{% elsif s.bg_role == 'custom' and s.bg_role_custom != blank %}
  {% assign bg_color_value = s.bg_role_custom %}
{% endif %}
{% assign border_color_value = blank %}
{% if s.border_role == 'palette' and s.border_role_palette != blank %}
  {% assign border_color_value = 'var(--palette-{{ s.border_role_palette }})' %}
{% elsif s.border_role == 'gradient' and s.border_role_gradient != blank %}
  {% assign border_color_value = 'var(--gradient-{{ s.border_role_gradient }})' %}
{% elsif s.border_role == 'custom' and s.border_role_custom != blank %}
  {% assign border_color_value = s.border_role_custom %}
{% endif %}
{% assign styles = blank %}

{% if s.padding_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.padding_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}

{% if s.margin_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-mt: {{ s.margin_vertical_custom_top }}rem'
    | push: '--space-mb: {{ s.margin_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.margin_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-ml: {{ s.margin_horizontal_custom_left }}rem'
    | push: '--space-mr: {{ s.margin_horizontal_custom_right }}rem'
  %}
{% endif %}

{% if s.gap == 'custom' %}
  {% assign styles = styles | push: '--space-gap: {{ s.gap_custom }}rem' %}
{% endif %}

{% unless s.border_mode == 'none' %}
  {% assign styles = styles | push: '--border-style: {{ s.border_style }}' %}
  {% if border_color_value != blank -%}
    {%- assign styles = styles | push: '--border: {{ border_color_value }}' -%}
  {%- endif %}
{% endunless %}

{% assign styles = styles
  | push_if: '--radius-global: {{ s.border_radius }}px', s.border_radius_override
  | push_if: '--shadow: {{ s.shadow_color }}', s.shadow_color_override
%}
{% if text_color_value != blank %}{% assign styles = styles | push: '--text: {{ text_color_value }}' %}{% endif %}
{% comment %} Background layer alpha + escape-hatch hex/gradient {% endcomment %}
{% if bg_color_value != blank %}
  {% assign styles = styles | push: 'background: {{ bg_color_value }}' %}
{% endif %}
{% assign block_styles = styles | join: ';' %}

{% comment %} --- Nav Direction Logic --- {% endcomment %}
{% assign wrapper_classes = blank %}
{% if s.show_arrows %}
  {% if s.nav_anchor contains 'top-' %}{% assign wrapper_classes = wrapper_classes | push: 'has-nav-top' %}{% endif %}
  {% if s.nav_anchor contains 'bottom-' %}{% assign wrapper_classes = wrapper_classes | push: 'has-nav-bottom' %}{% endif %}
{% endif %}
{% case s.content_align %}
  {% when 'left' %}
    {% assign wrapper_classes = wrapper_classes | push: 'align-items-start' %}
  {% when 'center' %}
    {% assign wrapper_classes = wrapper_classes | push: 'align-items-center' %}
  {% when 'right' %}
    {% assign wrapper_classes = wrapper_classes | push: 'align-items-end' %}
  {% else %}
    {% assign wrapper_classes = wrapper_classes | push: 'align-items-stretch' %}
{% endcase %}

{% assign wrapper_classes = wrapper_classes | join: ' ' %}

{% comment %} --- Component Render --- {% endcomment %}
<div
  class="{{ block_classes }}"
  style="{{ block_styles }}"
  {{ context.attached_attributes }}
>
  <div
    class="slideshow-wrapper relative isolate w-full h-full flex flex-col {{ wrapper_classes }}"
    data-behavior="slideshow"
    data-autoplay="{{ s.autoplay }}"
    data-speed="{{ s.autoplay_speed }}"
    data-infinite="{{ s.infinite_scroll }}"
    data-cols-mobile="{{ s.columns_mobile }}"
    data-peek-mobile="{{ s.peek_mobile }}"
    data-cols-desktop="{{ s.columns_desktop }}"
    data-peek-desktop="{{ s.peek_desktop }}"
    style="
      --cols-mobile: {{ s.columns_mobile }};
      --cols-desktop: {{ s.columns_desktop }};
    "
  >
    {% if s.show_arrows %}
      <div
        class="slideshow-controls absolute z-floating anchor-{{ s.nav_anchor }} flex items-center gap-1 hidden"
        style="--nav-offset-x: {{ s.nav_offset_x | default: 0 }}rem; --nav-offset-y: {{ s.nav_offset_y | default: 0 }}rem;"
      >
        <button
          type="button"
          class="slideshow-prev pointer-events-auto btn-nav nav-size-{{ s.nav_size }} nav-shape-{{ s.nav_shape }}"
          aria-label="Previous"
        >
          {% render 'icon', name: s.arrow_icon %}
        </button>

        {% if s.show_counter %}
          <div class="slideshow-counter-wrapper tabular-nums">
            {% render 'typography', tag: 'span', display_size: s.display_size, weight: s.font_weight %}
          </div>
        {% endif %}

        <button
          type="button"
          class="slideshow-next pointer-events-auto btn-nav nav-size-{{ s.nav_size }} nav-shape-{{ s.nav_shape }}"
          aria-label="Next"
        >
          {% assign icon_name = s.arrow_icon | replace: '-left', '-right' %}
          {% render 'icon', name: icon_name %}
        </button>
      </div>
    {% endif %}

    {% render 'bg-overlay',
      role: s.overlay_role,
      alpha: s.overlay_alpha,
      palette_token: s.overlay_role_palette,
      custom_color: s.overlay_role_custom,
      gradient_token: s.overlay_role_gradient,
      behind: true
    %}
    <div class="slideshow-track flex h-full overflow-x-auto snap-x snap-mandatory scroll-smooth scrollbar-hide cursor-grab active:cursor-grabbing gap-{{ s.gap }}">
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Carousel",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Mobile Columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "peek_mobile",
      "label": "Mobile Peek (%)",
      "min": 0,
      "max": 50,
      "step": 5,
      "default": 0,
      "info": "Percentage of the next card to reveal. Set to 0 for exact fit."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop Columns",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "peek_desktop",
      "label": "Desktop Peek (%)",
      "min": 0,
      "max": 50,
      "step": 5,
      "default": 0,
      "info": "Percentage of the next card to reveal. Set to 0 for exact fit."
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": true
    },
    {
      "type": "select",
      "id": "arrow_icon",
      "label": "Arrow Style",
      "options": [
        {
          "value": "chevron-left",
          "label": "Chevron"
        },
        {
          "value": "arrow-left",
          "label": "Arrow"
        }
      ],
      "default": "chevron-left",
      "conditional": "setting.show_arrows"
    },
    {
      "type": "header",
      "content": "Anchor",
      "conditional": "setting.show_arrows"
    },
    {
      "type": "select",
      "id": "nav_anchor",
      "label": "Anchor",
      "options": [
        {
          "value": "top-left",
          "label": "Top Left"
        },
        {
          "value": "top-right",
          "label": "Top Right"
        },
        {
          "value": "top-center",
          "label": "Top Center"
        },
        {
          "value": "bottom-left",
          "label": "Bottom Left"
        },
        {
          "value": "bottom-right",
          "label": "Bottom Right"
        },
        {
          "value": "bottom-center",
          "label": "Bottom Center"
        }
      ],
      "default": "top-right",
      "conditional": "setting.show_arrows"
    },
    {
      "type": "range",
      "id": "nav_offset_x",
      "label": "Horizontal Nudge",
      "min": -5,
      "max": 5,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "info": "Fine-tune the horizontal position (negative moves left, positive moves right).",
      "conditional": "setting.show_arrows"
    },
    {
      "type": "range",
      "id": "nav_offset_y",
      "label": "Vertical Nudge",
      "min": -5,
      "max": 5,
      "step": 0.25,
      "default": -3,
      "unit": "rem",
      "info": "Fine-tune the vertical position to align with headings outside the block (negative moves up).",
      "conditional": "setting.show_arrows"
    },
    {
      "type": "select",
      "id": "nav_size",
      "label": "Button Size",
      "options": [
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "lg",
          "label": "Large"
        }
      ],
      "default": "md",
      "conditional": "setting.show_arrows"
    },
    {
      "type": "select",
      "id": "nav_shape",
      "label": "Button Shape",
      "options": [
        {
          "value": "circle",
          "label": "Circle"
        },
        {
          "value": "rounded",
          "label": "Rounded"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ],
      "default": "circle",
      "conditional": "setting.show_arrows"
    },
    {
      "type": "checkbox",
      "id": "show_counter",
      "label": "Show Counter",
      "default": false
    },
    {
      "type": "header",
      "content": "Counter Style",
      "conditional": "setting.show_counter"
    },
    {
      "type": "select",
      "id": "display_size",
      "label": "Counter Size",
      "default": "small",
      "options": [
        {
          "value": "body",
          "label": "Body"
        },
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "caption",
          "label": "Caption"
        }
      ],
      "conditional": "setting.show_counter"
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Counter Weight",
      "default": "medium",
      "options": [
        {
          "value": "normal",
          "label": "Normal"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "bold",
          "label": "Bold"
        }
      ],
      "conditional": "setting.show_counter"
    },
