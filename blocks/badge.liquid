{% assign s = block.settings %}

{% assign layout_class = 'inline-flex flex-row' %}
{% assign align_class = 'align-items-center' %}
{% assign justify_class = 'justify-content-center' %}

{% assign classes = 'badge-pill relative transition-all rounded-full overflow-hidden width-fit'
  | push: layout_class
  | push: justify_class
  | push: align_class
  | push: 'text-align-{{ s.text_align }}'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
  | push: 'gap-{{ s.gap }}'
  | push: 'margin-my-{{ s.margin_vertical }}'
  | push: 'margin-mx-{{ s.margin_horizontal }}'
  | push_if: 'shadow-lg', s.shadow
%}

{% comment %} Background layer: scheme-driven via .bg-<role>. Escape-hatch
   (bg_color_override) is rendered as inline style further down. {% endcomment %}
{% if s.bg_role and s.bg_role != 'none' and s.bg_color_override != true %}
  {% assign classes = classes | push: 'bg-{{ s.bg_role }}' %}
{% endif %}

{% if s.inherit_styles == false and s.color_scheme_override == true %}
  {% assign classes = classes | push: "color-{{ s.color_scheme | default: 'none' }}" %}
{% endif %}

{% comment %} Borders {% endcomment %}
{% unless s.border_mode == 'none' %}
  {% assign classes = classes
    | push: 'group-border-{{ s.border_mode }}'
    | push: 'group-border-size-{{ s.border_size }}'
  %}
  {% if s.border_mode == 'custom' %}
    {% assign classes = classes
      | push_if: 'group-border-custom-left', s.border_custom_left
      | push_if: 'group-border-custom-right', s.border_custom_right
      | push_if: 'group-border-custom-top', s.border_custom_top
      | push_if: 'group-border-custom-bottom', s.border_custom_bottom
    %}
  {% endif %}
{% endunless %}

{% assign block_classes = classes | join: ' ' %}

{% assign styles = blank %}

{% if s.padding_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.padding_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}

{% if s.margin_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-mt: {{ s.margin_vertical_custom_top }}rem'
    | push: '--space-mb: {{ s.margin_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.margin_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-ml: {{ s.margin_horizontal_custom_left }}rem'
    | push: '--space-mr: {{ s.margin_horizontal_custom_right }}rem'
  %}
{% endif %}

{% if s.gap == 'custom' %}
  {% assign styles = styles | push: '--space-gap: {{ s.gap_custom }}rem' %}
{% endif %}

{% unless s.inherit_styles %}
  {% assign styles = styles
    | push_if: '--color-text: {{ s.text_color }}', s.text_color_override
    | push_if: '--color-shadow: {{ s.shadow_color }}', s.shadow_color_override
  %}
{% endunless %}

{% comment %} Background layer alpha + escape-hatch hex/gradient {% endcomment %}
{% if s.bg_color_override and s.bg_color != blank %}
  {% assign styles = styles | push: 'background: {{ s.bg_color }}' %}
{% elsif s.bg_role and s.bg_role != 'none' and s.bg_alpha and s.bg_alpha != 100 %}
  {% assign styles = styles | push: '--bg-alpha: {{ s.bg_alpha | divided_by: 100.0 }}' %}
{% endif %}

{% assign block_styles = styles | join: ';' %}

<div
  class="isolate {{ block_classes }}"
  style="{{ block_styles }}"
  {{ context.attached_attributes }}
>
  {% render 'bg-overlay',
       role: s.overlay_role,
       alpha: s.overlay_alpha,
       use_custom: s.overlay_color_override,
       custom_color: s.overlay_color,
       behind: true
  %}
  {% content_for 'blocks' %}
</div>
{% schema %}
{
  "name": "Badge Pill",
  "settings": [
    {
      "type": "header",
      "content": "General Styles"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Padding/Margins"
    },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "xs"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 4,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 4,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "md"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "select",
      "id": "margin_vertical",
      "label": "Vertical margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "margin_horizontal",
      "label": "Horizontal margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "gap",
      "label": "Gap",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "xs"
    },
    {
      "type": "range",
      "id": "gap_custom",
      "label": "Custom Gap",
      "min": 0,
      "max": 4,
      "step": 0.25,
      "default": 0.5,
      "unit": "rem",
      "conditional": "setting.gap == 'custom'"
    },
    {
      "type": "header",
      "content": "Borders"
    },
    {
      "type": "select",
      "id": "border_mode",
      "label": "Border",
      "default": "none",
      "options": [
        { "value": "custom", "label": "Custom" },
        { "value": "full", "label": "Full" },
        { "value": "none", "label": "None" }
      ]
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border Style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "dotted", "label": "Dotted" },
        { "value": "double", "label": "Double" }
      ]
    },
    {
      "type": "checkbox",
      "id": "border_custom_left",
      "label": "Border Left",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_right",
      "label": "Border Right",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_top",
      "label": "Border Top",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_bottom",
      "label": "Border Bottom",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "select",
      "id": "border_size",
      "label": "Border Size",
      "options": [
        { "value": "xxs", "label": "XXS", "info": "1px" },
        { "value": "xs", "label": "XS", "info": "2px" },
        { "value": "sm", "label": "Small", "info": "4px" },
        { "value": "md", "label": "Medium", "info": "6px" },
        { "value": "lg", "label": "Large", "info": "8px" }
      ],
      "default": "md",
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "header",
      "content": "Style"
    },
    { "type": "checkbox", "id": "inherit_styles", "label": "Inherit Theme Styles", "default": true },
    {
      "type": "select",
      "id": "bg_role",
      "label": "Background",
      "default": "none",
      "options": [
        { "value": "none",    "label": "None" },
        { "value": "body",    "label": "Body" },
        { "value": "surface", "label": "Surface" },
        { "value": "accent",  "label": "Accent" },
        { "value": "button",  "label": "Button" },
        { "value": "nav",     "label": "Control" }
      ]
    },
    {
      "type": "range",
      "id": "bg_alpha",
      "label": "Background Opacity",
      "min": 0, "max": 100, "step": 5, "default": 100, "unit": "%",
      "conditional": "setting.bg_role != 'none'"
    },
    {
      "type": "select",
      "id": "overlay_role",
      "label": "Overlay",
      "default": "none",
      "options": [
        { "value": "none",    "label": "None" },
        { "value": "body",    "label": "Body" },
        { "value": "surface", "label": "Surface" },
        { "value": "accent",  "label": "Accent" },
        { "value": "button",  "label": "Button" },
        { "value": "nav",     "label": "Control" }
      ]
    },
    {
      "type": "range",
      "id": "overlay_alpha",
      "label": "Overlay Opacity",
      "min": 0, "max": 100, "step": 5, "default": 50, "unit": "%",
      "conditional": "setting.overlay_role != 'none' or setting.overlay_color_override"
    },
    {
      "type": "checkbox",
      "id": "overlay_color_override",
      "label": "Custom Overlay (free hex/gradient)",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Custom Overlay Color",
      "default": "",
      "conditional": "setting.overlay_color_override"
    },
    { "type": "checkbox", "id": "shadow", "label": "Show Shadow", "default": false },
    {
      "type": "header",
      "content": "Overrides",
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "checkbox",
      "id": "color_scheme_override",
      "label": "Override Color Scheme",
      "default": false,
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "default",
      "conditional": "setting.inherit_styles != true and setting.color_scheme_override == true"
    },
    {
      "type": "checkbox",
      "id": "bg_color_override",
      "label": "Custom Background (free hex/gradient)",
      "default": false,
      "conditional": "setting.bg_role != 'none'"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Custom Background Color",
      "conditional": "setting.bg_role != 'none' and setting.bg_color_override"
    },
    {
      "type": "checkbox",
      "id": "text_color_override",
      "label": "Override Text Color",
      "default": false,
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Custom Text Color",
      "default": "#ffffff",
      "conditional": "setting.inherit_styles != true and setting.text_color_override"
    },
    {
      "type": "checkbox",
      "id": "shadow_color_override",
      "label": "Override Shadow Color",
      "default": false,
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "color",
      "id": "shadow_color",
      "label": "Custom Shadow Color",
      "default": "rgba(0,0,0,1)",
      "conditional": "setting.inherit_styles != true and setting.shadow_color_override"
    },
    {
      "type": "checkbox",
      "id": "border_radius_override",
      "label": "Override Border Radius",
      "default": false,
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 1000,
      "label": "Radius",
      "default": 0,
      "unit": "px",
      "conditional": "setting.inherit_styles != true and setting.border_radius_override"
    },
    {
      "type": "checkbox",
      "id": "border_color_override",
      "label": "Override Border Color",
      "default": false,
      "conditional": "setting.inherit_styles != true and setting.border_mode != 'none'"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Custom Border Color",
      "default": "#ffffff",
      "conditional": "setting.inherit_styles != true and setting.border_color_override and setting.border_mode != 'none'"
    }
  ],
  "blocks": [{ "type": "@theme" }],
  "presets": [
    {
      "name": "Badge Pill",
      "settings": {
        "padding_vertical": "xs",
        "padding_horizontal": "md",
        "gap": "xs"
      },
      "blocks": {
        "badge_text": {
          "type": "text",
          "settings": {
            "content": "Premium",
            "display_size": "caption",
            "text_transform": "uppercase",
            "font_weight": "bold"
          }
        }
      },
      "block_order": ["badge_text"]
    }
  ]
}
{% endschema %}
