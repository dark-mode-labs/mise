    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "default": "primary",
      "options": [
        {
          "value": "primary",
          "label": "Solid"
        },
        {
          "value": "outline",
          "label": "Outline"
        },
        {
          "value": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "select",
