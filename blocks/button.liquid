        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "emphasis",
          "label": "Emphasis"
        },
        {
          "value": "palette",
          "label": "Base Palette"
        },
        {
          "value": "custom",
          "label": "Raw Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        }
      ],
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "palette",
      "id": "border_role_palette",
      "label": "Border Palette Token",
