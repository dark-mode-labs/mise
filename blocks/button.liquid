{% assign s = block.settings %}

{% assign text_color_value = blank %}
{% if s.text_role == 'palette' and s.text_role_palette != blank %}
  {% assign text_color_value = 'var(--palette-{{ s.text_role_palette }})' %}
{% elsif s.text_role == 'custom' and s.text_role_custom != blank %}
  {% assign text_color_value = s.text_role_custom %}
{% endif %}
{% assign bg_color_value = blank %}
{% if s.bg_role == 'palette' and s.bg_role_palette != blank %}
  {% assign bg_color_value = 'var(--palette-{{ s.bg_role_palette }})' %}
{% elsif s.bg_role == 'gradient' and s.bg_role_gradient != blank %}
  {% assign bg_color_value = 'var(--gradient-{{ s.bg_role_gradient }})' %}
{% elsif s.bg_role == 'custom' and s.bg_role_custom != blank %}
  {% assign bg_color_value = s.bg_role_custom %}
{% endif %}
{% assign border_color_value = blank %}
{% if s.border_role == 'palette' and s.border_role_palette != blank %}
  {% assign border_color_value = 'var(--palette-{{ s.border_role_palette }})' %}
{% elsif s.border_role == 'gradient' and s.border_role_gradient != blank %}
  {% assign border_color_value = 'var(--gradient-{{ s.border_role_gradient }})' %}
{% elsif s.border_role == 'custom' and s.border_role_custom != blank %}
  {% assign border_color_value = s.border_role_custom %}
{% endif %}

{% comment %} --- 1. Wrapper Classes (Outer DIV) --- {% endcomment %}
{% assign wrapper_classes = 'rounded-global whitespace-nowrap'
  | push: 'margin-my-{{ s.margin_vertical }}'
  | push: 'margin-mx-{{ s.margin_horizontal }}'
%}

{% if s.width == 'fill' %}
  {% assign wrapper_classes = wrapper_classes | push: 'w-full block' %}
{% else %}
  {% comment %}
    Use the existing `width-fit limit-width` mise pattern so the
    wrapper's cross-axis size is explicitly `fit-content` instead of
    `auto`. In a flex-column parent (mise group default), `auto`
    cross-axis size lets `align-items: stretch` (CSS default) expand
    the button to full width — losing the inline-block intent. With
    explicit `fit-content`, the button stays content-width regardless
    of the parent's flex alignment, while still respecting
    `align-self: auto` so parent's `content_align: center/end` still
    positions it correctly along the cross-axis.
  {% endcomment %}
  {% assign wrapper_classes = wrapper_classes | push: 'inline-block width-fit limit-width' %}
{% endif %}

{% if s.surface_override %}
  {% assign wrapper_classes = wrapper_classes | push: "surface-{{ s.surface_id | default: 'default' }}" %}
{% endif %}

{% unless s.border_mode == 'none' %}
  {% assign wrapper_classes = wrapper_classes
    | push: 'group-border-{{ s.border_mode }}'
    | push: 'group-border-size-{{ s.border_size }}'
  %}
  {% if s.border_role and s.border_role != 'none' and s.border_role != 'custom' and s.border_role != 'palette' and s.border_role != 'gradient' %}
    {% assign wrapper_classes = wrapper_classes | push: 'border-{{ s.border_role }}' %}
  {% endif %}
  {% if s.border_mode == 'custom' %}
    {% assign wrapper_classes = wrapper_classes
      | push_if: 'group-border-custom-left', s.border_custom_left
      | push_if: 'group-border-custom-right', s.border_custom_right
      | push_if: 'group-border-custom-top', s.border_custom_top
      | push_if: 'group-border-custom-bottom', s.border_custom_bottom
    %}
  {% endif %}
{% endunless %}

{% assign wrapper_class_str = wrapper_classes | join: ' ' %}

{% comment %} --- 2. Inner Classes (Button / Link) --- {% endcomment %}
{% assign inner_classes = 'rounded-global w-full flex'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
%}

{% case s.style %}
  {% when 'outline' -%}
    {%- assign inner_classes = inner_classes | push: 'btn-outline' %}
  {% when 'link' -%}
    {%- assign inner_classes = inner_classes | push: 'btn-link' %}
  {% else -%}
    {%- assign inner_classes = inner_classes | push: 'btn-primary' %}
{% endcase %}

{% case s.content_align %}
  {% when 'center' -%}
    {%- assign inner_classes = inner_classes | push: 'justify-content-center' %}
  {% when 'right' -%}
    {%- assign inner_classes = inner_classes | push: 'justify-content-end' %}
  {% when 'between' -%}
    {%- assign inner_classes = inner_classes | push: 'justify-content-between' %}
  {% else -%}
    {%- assign inner_classes = inner_classes | push: 'justify-content-start' %}
{% endcase %}

{% case s.vertical_align %}
  {% when 'top' -%}
    {%- assign inner_classes = inner_classes | push: 'align-items-start' %}
  {% when 'middle' -%}
    {%- assign inner_classes = inner_classes | push: 'align-items-center' %}
  {% when 'bottom' -%}
    {%- assign inner_classes = inner_classes | push: 'align-items-end' %}
  {% else -%}
    {%- assign inner_classes = inner_classes | push: 'align-items-stretch' %}
{% endcase %}

{% assign inner_class_str = inner_classes | join: ' ' %}

{% comment %} --- 3. Wrapper Styles --- {% endcomment %}
{% assign styles = blank %}

{% if s.padding_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.padding_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}

{% if s.margin_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-mt: {{ s.margin_vertical_custom_top }}rem'
    | push: '--space-mb: {{ s.margin_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.margin_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-ml: {{ s.margin_horizontal_custom_left }}rem'
    | push: '--space-mr: {{ s.margin_horizontal_custom_right }}rem'
  %}
{% endif %}

{% unless s.border_mode == 'none' %}
  {% assign styles = styles | push: '--border-style: {{ s.border_style }}' %}
  {% if border_color_value != blank -%}
    {%- assign styles = styles | push: '--border: {{ border_color_value }}' -%}
  {%- endif %}
{% endunless %}

{% assign styles = styles | push_if: '--radius-global: {{ s.border_radius }}px', s.border_radius_override %}
{% if bg_color_value != blank %}{% assign styles = styles | push: '--button-bg: {{ bg_color_value }}' %}{% endif %}
{% if text_color_value != blank -%}
  {%- assign styles = styles | push: '--text-on-button: {{ text_color_value }}' -%}
{%- endif %}
{% assign wrapper_style_str = styles | join: ';' %}

{% comment %} --- 4. Typography Utilities & Config --- {% endcomment %}
{% assign utilities = blank %}

{% case s.text_wrap %}
  {% when 'nowrap' -%}
    {%- assign utilities = utilities | push: 'whitespace-nowrap' %}
  {% when 'balance' -%}
    {%- assign utilities = utilities | push: 'text-balance' %}
{% endcase %}

{% case s.overflow_behavior %}
  {% when 'hidden' -%}
    {%- assign utilities = utilities | push: 'overflow-hidden' %}
  {% when 'ellipsis' -%}
    {%- assign utilities = utilities | push: 'truncate' %}
{% endcase %}

{% assign utility_classes = utilities | join: ' ' %}


{% assign color_role = s.text_role %}
{% if s.text_role == 'custom' or s.text_role == 'palette' %}
  {% assign color_role = 'on-button' %}
{% endif %}

{% comment %} --- 5. Component Render --- {% endcomment %}
<div
  class="{{ wrapper_class_str }}"
  style="{{ wrapper_style_str }}"
  {{ context.attached_attributes }}
>
  {% if s.trigger == 'action' %}
    <button
      type="button"
      class="{{ inner_class_str }}"
      data-action="{{ s.action | escape }}"
      {% if s.action_args != blank %}
        data-action-args="{{ s.action_args | escape }}"
      {% endif %}
    >
      {% render 'typography',
        text: s.label,
        type_style: s.type_style,
        color_role: color_role,
        class: utility_classes
      %}
    </button>
  {% elsif s.trigger == 'link' %}
    <a
      href="{{ s.link }}"
      {% if s.link == blank %}
        inert="true"
      {% endif %}
      {% if s.link_target == '_blank' %}
        target="_blank" rel="noopener"
      {% endif %}
      class="{{ inner_class_str }}"
    >
      {% render 'typography',
        type_style: s.type_style,
        text: s.label,
                color_role: color_role,
        class: utility_classes
      %}
    </a>
  {% endif %}
</div>

{% schema %}
{
