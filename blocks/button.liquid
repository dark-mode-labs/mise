    {
      "type": "header",
      "content": "Trigger"
    },
    {
      "type": "select",
      "id": "trigger",
      "label": "Trigger",
      "default": "link",
      "options": [
        {
          "value": "link",
          "label": "Link"
        },
        {
          "value": "action",
          "label": "Action"
        }
      ]
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link",
      "conditional": "setting.trigger == 'link'"
