{% assign s = block.settings %}
{% capture style_override %}
  {% if s.padding_vertical == 'custom' %}
    --space-pt: {{ s.padding_vertical_custom_top }}rem;
    --space-pb: {{ s.padding_vertical_custom_bottom }}rem;
  {% endif %}
  {% if s.padding_horizontal == 'custom' %}
     --space-pl: {{ s.padding_horizontal_custom_left }}rem;
     --space-pr: {{ s.padding_horizontal_custom_right }}rem;
  {% endif %}
  {% if s.margin_vertical == 'custom' %}
    --space-mt: {{ s.margin_vertical_custom_top }}rem;
    --space-mb: {{ s.margin_vertical_custom_bottom }}rem;
  {% endif %}
  {% if s.margin_horizontal == 'custom' %}
     --space-ml: {{ s.margin_horizontal_custom_left }}rem;
     --space-mr: {{ s.margin_horizontal_custom_right }}rem;
  {% endif %}
  {% unless s.border_mode == 'none' %}
    {% if s.border_color_override %}
      --color-border: {{  s.border_color }};
    {% endif %}
    --border-style: {{ s.border_style }};
  {% endunless %}
  {% unless s.inherit_styles %}
    {% if s.border_radius_override %}
      --radius-global: {{ s.border_radius }}px;
    {% endif %}
    {% if s.bg_color_override %}
      --color-btn-bg: {{ s.bg_color }};
    {% endif %}
    {% if s.text_color_override %}
      --color-btn-text: {{ s.text_color }};
    {% endif %}
  {% endunless %}
{% endcapture %}

{% capture scheme_class %}
  {% unless s.inherit_styles %}color-{{ s.color_scheme | default: 'none' }}{% endunless %}
  margin-my-{{ s.margin_vertical }}
  margin-mx-{{ s.margin_horizontal }}
  {% unless s.border_mode == 'none' %}
    {% capture border_flags %}
      {% if s.border_mode == 'custom' %}
        {% if s.border_custom_left %}group-border-custom-left{% endif %}
        {% if s.border_custom_right %}group-border-custom-right{% endif %}
        {% if s.border_custom_top %}group-border-custom-top{% endif %}
        {% if s.border_custom_bottom %}group-border-custom-bottom{% endif %}
      {% endif %}
    {% endcapture %}
    group-border-{{ s.border_mode }} group-border-size-{{ s.border_size }} {{ border_flags }}
  {% endunless %}
{% endcapture %}

{% assign width_class = 'inline-block' %}
{% if s.width == 'full' %}
  {% assign width_class = 'w-full block' %}
{% endif %}

{% assign style_class = 'btn-primary' %}

{% case s.style %}
  {% when 'outline' %}
    {% assign style_class = 'btn-outline' %}
  {% when 'link' %}
    {% assign style_class = 'btn-link' %}
{% endcase %}

{% capture inert %}
  {% if s.link == blank %}
    inert="true"
  {% endif %}
{% endcapture %}

{% case s.content_align %}
  {% when 'left' -%}
    {%- assign justify_class = 'justify-content-start' %}
  {% when 'center' -%}
    {%- assign justify_class = 'justify-content-center' %}
  {% when 'right' -%}
    {%- assign justify_class = 'justify-content-end' %}
  {% when 'between' -%}
    {%- assign justify_class = 'justify-content-between' %}
  {% else -%}
    {%- assign justify_class = 'justify-content-start' %}
{% endcase %}
{% case s.vertical_align %}
  {% when 'top' -%}
    {%- assign align_class = 'align-items-start' %}
  {% when 'middle' -%}
    {%- assign align_class = 'align-items-center' %}
  {% when 'bottom' -%}
    {%- assign align_class = 'align-items-end' %}
  {% when 'stretch' -%}
    {%- assign align_class = 'align-items-stretch' %}
  {% else -%}
    {%- assign align_class = 'align-items-stretch' %}
{% endcase %}

<div
  class="rounded-global {{ width_class }} whitespace-nowrap {{ scheme_class }}"
  style="{{ style_override }}"
  {{ context.attached_attributes }}
>
  <a
    href="{{ s.link }}"
    {{ inert }}
    class="
      rounded-global w-full flex
      {{ justify_class }}
      {{ align_class }}
      padding-py-{{ s.padding_vertical }}
      padding-px-{{ s.padding_horizontal }}
      {{ style_class }}
    "
  >
    {% render 'typography',
      text: s.label,
      display_size: s.display_size,
      weight: s.font_weight,
      color: 'text-btn',
      family: 'btn'
    %}
  </a>
</div>

{% schema %}
{
  "name": "Button",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Book Now" },
    { "type": "url", "id": "link", "label": "Link" },
    {
      "type": "select",
      "id": "style",
      "label": "Layout",
      "default": "primary",
      "options": [
        { "value": "primary", "label": "Solid" },
        { "value": "outline", "label": "Outline" },
        { "value": "link", "label": "Link" }
      ]
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "full", "label": "Full Width" }
      ]
    },
    {
      "type": "select",
      "id": "display_size",
      "label": "Size",
      "default": "body",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "display", "label": "Display" },
        { "value": "body", "label": "Body" },
        { "value": "caption", "label": "Caption" },
        { "value": "small", "label": "Small" },
        { "value": "jumbo", "label": "Jumbo" }
      ]
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Horizontal Alignment",
      "options": [
        { "value": "left", "label": "Left / Start" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right / End" },
        { "value": "between", "label": "Space Between" },
        { "value": "stretch", "label": "Stretch" }
      ]
    },
    {
      "type": "select",
      "id": "vertical_align",
      "label": "Vertical Alignment",
      "options": [
        { "value": "top", "label": "Top / Start" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom / End" },
        { "value": "between", "label": "Space Between" },
        { "value": "stretch", "label": "Stretch" }
      ]
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Weight",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "medium", "label": "Medium" },
        { "value": "bold", "label": "Bold" },
        { "value": "extrabold", "label": "Extra Bold" },
        { "value": "black", "label": "Black" }
      ],
      "default": "normal"
    },
    {
      "type": "header",
      "content": "Borders"
    },
    {
      "type": "select",
      "id": "border_mode",
      "label": "Border",
      "default": "none",
      "options": [
        { "value": "custom", "label": "Custom" },
        { "value": "full", "label": "Full" },
        { "value": "none", "label": "None" }
      ]
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border Style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "dotted", "label": "Dotted" },
        { "value": "double", "label": "Double" }
      ]
    },
    {
      "type": "checkbox",
      "id": "border_custom_left",
      "label": "Border Left",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_right",
      "label": "Border Right",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_top",
      "label": "Border Top",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_bottom",
      "label": "Border Bottom",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "select",
      "id": "border_size",
      "label": "Border Size",
      "options": [
        { "value": "xxs", "label": "XXS", "info": "1px" },
        { "value": "xs", "label": "XS", "info": "2px" },
        { "value": "sm", "label": "Small", "info": "4px" },
        { "value": "md", "label": "Medium", "info": "6px" },
        { "value": "lg", "label": "Large", "info": "8px" }
      ],
      "default": "md",
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "xs"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "md"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "select",
      "id": "margin_vertical",
      "label": "Vertical margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "auto", "label": "Auto" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_top",
      "label": "Custom Top margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_bottom",
      "label": "Custom Bottom margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "select",
      "id": "margin_horizontal",
      "label": "Horizontal margin",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "XS" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "auto", "label": "Auto" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_left",
      "label": "Custom Left margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_right",
      "label": "Custom Right margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "checkbox",
      "id": "inherit_styles",
      "label": "Inherit Theme Colors",
      "default": true,
      "info": "Uncheck to customize button colors manually."
    },
    {
      "type": "header",
      "content": "Overrides",
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Palette",
      "default": "default",
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "checkbox",
      "id": "bg_color_override",
      "label": "Override Background",
      "default": false,
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Custom Background",
      "default": "#000000",
      "conditional": "setting.inherit_styles != true and setting.bg_color_override"
    },
    {
      "type": "checkbox",
      "id": "text_color_override",
      "label": "Override Text Color",
      "default": false,
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Custom Text Color",
      "default": "#ffffff",
      "conditional": "setting.inherit_styles != true and setting.text_color_override"
    },
    {
      "type": "checkbox",
      "id": "border_radius_override",
      "label": "Override Border Radius",
      "default": false,
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Custom Border Radius",
      "min": 0,
      "max": 1000,
      "default": 4,
      "unit": "px",
      "conditional": "setting.inherit_styles != true and setting.border_radius_override"
    },
    {
      "type": "checkbox",
      "id": "border_color_override",
      "label": "Override Border Color",
      "default": false,
      "conditional": "setting.inherit_styles != true and setting.border_mode != 'none'"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Custom Border Color",
      "default": "#ffffff",
      "conditional": "setting.inherit_styles != true and setting.border_color_override and setting.border_mode != 'none'"
    }
  ]
}
{% endschema %}
