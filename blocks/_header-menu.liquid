{% assign s = block.settings %}

{% comment %} --- Wrapper Classes --- {% endcomment %}
{% assign nav_classes = 'header-nav hidden lg:flex items-center' %}

{% if s.surface_override %}
  {% assign nav_classes = nav_classes | push: "surface-{{ s.surface_id | default: 'default' }}" %}
{% endif %}

{% assign block_classes = nav_classes | join: ' ' %}

{% comment %} --- Styles Array Building --- {% endcomment %}
{% assign text_color_value = blank %}
{% if s.text_role == 'palette' and s.text_role_palette != blank %}
  {% assign text_color_value = 'var(--palette-{{ s.text_role_palette }})' %}
{% elsif s.text_role == 'custom' and s.text_role_custom != blank %}
  {% assign text_color_value = s.text_role_custom %}
{% endif %}
{% assign styles = blank %}
{% if text_color_value != blank %}
  {% assign styles = styles | push: '--text: {{ text_color_value }}' %}
{% endif %}
{% assign block_styles = styles | join: ';' %}

{% assign color_role = s.text_role %}
{% if s.text_role == 'custom' or s.text_role == 'palette' %}{% assign color_role = 'primary' %}{% endif %}

{% comment %} --- Typography Utilities --- {% endcomment %}
{% assign utilities = blank %}

{% case s.text_wrap %}
  {% when 'nowrap' %}
    {% assign utilities = utilities | push: 'whitespace-nowrap' %}
  {% when 'balance' %}
    {% assign utilities = utilities | push: 'text-balance' %}
{% endcase %}

{% assign utility_classes = utilities | join: ' ' %}

{% comment %} --- Component Render --- {% endcomment %}
<nav
  class="{{ block_classes }}"
  style="{{ block_styles }}"
  {{ context.attached_attributes }}
>
  <ul class="flex items-center gap-8">
    {% for link in s.nav.links %}
      {% assign has_mega = false %}
      {% if link.levels > 1 %}{% assign has_mega = true %}{% endif %}

      <li class="group flex items-center relative">
        <a
          href="{{ link.url }}"
          class="hover:opacity-70 flex items-center gap-1"
        >
          {% render 'typography',
            text: link.title,
            type_style: s.type_style,
            color_role: color_role,
            class: utility_classes
          %}
          {% if link.links != blank %}
            {% render 'icon',
              name: 'chevron-down',
              class: 'w-3 h-3 opacity-50 group-hover:rotate-180 transition-transform'
            %}
          {% endif %}
        </a>

        {% if link.links != blank %}
          <div
            class="
              absolute top-full left-0 border border-default shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-floating
              {% if has_mega %}!fixed left-0 right-0 w-full border-x-0{% else %}w-64{% endif %}
            "
          >
            {% if has_mega %}
              <div class="mx-auto px-8 py-12 grid grid-cols-4 gap-8">
                {% for child in link.links %}
                  <div>
                    <a
                      href="{{ child.url }}"
                      class="block mb-4 hover:underline underline-offset-4"
                    >
                      {% render 'typography',
        type_style: s.type_style,
                        text: child.title,
                                                color_role: color_role,
                        class: utility_classes
                      %}
                    </a>
                    <ul class="space-y-2">
                      {% for grandchild in child.links %}
                        <li>
                          <a
                            href="{{ grandchild.url }}"
                            class="opacity-70 hover:opacity-100 block"
                          >
                            {% render 'typography',
        type_style: s.type_style,
                              text: grandchild.title,
                                                            color_role: color_role,
                              class: utility_classes
                            %}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endfor %}
              </div>

            {% else %}
              <ul class="py-4">
                {% for child in link.links %}
                  <li>
                    <a href="{{ child.url }}" class="block px-6 py-2 text-sm hover:bg-gray-50/5 whitespace-nowrap">
                      {{ child.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</nav>

{% if s.nav %}
  {% render 'header-drawer',
    menu: s.nav,
    type_style: s.type_style,
    color_role: color_role
  %}
{% endif %}

{% schema %}
{
  "name": "Header Nav",
  "settings": [
    {
      "type": "link_list",
      "id": "nav",
      "label": "Menu"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "type_style",
      "id": "type_style",
      "label": "Type Style",
      "info": "References a Tier-2 type-style entry \u2014 bundles font family, size, weight, tracking, leading, transform into one named treatment.",
      "default": "nav"
    },
    {
      "type": "select",
      "id": "text_wrap",
      "label": "Text Wrapping",
      "default": "nowrap",
      "options": [
        {
          "value": "wrap",
          "label": "Wrap"
        },
        {
          "value": "nowrap",
          "label": "No Wrap"
        },
        {
          "value": "balance",
          "label": "Balance"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_role",
      "label": "Text Color Role",
      "default": "button",
      "options": [
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "secondary",
          "label": "Secondary"
        },
        {
          "value": "subtle",
          "label": "Subtle"
        },
        {
          "value": "emphasis",
          "label": "Emphasis"
        },
        {
          "value": "on-accent",
          "label": "On Accent"
        },
        {
          "value": "on-button",
          "label": "On Button"
        },
        {
          "value": "on-control",
          "label": "On Control"
        },
        {
          "value": "palette",
          "label": "Base Palette"
        },
        {
          "value": "custom",
          "label": "Raw Color"
        }
      ]
    },
    {
      "type": "palette",
      "id": "text_role_palette",
      "label": "Text Palette Token",
      "info": "Picks a named brand-palette token. Updates follow palette edits.",
      "default": "brand",
      "conditional": "setting.text_role == 'palette'"
    },
    {
      "type": "color",
      "id": "text_role_custom",
      "label": "Raw Text Color",
      "conditional": "setting.text_role == 'custom'"
    },
    {
      "type": "header",
      "content": "General Style"
    },
    {
      "type": "header",
      "content": "Overrides",
      "conditional": "true"
    },
    {
      "type": "checkbox",
      "id": "surface_override",
      "label": "Override Color Scheme",
      "default": false,
      "conditional": "true"
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Color Scheme",
      "default": "default",
      "conditional": "setting.surface_override == true"
    }
  ]
}
{% endschema %}
