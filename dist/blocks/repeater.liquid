{% assign s = block.settings %}
{% case s.data_source_type %}
  {% when 'json' %}
    {% if s.data_json != blank %}
      {% assign items = s.data_json | decode_json | values %}
    {% endif %}
  {% when 'inherit' %}
    {% if s.data_field != blank %}
      {% assign items = context.item | map: s.data_field %}
    {% else %}
      {% assign items = context.item %}
    {% endif %}
  {% when 'item_collection' %}
    {% unless s.item_collection == blank %}
      {% assign args = 'source'
        | push: 'item_collection'
        | push: 'item_collection_identifier'
        | push: s.item_collection
      %}
      {% assign items = 'item' | data_source: 'list', args %}
    {% endunless %}
  {% when 'locations' %}
    {% assign items = 'location' | data_source: 'list' %}
  {% when 'collections_in' %}
    {% unless s.collections_in == blank %}
      {% assign args = 'source'
        | push: 'item_collection'
        | push: 'item_collection_identifiers'
        | push: s.collections_in
      %}
      {% assign items = 'item_collection' | data_source: 'list', args %}
    {% endunless %}
{% endcase %}

<div class="contents" {{ context.attached_attributes }}>
  {% if items == blank %}
    {% content_for 'blocks' %}
  {% else %}
    {% for item in items %}
      {% content_for 'blocks', context.item: item %}
    {% endfor %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Repeater Template",
  "settings": [
    { "type": "header", "content": "Data Source" },
    {
      "type": "select",
      "id": "data_source_type",
      "label": "Type",
      "options": [
        { "value": "json", "label": "JSON" },
        { "value": "inherit", "label": "Inherit" },
        { "value": "item_collection", "label": "Items in Collection" },
        { "value": "locations", "label": "Locations" },
        { "value": "collections_in", "label": "Collections" }
      ]
    },
    {
      "type": "json",
      "id": "data_json",
      "label": "JSON",
      "default": "{}",
      "conditional": "setting.data_source_type == 'json'"
    },
    {
      "type": "text",
      "id": "data_field",
      "label": "Context Field",
      "conditional": "setting.data_source_type == 'inherit'"
    },
    {
      "type": "collection",
      "id": "item_collection",
      "label": "Select Item Collection",
      "conditional": "setting.data_source_type == 'item_collection'"
    },
    {
      "type": "collection",
      "id": "collections_in",
      "label": "Select Item Collections",
      "conditional": "setting.data_source_type == 'collections_in'"
    }
  ],
  "blocks": [{ "type": "@theme" }, { "type": "_menu-card-full" }, { "type": "_tab-head" }, { "type": "_tab-content" }],
  "presets": [{ "name": "Repeater Template", "settings": {}, "blocks": {}, "block_order": [] }]
}
{% endschema %}
