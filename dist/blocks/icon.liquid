{% assign s = block.settings %}

{% comment %} --- Wrapper Classes --- {% endcomment %}
{% assign classes = 'icon icon-size inline-flex items-center justify-center flex-shrink-0'
  | push: 'margin-my-{{ s.margin_vertical }}'
  | push: 'margin-mx-{{ s.margin_horizontal }}'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
%}

{% assign color_role = 'text-{{ s.text_role }}' %}
{% assign classes = classes | push_if: "surface-{{ s.surface_id | default: 'default' }}", s.surface_override %}

{% if s.text_role == 'custom' or s.text_role == 'palette' %}
  {% assign color_role = 'text-primary' %}
{% endif %}
{% assign block_classes = classes | push: color_role | join: ' ' %}

{% comment %} --- Styles Array Building --- {% endcomment %}
{% assign text_color_value = blank %}
{% if s.text_role == 'palette' and s.text_role_palette != blank %}
  {% assign text_color_value = 'var(--palette-{{ s.text_role_palette }})' %}
{% elsif s.text_role == 'custom' and s.text_role_custom != blank %}
  {% assign text_color_value = s.text_role_custom %}
{% endif %}
{% assign styles = blank %}

{% if s.padding_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.padding_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}

{% if s.margin_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-mt: {{ s.margin_vertical_custom_top }}rem'
    | push: '--space-mb: {{ s.margin_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.margin_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-ml: {{ s.margin_horizontal_custom_left }}rem'
    | push: '--space-mr: {{ s.margin_horizontal_custom_right }}rem'
  %}
{% endif %}

{% assign styles = styles | push: '--icon-size: {{ s.icon_size }}rem' %}

{% if text_color_value != blank %}
  {% assign styles = styles | push: '--text: {{ text_color_value }}' %}
{% endif %}
{% assign block_styles = styles | join: ';' %}

{% comment %} --- Component Render --- {% endcomment %}
<div
  class="{{ block_classes }}"
  style="{{ block_styles }}"
  {{ context.attached_attributes }}
>
  {{ s.svg }}
</div>

{% schema %}
{
  "name": "Icon",
  "settings": [
    {
      "type": "textarea",
      "id": "svg",
      "label": "SVG",
      "default": "<svg fill=\"currentColor\" stroke=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z\" clip-rule=\"evenodd\"/></svg>"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Size",
      "min": 0.75,
      "max": 8,
      "step": 0.25,
      "default": 1.5,
      "unit": "rem"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "space",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "space",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "space",
      "id": "margin_vertical",
      "label": "Vertical Margin",
      "default": "none"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_top",
      "label": "Custom Top Margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_vertical_custom_bottom",
      "label": "Custom Bottom Margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_vertical == 'custom'"
    },
    {
      "type": "space",
      "id": "margin_horizontal",
      "label": "Horizontal Margin",
      "default": "none"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_left",
      "label": "Custom Left Margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "margin_horizontal_custom_right",
      "label": "Custom Right Margin",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.margin_horizontal == 'custom'"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "text_role",
      "label": "Text Color Role",
      "default": "primary",
      "options": [
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "secondary",
          "label": "Secondary"
        },
        {
          "value": "subtle",
          "label": "Subtle"
        },
        {
          "value": "emphasis",
          "label": "Emphasis"
        },
        {
          "value": "on-accent",
          "label": "On Accent"
        },
        {
          "value": "on-button",
          "label": "On Button"
        },
        {
          "value": "on-control",
          "label": "On Control"
        },
        {
          "value": "palette",
          "label": "Base Palette"
        },
        {
          "value": "custom",
          "label": "Raw Color"
        }
      ]
    },
    {
      "type": "palette",
      "id": "text_role_palette",
      "label": "Text Palette Token",
      "info": "Picks a named brand-palette token. Updates follow palette edits.",
      "default": "brand",
      "conditional": "setting.text_role == 'palette'"
    },
    {
      "type": "color",
      "id": "text_role_custom",
      "label": "Raw Text Color",
      "conditional": "setting.text_role == 'custom'"
    },
    {
      "type": "header",
      "content": "Overrides",
      "conditional": "true"
    },
    {
      "type": "checkbox",
      "id": "surface_override",
      "label": "Override Color Scheme",
      "default": false,
      "conditional": "true"
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Color Scheme",
      "default": "default",
      "conditional": "setting.surface_override == true"
    }
  ]
}
{% endschema %}
