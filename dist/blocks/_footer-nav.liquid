{% assign s = block.settings %}
{% capture scheme_class %}
  {% unless s.inherit_styles %}color-{{ s.color_scheme | default: 'none' }}{% endunless %}
{% endcapture %}
{% capture wrap_style %}
  {% case s.text_wrap %}
    {% when 'nowrap' %}whitespace-nowrap
    {% when 'balance' %}text-balance
  {% endcase %}
{% endcapture %}

<div
  class="footer-block {{ scheme_class }}"
  {{ context.attached_attributes }}
>
  <details class="group" open>
    <summary class="flex items-center justify-between cursor-pointer md:cursor-default list-none mb-4">
      {% render 'typography', text: s.heading, display_size: s.display_size, weight: s.font_weight, class: wrap_style %}
      {% render 'icon', name: 'chevron-right', class: 'w-4 h-4 transition-transform group-open:rotate-90 md:hidden' %}
    </summary>

    {% content_for 'blocks' %}
  </details>
</div>

{% schema %}
{
  "name": "Nav Group",
  "blocks": [{ "type": "_nav-group" }],
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Quick Links" },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "checkbox",
      "id": "inherit_styles",
      "label": "Inherit Styles",
      "default": true
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "select",
      "id": "display_size",
      "label": "Size",
      "default": "body",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "display", "label": "Display" },
        { "value": "body", "label": "Body" },
        { "value": "caption", "label": "Caption" },
        { "value": "small", "label": "Small" },
        { "value": "jumbo", "label": "Jumbo" }
      ]
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Weight",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "medium", "label": "Medium" },
        { "value": "bold", "label": "Bold" },
        { "value": "extrabold", "label": "Extra Bold" },
        { "value": "black", "label": "Black" }
      ],
      "default": "normal"
    },
    {
      "type": "select",
      "id": "text_wrap",
      "label": "Text Wrapping",
      "default": "nowrap",
      "options": [
        { "value": "wrap", "label": "Wrap" },
        { "value": "nowrap", "label": "No Wrap" },
        { "value": "balance", "label": "Balance" }
      ]
    },
    {
      "type": "header",
      "content": "Overrides",
      "conditional": "setting.inherit_styles != true"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Palette",
      "default": "default",
      "conditional": "setting.inherit_styles != true"
    }
  ]
}
{% endschema %}
