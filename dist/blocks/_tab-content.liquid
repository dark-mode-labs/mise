{% assign s = block.settings %}

<div
  {{ context.attached_attributes }}
  class='tab-content'
  data-behavior='tab-content'
  data-tab-id='{{ s.tab_id }}'
  data-tab-group='{{ section.id }}'
  aria-expanded='false'
>
  {% content_for 'blocks' %}
</div>
{% schema %}
{
  "name": "Tab Content",
  "settings": [
    {
      "type": "type_style",
      "id": "type_style",
      "label": "Type Style",
      "default": "body"
    },
    {
      "type": "header",
      "content": "Binding"
    },
    {
      "type": "text",
      "id": "tab_id",
      "label": "Tab Identifier",
      "default": "{{ context.item.uuid }}"
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    }
  ]
}
{% endschema %}
