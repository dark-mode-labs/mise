{% assign tag_el = tag | default: 'p' %}
{% assign text_color = color | default: 'text-body' %}
{% assign size_class = 'text-base' %}

{% case display_size %}
  {% when 'display' %}
    {% assign size_class = 'text-5xl md:text-7xl font-heading' %}
  {% when 'h1' %}
    {% assign size_class = 'text-4xl md:text-5xl font-heading' %}
  {% when 'h2' %}
    {% assign size_class = 'text-3xl md:text-4xl font-heading' %}
  {% when 'h3' %}
    {% assign size_class = 'text-2xl md:text-3xl font-heading' %}
  {% when 'h4' %}
    {% assign size_class = 'text-xl md:text-2xl font-heading' %}
  {% when 'h5' %}
    {% assign size_class = 'text-lg md:text-xl font-heading' %}
  {% when 'h6' %}
    {% assign size_class = 'text-base md:text-lg font-heading ' %}
  {% when 'body' %}
    {% assign size_class = 'text-base font-body' %}
  {% when 'caption' %}
    {% assign size_class = 'text-xs font-body' %}
  {% when 'small' %}
    {% assign size_class = 'text-sm font-body' %}
  {% when 'jumbo' %}
    {% assign size_class = 'text-5xl md:text-7xl xl:text-8xl font-heading' %}
{% endcase %}

{% capture weight_class %}
  {% case weight %}
    {% when 'normal' %}
      font-normal
    {% when 'medium' %}
      font-medium
    {% when 'bold' %}
      font-bold
    {% when 'extrabold' %}
      font-extrabold
    {% when 'black' %}
      font-black
  {% endcase %}
{% endcapture %}

{% capture tracking_class %}
  {% case tracking %}
    {% when 'tighter' %}
      tracking-tighter
    {% when 'tight' %}
      tracking-tight
    {% when 'wide' %}
      tracking-wide
    {% when 'wider' %}
      tracking-wider
    {% when 'widest' %}
      tracking-widest
    {% when 'custom' %}
      tracking-custom
    {% else %}
      tracking-normal
  {% endcase %}
{% endcapture %}

{% capture leading_class %}
  {% case leading %}
    {% when 'none' %}
      leading-none
    {% when 'tight' %}
      leading-tight
    {% when 'snug' %}
      leading-snug
    {% when 'relaxed' %}
      leading-relaxed
    {% when 'loose' %}
      leading-loose
    {% when 'custom' %}
      leading-custom
    {% else %}
      leading-normal
  {% endcase %}
{% endcapture %}

{% assign family_class = '' %}
{% if family != blank %}
  {% assign family_class = 'font-' | append: family %}
{% endif %}

<{{ tag_el }} class="{{ size_class }} {{ family_class }} {{ weight_class }} {{ text_color }} {{ class }} {{ tracking_class }} {{ leading_class }}">
  {{ text }}
</{{ tag_el }}>
