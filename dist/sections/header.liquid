{% assign s = section.settings %}

{% assign bg_color_value = blank %}
{% if s.bg_role == 'palette' and s.bg_role_palette != blank %}
  {% assign bg_color_value = 'var(--palette-{{ s.bg_role_palette }})' %}
{% elsif s.bg_role == 'gradient' and s.bg_role_gradient != blank %}
  {% assign bg_color_value = 'var(--gradient-{{ s.bg_role_gradient }})' %}
{% elsif s.bg_role == 'custom' and s.bg_role_custom != blank %}
  {% assign bg_color_value = s.bg_role_custom %}
{% endif %}

{% comment %}
  Paint --text on the header so descendants (hamburger, icons,
  text_role:inherit blocks) cascade. `primary` leaves --text alone
  so the surface paints it.
{% endcomment %}
{% assign text_override_value = blank %}
{% if s.text_role == 'palette' and s.text_role_palette != blank %}
  {% assign text_override_value = 'var(--palette-{{ s.text_role_palette }})' %}
{% elsif s.text_role == 'custom' and s.text_role_custom != blank %}
  {% assign text_override_value = s.text_role_custom %}
{% elsif s.text_role != blank and s.text_role != 'primary' %}
  {% assign text_override_value = 'var(--text-{{ s.text_role }})' %}
{% endif %}

{% assign is_overlay = false %}
{% if s.header_overlay_mode == 'overlay' or s.header_overlay_mode == 'transparent' %}
  {% assign is_overlay = true %}
{% endif %}

{% assign needs_spacer = false %}
{% assign positions = blank %}

{% if s.sticky_behavior == 'always' or s.sticky_behavior == 'on_scroll_up' %}
  {% assign positions = positions | push: 'fixed top-[var(--top-nav,0)] inset-x-0' %}
  {% unless is_overlay %}
    {% assign needs_spacer = true %}
  {% endunless %}
{% elsif is_overlay %}
  {% assign positions = positions | push: 'absolute top-[var(--top-nav,0)] inset-x-0' %}
{% else %}
  {% assign positions = positions | push: 'relative' %}
{% endif %}

{% assign position_class_str = positions | join: ' ' %}

{% assign bg_role_safe = s.bg_role | default: 'body' %}
{% assign bg_class = 'bg-' | append: bg_role_safe %}
{% if bg_color_value != blank %}{% assign bg_class = '' %}{% endif %}

{% assign header_classes = 'header-section z-header transition-all duration-300'
  | push: position_class_str
  | push: 'surface-{{ s.surface_id | default: "default" }}'
  | push: bg_class
  | push: 'bp-{{ s.mobile_breakpoint }}'
  | push: 'mobile-{{ s.mobile_layout }}'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
%}

{% assign border_color_value = blank %}
{% if s.border_role == 'palette' and s.border_role_palette != blank %}
  {% assign border_color_value = 'var(--palette-{{ s.border_role_palette }})' %}
{% elsif s.border_role == 'custom' and s.border_role_custom != blank %}
  {% assign border_color_value = s.border_role_custom %}
{% endif %}

{% unless s.border_mode == 'none' or s.border_mode == blank %}
  {% assign header_classes = header_classes
    | push: 'group-border-{{ s.border_mode }}'
    | push: 'group-border-size-{{ s.border_size | default: "xxs" }}'
  %}
  {% if s.border_role and s.border_role != 'none' and s.border_role != 'custom' and s.border_role != 'palette' %}
    {% assign header_classes = header_classes | push: 'border-{{ s.border_role }}' %}
  {% endif %}
  {% if s.border_mode == 'custom' %}
    {% assign header_classes = header_classes
      | push_if: 'group-border-custom-left', s.border_custom_left
      | push_if: 'group-border-custom-right', s.border_custom_right
      | push_if: 'group-border-custom-top', s.border_custom_top
      | push_if: 'group-border-custom-bottom', s.border_custom_bottom
    %}
  {% endif %}
{% endunless %}
{% if s.backdrop_blur and s.backdrop_blur != 'none' %}
  {% assign header_classes = header_classes | push: 'backdrop-blur-{{ s.backdrop_blur }}' %}
{% endif %}

{% assign header_class_str = header_classes | join: ' ' %}

{% assign styles = blank %}
{% if s.padding_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}
{% if s.padding_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}
{% if bg_color_value != blank %}
  {% assign styles = styles | push: 'background: {{ bg_color_value }}' %}
{% endif %}
{% if text_override_value != blank %}
  {% assign styles = styles | push: '--text: {{ text_override_value }}' %}
{% endif %}
{% unless s.border_mode == 'none' or s.border_mode == blank %}
  {% assign styles = styles | push: '--border-style: {{ s.border_style | default: "solid" }}' %}
  {% if border_color_value != blank -%}
    {%- assign styles = styles | push: '--border: {{ border_color_value }}' -%}
  {%- endif %}
{% endunless %}
{% assign style_str = styles | join: ';' %}

{% comment %}
  `slot_actions` must be captured BEFORE `slot_nav` — slot_nav
  forwards the rendered actions HTML to the drawer via
  `context.drawer_actions_html`.
{% endcomment %}
{% capture slot_logo %}{% content_for 'block', type: 'group', id: 'header-logo' %}{% endcapture %}
{% capture slot_actions %}{% content_for 'block', type: '_header-actions', id: 'header-actions' %}{% endcapture %}
{% capture slot_nav %}{% content_for 'block', type: '_header-menu', id: 'header-menu', context.drawer_actions_html: slot_actions %}{% endcapture %}

{% capture hamburger_btn %}
  {% if s.show_mobile_menu %}
    <button
      type='button'
      class='header-mobile-toggle p-2 hover:opacity-70'
      data-action='toggle-drawer'
      aria-label='Menu'
    >
      {% render 'icon', name: 'menu', class: 'w-6 h-6' %}
    </button>
  {% endif %}
{% endcapture %}

<header
  class='{{ header_class_str }}'
  data-behavior='header'
  data-sticky='{{ s.sticky_behavior }}'
  data-transparent='{% if s.header_overlay_mode == 'transparent' %}true{% else %}false{% endif %}'
  style='{{ style_str }}'
  {{ context.attached_attributes }}
>
  <div class='width-{{ s.width }} header-grid limit-width'>
    <div class='flex items-center justify-start gap-4'>
      {% if s.mobile_layout != 'logo_left' %}{{ hamburger_btn }}{% endif %}

      {% if s.desktop_layout == 'logo_left' %}
        <div class='mr-8 flex-shrink-0 hidden header-logo-desktop'>{{ slot_logo }}</div>
        {% if s.show_nav and s.nav_alignment == 'left' %}{{ slot_nav }}{% endif %}
      {% else %}
        {% if s.show_nav %}{{ slot_nav }}{% endif %}
      {% endif %}

      {% if s.mobile_layout == 'logo_left' %}
        <div class='header-logo-mobile'>{{ slot_logo }}</div>
      {% endif %}
    </div>

    <div class='flex items-center justify-center'>
      {% if s.show_nav and s.desktop_layout == 'logo_left' and s.nav_alignment == 'center' %}{{ slot_nav }}{% endif %}

      {% if s.desktop_layout != 'logo_left' or s.mobile_layout == 'logo_center' %}
        {% assign logo_wrap_class = '' %}
        {% if s.desktop_layout == 'logo_left' and s.mobile_layout == 'logo_center' %}
          {% assign logo_wrap_class = 'header-logo-mobile' %}
        {% endif %}
        <div class='{{ logo_wrap_class }}'>{{ slot_logo }}</div>
      {% endif %}
    </div>

    <div class='flex items-center justify-end gap-4'>
      {% if s.show_nav and s.desktop_layout == 'logo_left' and s.nav_alignment == 'right' %}{{ slot_nav }}{% endif %}

      {% if s.mobile_layout == 'logo_right' %}
        <div class='header-logo-mobile'>{{ slot_logo }}</div>
      {% endif %}

      {% if s.show_actions %}{{ slot_actions }}{% endif %}

      {% if s.show_search %}
        <a href='/search' class='p-2 hover:opacity-70'>
          <span class='sr-only'>Search</span>
          {% render 'icon', name: 'search', class: 'w-5 h-5' %}
        </a>
      {% endif %}

      {% if s.show_cart %}
        {% assign cart_bg_color = blank %}
        {% if s.cart_bg_role == 'palette' and s.cart_bg_role_palette != blank %}
          {% assign cart_bg_color = 'var(--palette-{{ s.cart_bg_role_palette }})' %}
        {% elsif s.cart_bg_role == 'custom' and s.cart_bg_role_custom != blank %}
          {% assign cart_bg_color = s.cart_bg_role_custom %}
        {% endif %}
        {% assign cart_text_color = blank %}
        {% if s.cart_text_role == 'palette' and s.cart_text_role_palette != blank %}
          {% assign cart_text_color = 'var(--palette-{{ s.cart_text_role_palette }})' %}
        {% elsif s.cart_text_role == 'custom' and s.cart_text_role_custom != blank %}
          {% assign cart_text_color = s.cart_text_role_custom %}
        {% endif %}
        {% assign badge_bg_color = blank %}
        {% if s.cart_badge_bg_role == 'palette' and s.cart_badge_bg_role_palette != blank %}
          {% assign badge_bg_color = 'var(--palette-{{ s.cart_badge_bg_role_palette }})' %}
        {% elsif s.cart_badge_bg_role == 'custom' and s.cart_badge_bg_role_custom != blank %}
          {% assign badge_bg_color = s.cart_badge_bg_role_custom %}
        {% endif %}
        {% assign badge_text_color = blank %}
        {% if s.cart_badge_text_role == 'palette' and s.cart_badge_text_role_palette != blank %}
          {% assign badge_text_color = 'var(--palette-{{ s.cart_badge_text_role_palette }})' %}
        {% elsif s.cart_badge_text_role == 'custom' and s.cart_badge_text_role_custom != blank %}
          {% assign badge_text_color = s.cart_badge_text_role_custom %}
        {% endif %}
        {% assign cart_button_styles = blank %}
        {% if s.cart_size %}
          {% assign cart_button_styles = cart_button_styles
            | push: 'width: {{ s.cart_size }}rem'
            | push: 'height: {{ s.cart_size }}rem'
          %}
        {% endif %}
        {% if cart_bg_color != blank %}
          {% assign cart_button_styles = cart_button_styles | push: 'background: {{ cart_bg_color }}' %}
        {% endif %}
        {% if cart_text_color != blank %}
          {% assign cart_button_styles = cart_button_styles | push: 'color: {{ cart_text_color }}' %}
        {% endif %}
        {% if s.cart_shadow_color_override and s.cart_shadow_color != blank %}
          {% assign cart_button_styles = cart_button_styles | push: '--shadow: {{ s.cart_shadow_color }}' %}
        {% endif %}
        {% assign cart_btn_class = 'header-cart-btn relative hover:opacity-90 inline-flex items-center justify-center shrink-0' %}
        {% if s.cart_shadow %}
          {% assign cart_btn_class = cart_btn_class | append: ' shadow-lg' %}
        {% endif %}
        {% if s.cart_shape == 'circle' or cart_bg_color != blank %}
          {% assign cart_btn_class = cart_btn_class | append: ' rounded-full' %}
        {% else %}
          {% assign cart_btn_class = cart_btn_class | append: ' p-2 hover:opacity-70' %}
        {% endif %}
        <a
          data-action='open-cart'
          class='{{ cart_btn_class }}'
          style='{{ cart_button_styles | join: ";" }}'
        >
          <span class='sr-only' data-cart-aria aria-live='polite'>{{ 'cart.aria_label_empty' | t }}</span>
          {% if s.cart_icon_svg != blank %}
            {{ s.cart_icon_svg }}
          {% else %}
            {% render 'icon', name: 'bag', class: 'w-6 h-6' %}
          {% endif %}
          {% assign badge_styles = blank %}
          {% if badge_bg_color != blank %}
            {% assign badge_styles = badge_styles | push: 'background: {{ badge_bg_color }}' %}
          {% endif %}
          {% if badge_text_color != blank %}
            {% assign badge_styles = badge_styles | push: 'color: {{ badge_text_color }}' %}
          {% endif %}
          <span
            class='cart-count-badge'
            data-cart-badge
            data-empty
            style='{{ badge_styles | join: ";" }}'
            data-aria-empty='{{ 'cart.aria_label_empty' | t }}'
            data-aria-one='{{ 'cart.aria_label_one' | t }}'
            data-aria-other='{{ 'cart.aria_label_other' | t }}'
            ><span data-cart-count>0</span></span
          >
        </a>
      {% endif %}

      {% if s.mobile_layout == 'logo_left' %}{{ hamburger_btn }}{% endif %}
    </div>
  </div>
</header>

{% if needs_spacer %}
  <div class='w-full h-16'></div>
{% endif %}

{% schema %}
{
  "name": "Header",
  "restriction": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "width",
      "id": "width",
      "label": "Max Content Width",
      "default": "fill"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Logo placement",
      "options": [
        {
          "value": "logo_center",
          "label": "Center"
        },
        {
          "value": "logo_left",
          "label": "Left"
        }
      ],
      "default": "logo_center"
    },
    {
      "type": "select",
      "id": "nav_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "info": "Desktop only.",
      "conditional": "setting.desktop_layout == 'logo_left'"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile logo placement",
      "options": [
        { "value": "logo_center", "label": "Center" },
        { "value": "logo_left", "label": "Left" },
        { "value": "logo_right", "label": "Right" }
      ],
      "default": "logo_center"
    },
    {
      "type": "width",
      "id": "mobile_breakpoint",
      "label": "Desktop nav breakpoint",
      "default": "broad",
      "info": "Width threshold above which the desktop nav shows and the hamburger is hidden."
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "space",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "space",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "default": "xs"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "header",
      "content": "Borders"
    },
    {
      "type": "select",
      "id": "border_mode",
      "label": "Border",
      "default": "none",
      "options": [
        { "value": "custom", "label": "Custom" },
        { "value": "full", "label": "Full" },
        { "value": "none", "label": "None" }
      ]
    },
    {
      "type": "select",
      "id": "border_role",
      "label": "Border Color",
      "default": "default",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "default", "label": "Default" },
        { "value": "emphasis", "label": "Emphasis" },
        { "value": "palette", "label": "Base Palette" },
        { "value": "custom", "label": "Raw Color" }
      ],
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "palette",
      "id": "border_role_palette",
      "label": "Border Palette Token",
      "default": "brand",
      "conditional": "setting.border_role == 'palette' and setting.border_mode != 'none'"
    },
    {
      "type": "color",
      "id": "border_role_custom",
      "label": "Raw Border",
      "conditional": "setting.border_role == 'custom' and setting.border_mode != 'none'"
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border Style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "dotted", "label": "Dotted" },
        { "value": "double", "label": "Double" }
      ],
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "select",
      "id": "border_size",
      "label": "Border Size",
      "default": "xxs",
      "options": [
        { "value": "xxs", "label": "XXS", "info": "1px" },
        { "value": "xs", "label": "XS", "info": "2px" },
        { "value": "sm", "label": "SM", "info": "4px" },
        { "value": "md", "label": "MD", "info": "6px" },
        { "value": "lg", "label": "LG", "info": "8px" }
      ],
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_left",
      "label": "Border Left",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_right",
      "label": "Border Right",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_top",
      "label": "Border Top",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_bottom",
      "label": "Border Bottom",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "select",
      "id": "sticky_behavior",
      "label": "Sticky Mode",
      "options": [
        {
          "value": "none",
          "label": "Static"
        },
        {
          "value": "always",
          "label": "Always"
        },
        {
          "value": "on_scroll_up",
          "label": "Scroll"
        }
      ],
      "default": "always"
    },
    {
      "type": "select",
      "id": "header_overlay_mode",
      "label": "Header Overlay",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "overlay",
          "label": "Top of Content"
        },
        {
          "value": "transparent",
          "label": "Transparent on Top"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "show_nav",
      "label": "Show Navigation",
      "info": "Renders the desktop nav (and the drawer's nav links). Disable for minimal headers — e.g. checkout, order confirmation.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_actions",
      "label": "Show Action Blocks",
      "info": "Renders the user-arranged action blocks (buttons, groups). Cart and search icons have their own toggles.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_mobile_menu",
      "label": "Show Mobile Drawer",
      "info": "Renders the hamburger button and drawer below the desktop breakpoint. Disable for headers that don't need a mobile menu (e.g. checkout).",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show Search",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "Show Cart",
      "default": true
    },
    {
      "type": "header",
      "content": "Cart Style",
      "conditional": "setting.show_cart == true"
    },
    {
      "type": "textarea",
      "id": "cart_icon_svg",
      "label": "Cart Icon (custom SVG)",
      "info": "Paste raw SVG. Falls back to default bag icon if empty.",
      "conditional": "setting.show_cart == true"
    },
    {
      "type": "range",
      "id": "cart_size",
      "label": "Cart Button Size",
      "min": 0,
      "max": 5,
      "step": 0.125,
      "unit": "rem",
      "default": 0,
      "info": "0 = default icon-only sizing.",
      "conditional": "setting.show_cart == true"
    },
    {
      "type": "select",
      "id": "cart_shape",
      "label": "Cart Button Shape",
      "default": "icon",
      "options": [
        { "value": "icon", "label": "Icon Only" },
        { "value": "circle", "label": "Circle" }
      ],
      "conditional": "setting.show_cart == true"
    },
    {
      "type": "select",
      "id": "cart_bg_role",
      "label": "Cart Button BG",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "palette", "label": "Palette" },
        { "value": "custom", "label": "Raw" }
      ],
      "conditional": "setting.show_cart == true"
    },
    {
      "type": "palette",
      "id": "cart_bg_role_palette",
      "label": "Cart BG Palette",
      "conditional": "setting.show_cart == true and setting.cart_bg_role == 'palette'"
    },
    {
      "type": "color",
      "id": "cart_bg_role_custom",
      "label": "Cart BG Color",
      "conditional": "setting.show_cart == true and setting.cart_bg_role == 'custom'"
    },
    {
      "type": "select",
      "id": "cart_text_role",
      "label": "Cart Icon Color",
      "default": "none",
      "options": [
        { "value": "none", "label": "Inherit" },
        { "value": "palette", "label": "Palette" },
        { "value": "custom", "label": "Raw" }
      ],
      "conditional": "setting.show_cart == true"
    },
    {
      "type": "palette",
      "id": "cart_text_role_palette",
      "label": "Cart Icon Palette",
      "conditional": "setting.show_cart == true and setting.cart_text_role == 'palette'"
    },
    {
      "type": "color",
      "id": "cart_text_role_custom",
      "label": "Cart Icon Color",
      "conditional": "setting.show_cart == true and setting.cart_text_role == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "cart_shadow",
      "label": "Cart Button Shadow",
      "default": false,
      "conditional": "setting.show_cart == true"
    },
    {
      "type": "checkbox",
      "id": "cart_shadow_color_override",
      "label": "Override Cart Shadow Color",
      "default": false,
      "conditional": "setting.show_cart == true and setting.cart_shadow == true"
    },
    {
      "type": "color",
      "id": "cart_shadow_color",
      "label": "Cart Shadow Color",
      "default": "rgba(0,0,0,0.45)",
