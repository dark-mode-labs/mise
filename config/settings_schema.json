{
  "schema": [
    {
      "name": "Typography",
      "id": "typography",
      "settings": [
        {
          "type": "font_scheme",
          "id": "heading_font_scheme",
          "label": "Heading Font",
          "default": "default"
        },
        {
          "type": "font_scheme",
          "id": "body_font_scheme",
          "label": "Body Font",
          "default": "default"
        },
        {
          "type": "font_scheme",
          "id": "button_font_scheme",
          "label": "Button / UI Font",
          "default": "default"
        },
        {
          "type": "range",
          "id": "type_scale",
          "label": "Type Scale",
          "min": 80,
          "max": 120,
          "step": 5,
          "default": 100,
          "unit": "%"
        }
      ]
    },
    {
      "name": "Layout",
      "id": "layout",
      "settings": [
        {
          "type": "range",
          "id": "corner_radius",
          "label": "Global Corner Radius",
          "min": 0,
          "max": 40,
          "step": 4,
          "default": 0,
          "unit": "px",
          "info": "Affects buttons, cards, and media."
        }
      ]
    },
    {
      "name": "Social Media",
      "id": "social_media",
      "settings": [
        {
          "type": "header",
          "content": "Accounts"
        },
        {
          "type": "text",
          "id": "instagram_link",
          "label": "Instagram",
          "info": "https://instagram.com/@yourhandle"
        },
        {
          "type": "text",
          "id": "facebook_link",
          "label": "Facebook",
          "info": "https://facebook.com/yourpage"
        },
        {
          "type": "text",
          "id": "tiktok_link",
          "label": "TikTok",
          "info": "https://tiktok.com/@yourhandle"
        },
        {
          "type": "text",
          "id": "twitter_link",
          "label": "X (Twitter)",
          "info": "https://x.com/@yourhandle"
        },
        {
          "type": "text",
          "id": "yelp_link",
          "label": "Yelp",
          "info": "https://yelp.com/biz/your-biz"
        },
        {
          "type": "text",
          "id": "linkedin_link",
          "label": "LinkedIn",
          "info": "https://linkedin.com/company/your-company"
        },
        {
          "type": "text",
          "id": "youtube_link",
          "label": "YouTube",
          "info": "https://youtube.com/@yourhandle"
        }
      ]
    },
    {
      "name": "Brand Palette",
      "type": "group",
      "id": "palette",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Token"
        },
        {
          "type": "color",
          "id": "value",
          "label": "Color",
          "default": "rgba(0, 0, 0, 1)",
          "info": "Hex (e.g. #ea580c) or CSS gradient string."
        }
      ]
    },
    {
      "name": "Surfaces",
      "type": "group",
      "id": "surfaces",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Surface"
        },
        {
          "type": "header",
          "content": "Background slots",
          "info": "Hex / gradient / @palette-token reference. Leave empty to default to transparent."
        },
        {
          "type": "color",
          "id": "background",
          "label": "Background"
        },
        {
          "type": "color",
          "id": "background_alt",
          "label": "Background (alt)"
        },
        {
          "type": "color",
          "id": "surface",
          "label": "Surface"
        },
        {
          "type": "color",
          "id": "surface_alt",
          "label": "Surface (alt)"
        },
        {
          "type": "color",
          "id": "accent_bg",
          "label": "Accent BG"
        },
        {
          "type": "color",
          "id": "button_bg",
          "label": "Button BG"
        },
        {
          "type": "color",
          "id": "control_bg",
          "label": "Control BG"
        },
        {
          "type": "header",
          "content": "Text slots"
        },
        {
          "type": "color",
          "id": "text",
          "label": "Text — primary"
        },
        {
          "type": "color",
          "id": "text_secondary",
          "label": "Text — secondary"
        },
        {
          "type": "color",
          "id": "text_subtle",
          "label": "Text — subtle"
        },
        {
          "type": "color",
          "id": "text_emphasis",
          "label": "Text — emphasis"
        },
        {
          "type": "color",
          "id": "text_on_accent",
          "label": "Text on accent"
        },
        {
          "type": "color",
          "id": "text_on_button",
          "label": "Text on button"
        },
        {
          "type": "color",
          "id": "text_on_control",
          "label": "Text on control"
        },
        {
          "type": "header",
          "content": "Borders & shadow"
        },
        {
          "type": "color",
          "id": "border",
          "label": "Border"
        },
        {
          "type": "color",
          "id": "border_emphasis",
          "label": "Border — emphasis"
        },
        {
          "type": "color",
          "id": "shadow",
          "label": "Shadow"
        }
      ]
    },
    {
      "name": "Font Schemes",
      "type": "group",
      "id": "font_schemes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Font Scheme"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Font Family",
          "info": "CSS font-family value used for --font-heading, --font-body, --font-button. E.g. 'Inter', 'Playfair Display', sans-serif.",
          "default": "sans-serif"
        },
        {
          "type": "text",
          "id": "url",
          "label": "Google Fonts URL",
          "info": "Full stylesheet URL from Google Fonts (e.g. https://fonts.googleapis.com/css2?family=Inter…). Leave blank for system fonts."
        }
      ]
    },
    {
      "name": "Max Width Schemes",
      "type": "group",
      "id": "width_schemes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Default Width Scheme"
        },
        {
          "type": "select",
          "id": "width",
          "label": "Width",
          "options": [
            {
              "value": "sm",
              "label": "Small"
            },
            {
              "value": "md",
              "label": "Medium"
            },
            {
              "value": "lg",
              "label": "Large"
            },
            {
              "value": "xl",
              "label": "x-Large"
            },
            {
              "value": "2xl",
              "label": "2x-Large"
            },
            {
              "value": "3xl",
              "label": "3x-Large"
            },
            {
              "value": "4xl",
              "label": "4x-Large"
            },
            {
              "value": "5xl",
              "label": "5x-Large"
            },
            {
              "value": "6xl",
              "label": "6x-Large"
            },
            {
              "value": "7xl",
              "label": "7x-Large"
            },
            {
              "value": "fit",
              "label": "Fit Content"
            },
            {
              "value": "full",
              "label": "Full"
            },
            {
              "value": "half",
              "label": "Half"
            },
            {
              "value": "third",
              "label": "Third"
            },
            {
              "value": "custom",
              "label": "Custom"
            }
          ],
          "default": "fit"
        },
        {
          "type": "text",
          "id": "custom_width",
          "label": "Width (rem)",
          "info": "Enter a number in rem units (e.g. 80 for 80rem ≈ 1280px at base font size).",
          "default": "93.5",
          "conditional": "setting.width == 'custom'"
        }
      ]
    },
    {
      "name": "Preconnect Schemes",
      "type": "group",
      "id": "preconnect_schemes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Preconnect URL"
        },
        {
          "type": "text",
          "id": "url",
          "label": "Preconnect URL"
        },
        {
          "type": "text",
          "id": "attributes",
          "label": "Additional Attributes"
        }
      ]
    }
  ],
  "presets": {
    "default": {
      "layout": {
        "corner_radius": 0
      },
      "typography": {
        "type_scale": 100,
        "heading_font_scheme": "heading",
        "body_font_scheme": "body",
        "button_font_scheme": "button"
      },
      "font_schemes": {
        "heading": {
          "settings": {
            "title": "Heading",
            "name": "Inter",
            "url": "https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
          }
        },
        "body": {
          "settings": {
            "title": "Body",
            "name": "Inter",
            "url": "https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
          }
        },
        "button": {
          "settings": {
            "title": "Button",
            "name": "Inter",
            "url": "https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
          }
        }
      },
      "preconnect_schemes": {
        "fonts-google-apis": {
          "settings": {
            "title": "Fonts GoogleApis",
            "url": "https://fonts.googleapis.com"
          }
        },
        "fonts-gstatic": {
          "settings": {
            "title": "Fonts GStatic",
            "url": "https://fonts.gstatic.com",
            "attributes": "crossorigin"
          }
        }
      },
      "palette": {
        "neutral-0": {
          "settings": {
            "title": "Neutral 0",
            "value": "#ffffff"
          }
        },
        "neutral-100": {
          "settings": {
            "title": "Neutral 100",
            "value": "#f5f5f4"
          }
        },
        "neutral-300": {
          "settings": {
            "title": "Neutral 300",
            "value": "#d6d3d1"
          }
        },
        "neutral-500": {
          "settings": {
            "title": "Neutral 500",
            "value": "#78716c"
          }
        },
        "neutral-700": {
          "settings": {
            "title": "Neutral 700",
            "value": "#44403c"
          }
        },
        "neutral-900": {
          "settings": {
            "title": "Neutral 900",
            "value": "#1c1917"
          }
        },
        "brand": {
          "settings": {
            "title": "Brand",
            "value": "#0891b2"
          }
        },
        "brand-soft": {
          "settings": {
            "title": "Brand Soft",
            "value": "#bae6fd"
          }
        }
      },
      "surfaces": {
        "default": {
          "settings": {
            "title": "Default",
            "background": "@neutral-0",
            "background_alt": "@neutral-100",
            "surface": "@neutral-100",
            "surface_alt": "@neutral-300",
            "accent_bg": "@brand",
            "button_bg": "@brand",
            "control_bg": "@brand",
            "text": "@neutral-900",
            "text_secondary": "@neutral-700",
            "text_subtle": "@neutral-500",
            "text_emphasis": "@brand",
            "text_on_accent": "@neutral-0",
            "text_on_button": "@neutral-0",
            "text_on_control": "@neutral-0",
            "border": "@neutral-300",
            "border_emphasis": "@brand",
            "shadow": "rgba(8, 145, 178, 0.15)"
          }
        },
        "none": {
          "settings": {
            "title": "No Surface"
          }
        }
      },
      "width_schemes": {
        "fit": {
          "settings": {
            "title": "Fit Content",
            "width": "fit",
            "custom_width": "fit-content"
          }
        },
        "full": {
          "settings": {
            "title": "Full",
            "width": "full",
            "custom_width": "100%"
          }
        },
        "half": {
          "settings": {
            "title": "Half",
            "width": "half",
            "custom_width": "50%"
          }
        },
        "third": {
          "settings": {
            "title": "Third",
            "width": "third",
            "custom_width": "33%"
          }
        },
        "wide-6xl": {
          "settings": {
            "title": "Wide 6XL",
            "width": "6xl",
            "custom_width": "64"
          }
        },
        "wide-7xl": {
          "settings": {
            "title": "Wide 7XL",
            "width": "7xl",
            "custom_width": "80"
          }
        },
        "narrow-sm": {
          "settings": {
            "title": "Narrow SM",
            "width": "sm",
            "custom_width": "24"
          }
        },
        "narrow-md": {
          "settings": {
            "title": "Narrow MD",
            "width": "md",
            "custom_width": "28"
          }
        },
        "narrow-lg": {
          "settings": {
            "title": "Narrow LG",
            "width": "lg",
            "custom_width": "32"
          }
        },
        "narrow-xl": {
          "settings": {
            "title": "Narrow XL",
            "width": "xl",
            "custom_width": "36"
          }
        },
        "narrow-2xl": {
          "settings": {
            "title": "Narrow 2XL",
            "width": "2xl",
            "custom_width": "42"
          }
        },
        "narrow-3xl": {
          "settings": {
            "title": "Narrow 3XL",
            "width": "3xl",
            "custom_width": "48"
          }
        },
        "standard-4xl": {
          "settings": {
            "title": "Standard 4XL",
            "width": "4xl",
            "custom_width": "56"
          }
        },
        "standard-5xl": {
          "settings": {
            "title": "Standard 5XL",
            "width": "5xl",
            "custom_width": "64"
          }
        }
      }
    }
  }
}