        },
        {
          "type": "color",
          "id": "text_on_accent",
          "label": "Text on accent"
        },
        {
          "type": "color",
          "id": "text_on_button",
          "label": "Text on button"
        },
        {
          "type": "color",
          "id": "text_on_control",
          "label": "Text on control"
        },
