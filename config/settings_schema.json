    {
      "name": "Font Schemes",
      "type": "group",
      "id": "font_schemes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Font Scheme"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Font Family",
          "info": "CSS font-family value used for --font-heading, --font-body, --font-button. E.g. 'Inter', 'Playfair Display', sans-serif.",
          "default": "sans-serif"
        },
        {
          "type": "text",
          "id": "url",
          "label": "Google Fonts URL",
          "info": "Full stylesheet URL from Google Fonts (e.g. https://fonts.googleapis.com/css2?family=Inter\u2026). Leave blank for system fonts."
        }
      ]
    },
    {
      "name": "Container Scale",
      "type": "group",
      "id": "container_scale",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Container"
        },
        {
          "type": "text",
          "id": "max_width",
          "label": "Max Width",
          "info": "Any CSS max-width value: rem (e.g. 56rem), %, or \"none\" for unbounded.",
          "default": "56rem"
        }
      ]
    },
    {
      "name": "Height Scale",
      "type": "group",
      "id": "height_scale",
      "info": "Height tiers — flat (single `value`) or responsive (`min`/`max`/`vw` rendered as clamp()). Each tier renders to .height-<id>. The `floor` flag controls whether the tier sets `height` (fixed) or `min-height` (block can grow past it). Structural tiers (`auto`, `full`, `custom`) have specialized CSS in theme.css and skip the dynamic loop.",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Height"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Flat value",
          "info": "If set, the tier is a flat (non-responsive) height. Mutually exclusive with min/max/vw.",
          "default": ""
        },
        {
          "type": "text",
          "id": "min",
          "label": "Mobile floor",
          "info": "Lower bound of clamp() — the height at narrow viewports.",
          "default": ""
        },
        {
          "type": "text",
          "id": "max",
          "label": "Desktop ceiling",
          "info": "Upper bound of clamp() — the height at wide viewports.",
          "default": ""
        },
        {
          "type": "text",
          "id": "vw",
          "label": "Viewport rate",
          "info": "Middle term of clamp(min, X, max). Use vw for width-driven scaling, vh for viewport-relative.",
          "default": ""
        },
        {
          "type": "checkbox",
          "id": "floor",
          "label": "Behaves as a floor (min-height)",
          "info": "When on, blocks using this tier render with `min-height` — block can grow past the tier value if its content is taller. When off (default), the tier sets a fixed `height`. Source HTML's `min-h-N` maps to floor tiers; `h-N` maps to fixed tiers.",
          "default": false
        }
      ]
    },
    {
      "name": "Type Scale",
      "type": "group",
      "id": "text_scale",
      "info": "Typography tiers — flat (`value`) or responsive (`min`/`max`/`vw` rendered as clamp()). Each tier renders to .fs-<id>. Built-in tiers: jumbo/display/h1..h6/body/small/caption. Transpiler synthesizes additional tiers when source HTML uses responsive text-size patterns (e.g. `text-5xl sm:text-6xl md:text-7xl lg:text-8xl` mints a clamp tier scaling 48px → 96px). Structural tiers have specialized CSS in theme.css and skip the dynamic loop.",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Type"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Flat value",
          "info": "If set, the tier is a flat (non-responsive) font size. Mutually exclusive with min/max/vw.",
          "default": ""
        },
        {
          "type": "text",
          "id": "min",
          "label": "Mobile floor",
          "info": "Lower bound of clamp() — the size at narrow viewports.",
          "default": ""
        },
        {
          "type": "text",
          "id": "max",
          "label": "Desktop ceiling",
          "info": "Upper bound of clamp() — the size at wide viewports.",
          "default": ""
        },
        {
          "type": "text",
          "id": "vw",
          "label": "Viewport rate",
          "info": "Middle term of clamp(min, X, max). vw lets the tier scale with viewport width.",
          "default": ""
        }
      ]
    },
    {
      "name": "Space Scale",
      "type": "group",
      "id": "space_scale",
      "info": "Spacing tiers — flat (single `value`) or responsive (`min`/`max`/`vw` rendered as clamp()). Each tier renders to --space-<id> for padding/margin/gap classes. Built-ins (none/xs/sm/md/lg/xl/2xl/3xl/custom) live in defaults; transpiler synthesizes additional tiers from source HTML responsive spacing pairs. Structural tiers (`none` zero-out, `custom` per-instance values via --space-pl/pr/pt/pb/mt/mb/ml/mr/gap) have specialized CSS rules in theme.css; the dynamic loop in theme_variables.liquid skips them.",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Space"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Flat value",
          "info": "If set, the tier is a flat (non-responsive) length. Mutually exclusive with min/max/vw.",
          "default": ""
        },
        {
          "type": "text",
          "id": "min",
          "label": "Mobile floor",
          "info": "Lower bound of clamp() — the value at narrow viewports.",
          "default": ""
        },
        {
          "type": "text",
          "id": "max",
          "label": "Desktop ceiling",
          "info": "Upper bound of clamp() — the value at wide viewports.",
          "default": ""
        },
        {
          "type": "text",
          "id": "vw",
          "label": "Viewport rate",
          "info": "Middle term of clamp(min, X, max). Typically max-rem * 1.25 vw so the clamp hits max around the xl breakpoint (1280px).",
          "default": ""
        }
      ]
    },
    {
      "name": "Brand Gradients",
      "type": "group",
      "id": "gradients",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Gradient"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Gradient",
          "info": "Any CSS gradient (linear-gradient, radial-gradient, conic-gradient).",
          "default": "linear-gradient(to bottom, #000, transparent)"
        }
      ]
    },
    {
      "name": "Preconnect Schemes",
      "type": "group",
      "id": "preconnect_schemes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Preconnect URL"
        },
        {
          "type": "text",
          "id": "url",
          "label": "Preconnect URL"
        },
        {
          "type": "text",
          "id": "attributes",
          "label": "Additional Attributes"
        }
      ]
    }
  ],
