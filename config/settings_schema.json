{
  "schema": [
    {
      "name": "Color Schemes",
      "type": "group",
      "id": "color_schemes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Default Color Scheme"
        },
        {
          "type": "header",
          "content": "Base Colors"
        },
        {
          "type": "color",
          "id": "background",
          "label": "Background",
          "default": "rgba(255, 255, 255, 1)"
        },
        {
          "type": "color",
          "id": "text",
          "label": "Text",
          "default": "rgba(255, 255, 255, 1)"
        },
        {
          "type": "color",
          "id": "text_secondary",
          "label": "Secondary Text",
          "default": "rgba(102, 102, 102, 1)"
        },
        {
          "type": "color",
          "id": "accent",
          "label": "Accent / Links",
          "default": "rgba(0, 0, 0, 1)"
        },
        {
          "type": "color",
          "id": "surface",
          "label": "Surface / Card Background",
          "default": "rgba(245, 245, 245, 1)"
        },
        {
          "type": "color",
          "id": "border",
          "label": "Borders",
          "default": "rgba(255, 255, 255, 1)"
        },
        {
          "type": "color",
          "id": "shadow",
          "label": "Shadows",
          "default": "rgba(0, 0, 0, 1)"
        },
        {
          "type": "header",
          "content": "Buttons"
        },
        {
          "type": "color",
          "id": "button_bg",
          "label": "Solid Button Background",
          "default": "rgba(255, 255, 255, 1)"
        },
        {
          "type": "color",
          "id": "button_text",
          "label": "Solid Button Label",
          "default": "rgba(255, 255, 255, 1)"
        },
        {
          "type": "header",
          "content": "UI Controls (Arrows/Dots)"
        },
        {
          "type": "color",
          "id": "ui_bg",
          "label": "Control Background",
          "default": "rgba(255, 255, 255, 1)"
        },
        {
          "type": "color",
          "id": "ui_text",
          "label": "Control Icon/Text",
          "default": "rgba(0, 0, 0, 1)"
        }
      ]
    },
    {
      "name": "Font Schemes",
      "type": "group",
      "id": "font_schemes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Font Scheme"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Font Family",
          "info": "CSS font-family value used for --font-heading, --font-body, --font-button. E.g. 'Inter', 'Playfair Display', sans-serif.",
          "default": "sans-serif"
        },
        {
          "type": "text",
          "id": "url",
          "label": "Google Fonts URL",
          "info": "Full stylesheet URL from Google Fonts (e.g. https://fonts.googleapis.com/css2?family=Inter…). Leave blank for system fonts."
        }
      ]
    },
    {
      "name": "Typography",
      "id": "typography",
      "settings": [
        {
          "type": "font_scheme",
          "id": "heading_font_scheme",
          "label": "Heading Font",
          "default": "default"
        },
        {
          "type": "font_scheme",
          "id": "body_font_scheme",
          "label": "Body Font",
          "default": "default"
        },
        {
          "type": "font_scheme",
          "id": "button_font_scheme",
          "label": "Button / UI Font",
          "default": "default"
        },
        {
          "type": "range",
          "id": "type_scale",
          "label": "Type Scale",
          "min": 80,
          "max": 120,
          "step": 5,
          "default": 100,
          "unit": "%"
        }
      ]
    },
    {
      "name": "Max Width Schemes",
      "type": "group",
      "id": "width_schemes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Default Width Scheme"
        },
        {
          "type": "select",
          "id": "width",
          "label": "Width",
          "options": [
            {
              "value": "sm",
              "label": "Small"
            },
            {
              "value": "md",
              "label": "Medium"
            },
            {
              "value": "lg",
              "label": "Large"
            },
            {
              "value": "xl",
              "label": "x-Large"
            },
            {
              "value": "2xl",
              "label": "2x-Large"
            },
            {
              "value": "3xl",
              "label": "3x-Large"
            },
            {
              "value": "4xl",
              "label": "4x-Large"
            },
            {
              "value": "fit",
              "label": "Fit Content"
            },
            {
              "value": "full",
              "label": "Full"
            },
            {
              "value": "half",
              "label": "Half"
            },
            {
              "value": "third",
              "label": "Third"
            },
            {
              "value": "custom",
              "label": "Custom"
            }
          ],
          "default": "fit"
        },
        {
          "type": "text",
          "id": "custom_width",
          "label": "Width (rem)",
          "info": "Enter a number in rem units (e.g. 80 for 80rem ≈ 1280px at base font size).",
          "default": "93.5",
          "conditional": "setting.width == 'custom'"
        }
      ]
    },
    {
      "name": "Layout",
      "id": "layout",
      "settings": [
        {
          "type": "range",
          "id": "corner_radius",
          "label": "Global Corner Radius",
          "min": 0,
          "max": 40,
          "step": 4,
          "default": 0,
          "unit": "px",
          "info": "Affects buttons, cards, and media."
        }
      ]
    },
    {
      "name": "Social Media",
      "id": "social_media",
      "settings": [
        {
          "type": "header",
          "content": "Accounts"
        },
        {
          "type": "text",
          "id": "instagram_link",
          "label": "Instagram",
          "info": "https://instagram.com/@yourhandle"
        },
        {
          "type": "text",
          "id": "facebook_link",
          "label": "Facebook",
          "info": "https://facebook.com/yourpage"
        },
        {
          "type": "text",
          "id": "tiktok_link",
          "label": "TikTok",
          "info": "https://tiktok.com/@yourhandle"
        },
        {
          "type": "text",
          "id": "twitter_link",
          "label": "X (Twitter)",
          "info": "https://x.com/@yourhandle"
        },
        {
          "type": "text",
          "id": "yelp_link",
          "label": "Yelp",
          "info": "https://yelp.com/biz/your-biz"
        },
        {
          "type": "text",
          "id": "linkedin_link",
          "label": "LinkedIn",
          "info": "https://linkedin.com/company/your-company"
        },
        {
          "type": "text",
          "id": "youtube_link",
          "label": "YouTube",
          "info": "https://youtube.com/@yourhandle"
        }
      ]
    },
    {
      "name": "Preconnect Schemes",
      "type": "group",
      "id": "preconnect_schemes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Preconnect URL"
        },
        {
          "type": "text",
          "id": "url",
          "label": "Preconnect URL"
        },
        {
          "type": "text",
          "id": "attributes",
          "label": "Additional Attributes"
        }
      ]
    }
  ],
  "presets": {
    "default": {
      "layout": {
        "corner_radius": 0
      },
      "typography": {
        "type_scale": 100,
        "heading_font_scheme": "heading",
        "body_font_scheme": "body",
        "button_font_scheme": "button"
      },
      "font_schemes": {
        "heading": {
          "settings": {
            "title": "Inter",
            "name": "Inter",
            "url": "https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
          }
        },
        "body": {
          "settings": {
            "title": "Inter",
            "name": "Inter",
            "url": "https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
          }
        },
        "button": {
          "settings": {
            "title": "Inter",
            "name": "Inter",
            "url": "https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
          }
        }
      },
      "preconnect_schemes": {
        "fonts-google-apis": {
          "settings": {
            "title": "Fonts GoogleApis",
            "url": "https://fonts.googleapis.com"
          }
        },
        "fonts-gstatic": {
          "settings": {
            "title": "Fonts GStatic",
            "url": "https://fonts.gstatic.com",
            "attributes": "crossorigin"
          }
        }
      },
      "color_schemes": {
        "default": {
          "settings": {
            "title": "Default Color Scheme",
            "text": "#1A3A4A",
            "ui_bg": "#FFFFFF",
            "accent": "#0891B2",
            "border": "#BAE6FD",
            "shadow": "rgba(8, 145, 178, 0.15)",
            "surface": "#F0F9FF",
            "ui_text": "#1A3A4A",
            "button_bg": "#0891B2",
            "background": "#FDFEFE",
            "button_text": "#FFFFFF",
            "text_secondary": "#5B7C8D"
          }
        },
        "none": {
          "settings": {
            "title": "No Color Scheme",
            "text": "",
            "ui_bg": "",
            "accent": "",
            "border": "",
            "shadow": "",
            "surface": "",
            "ui_text": "",
            "button_bg": "",
            "background": "",
            "button_text": "",
            "text_secondary": ""
          }
        }
      },
      "width_schemes": {
        "fit": {
          "settings": {
            "title": "Fit Content",
            "width": "fit-content",
            "custom_width": "fit-content"
          }
        },
        "full": {
          "settings": {
            "title": "Full",
            "width": "full",
            "custom_width": "100%"
          }
        },
        "half": {
          "settings": {
            "title": "Half",
            "width": "half",
            "custom_width": "50%"
          }
        },
        "third": {
          "settings": {
            "title": "Third",
            "width": "third",
            "custom_width": "33%"
          }
        },
        "wide-6xl": {
          "settings": {
            "title": "Wide 6XL",
            "width": "6xl",
            "custom_width": "64"
          }
        },
        "wide-7xl": {
          "settings": {
            "title": "Wide 7XL",
            "width": "7xl",
            "custom_width": "80"
          }
        },
        "narrow-sm": {
          "settings": {
            "title": "Narrow SM",
            "width": "sm",
            "custom_width": "24"
          }
        },
        "narrow-md": {
          "settings": {
            "title": "Narrow MD",
            "width": "md",
            "custom_width": "28"
          }
        },
        "narrow-lg": {
          "settings": {
            "title": "Narrow LG",
            "width": "lg",
            "custom_width": "32"
          }
        },
        "narrow-xl": {
          "settings": {
            "title": "Narrow XL",
            "width": "xl",
            "custom_width": "36"
          }
        },
        "narrow-2xl": {
          "settings": {
            "title": "Narrow 2XL",
            "width": "2xl",
            "custom_width": "42"
          }
        },
        "narrow-3xl": {
          "settings": {
            "title": "Narrow 3XL",
            "width": "3xl",
            "custom_width": "48"
          }
        },
        "standard-4xl": {
          "settings": {
            "title": "Standard 4XL",
            "width": "4xl",
            "custom_width": "56"
          }
        },
        "standard-5xl": {
          "settings": {
            "title": "Standard 5XL",
            "width": "5xl",
            "custom_width": "64"
          }
        }
      }
    }
  }
}