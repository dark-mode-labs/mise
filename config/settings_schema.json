    },
    {
      "name": "Font Schemes",
      "type": "group",
      "id": "font_schemes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Font Scheme"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Font Family",
          "info": "CSS font-family value used for --font-heading, --font-body, --font-button, --font-accent. E.g. 'Inter', 'Playfair Display', sans-serif.",
          "default": "sans-serif"
        },
        {
          "type": "text",
          "id": "url",
          "label": "Google Fonts URL",
          "info": "Full stylesheet URL from Google Fonts (e.g. https://fonts.googleapis.com/css2?family=Inter\u2026). Leave blank for system fonts."
        }
      ]
    },
    {
      "name": "Type Styles",
      "type": "group",
      "id": "type_styles",
      "info": "Type styles bundle font family, size, weight, tracking, leading, and transform into one named treatment. Text-rendering blocks reference a single `type_style: <id>` instead of setting all dimensions individually. Single-dimension `font_size` (flat rem) \u2014 mobile responsiveness handled by CSS-side media queries on the rendered .ts-<id> class.",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Type Style"
        },
        {
          "type": "font_scheme",
          "id": "font_ref",
          "label": "Font",
          "info": "Picks one of the named font schemes (heading / body / button / brand-extended).",
          "default": "body"
        },
        {
          "type": "text",
          "id": "font_size",
          "label": "Font Size",
          "info": "Flat font-size value (e.g. `3rem`). Single-dimension only \u2014 mobile shrink applied via CSS media queries on .ts-<id>, not per-style data.",
          "default": "1rem"
        },
        {
          "type": "select",
          "id": "weight",
          "label": "Weight",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "medium", "label": "Medium" },
            { "value": "semibold", "label": "Semibold" },
            { "value": "bold", "label": "Bold" },
            { "value": "extrabold", "label": "Extra Bold" },
            { "value": "black", "label": "Black" }
          ]
        },
        {
          "type": "select",
          "id": "tracking",
          "label": "Tracking",
          "default": "normal",
          "options": [
            { "value": "tighter", "label": "Tighter" },
            { "value": "tight", "label": "Tight" },
            { "value": "normal", "label": "Normal" },
            { "value": "wide", "label": "Wide" },
            { "value": "wider", "label": "Wider" },
            { "value": "widest", "label": "Widest" }
          ]
        },
        {
          "type": "select",
          "id": "leading",
          "label": "Leading",
          "default": "normal",
          "options": [
            { "value": "none", "label": "None (1)" },
            { "value": "tight", "label": "Tight (1.25)" },
            { "value": "snug", "label": "Snug (1.375)" },
            { "value": "normal", "label": "Normal (1.5)" },
            { "value": "relaxed", "label": "Relaxed (1.625)" },
            { "value": "loose", "label": "Loose (2)" }
          ]
        },
        {
          "type": "select",
          "id": "transform",
          "label": "Transform",
          "default": "none",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "uppercase", "label": "Uppercase" },
            { "value": "lowercase", "label": "Lowercase" },
            { "value": "capitalize", "label": "Capitalize" }
          ]
        }
      ]
    },
    {
      "name": "Container Scale",
      "type": "group",
      "id": "container_scale",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Container"
        },
        {
          "type": "text",
          "id": "max_width",
          "label": "Max Width",
          "info": "Any CSS max-width value: rem (e.g. 56rem), %, or \"none\" for unbounded.",
          "default": "56rem"
        }
      ]
    },
    {
      "name": "Height Scale",
      "type": "group",
      "id": "height_scale",
      "info": "Height tiers — single `value` (any CSS length: rem, %, vh, etc.). Each tier renders to .height-<id>. The `floor` flag controls whether the tier sets `height` (fixed) or `min-height` (block can grow past it). Structural tiers (`auto`, `full`, `custom`) have specialized CSS in theme.css and skip the dynamic loop.",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Height"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "info": "Any CSS length: rem (e.g. `16rem`), %, vh (e.g. `100vh`), or `auto`.",
          "default": ""
        },
        {
          "type": "checkbox",
          "id": "floor",
          "label": "Behaves as a floor (min-height)",
          "info": "When on, blocks using this tier render with `min-height` — block can grow past the tier value if its content is taller. When off (default), the tier sets a fixed `height`. Source HTML's `min-h-N` maps to floor tiers; `h-N` maps to fixed tiers.",
          "default": false
        }
      ]
    },
    {
      "name": "Space Scale",
      "type": "group",
      "id": "space_scale",
      "info": "Spacing tiers — single `value` (any CSS length: rem, em, etc.). Each tier renders to --space-<id> for padding/margin/gap classes. Built-ins (none/xs/sm/md/lg/xl/2xl/3xl/custom) live in defaults; transpiler synthesizes additional tiers from source HTML spacing values. Structural tiers (`none` zero-out, `custom` per-instance values via --space-pl/pr/pt/pb/mt/mb/ml/mr/gap) have specialized CSS rules in theme.css; the dynamic loop in theme_variables.liquid skips them.",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Space"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "info": "Any CSS length: rem (e.g. `1rem`, `1.5rem`), em, or px.",
          "default": ""
        }
      ]
    },
    {
      "name": "Brand Gradients",
      "type": "group",
      "id": "gradients",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Gradient"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Gradient",
          "info": "Any CSS gradient (linear-gradient, radial-gradient, conic-gradient).",
          "default": "linear-gradient(to bottom, #000, transparent)"
        }
      ]
    },
    {
      "name": "Preconnect Schemes",
      "type": "group",
      "id": "preconnect_schemes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Preconnect URL"
        },
        {
          "type": "text",
          "id": "url",
          "label": "Preconnect URL"
        },
        {
          "type": "text",
          "id": "attributes",
          "label": "Additional Attributes"
        }
      ]
    }
  ],
