    {
      "name": "Font Schemes",
      "type": "group",
      "id": "font_schemes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Font Scheme"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Font Family",
          "info": "The CSS font-family for this scheme. E.g. 'Inter', 'Playfair Display', sans-serif.",
          "default": "sans-serif"
        },
        {
          "type": "text",
          "id": "url",
          "label": "Google Fonts URL",
          "info": "Full stylesheet URL from Google Fonts (e.g. https://fonts.googleapis.com/css2?family=Inter\u2026). Leave blank for system fonts."
        }
      ]
    },
    {
      "name": "Type Styles",
      "type": "group",
      "id": "type_styles",
      "info": "Named text treatment bundling font family, size, weight, tracking, leading, and transform. Text blocks reference one `type_style` id instead of setting each dimension separately.",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Type Style"
        },
        {
          "type": "font_scheme",
          "id": "font_ref",
          "label": "Font",
          "info": "Picks a named font scheme (e.g. heading, body, button, accent).",
          "default": "body"
        },
        {
          "type": "text",
          "id": "font_size",
          "label": "Font Size",
          "info": "Font size (e.g. `3rem`). Applies at every viewport unless `font_size_by_bp` sets per-breakpoint overrides.",
          "default": "1rem"
        },
        {
          "type": "text",
          "id": "font_size_by_bp",
          "label": "Per-Breakpoint Font Size",
          "info": "JSON map of breakpoint_scale tier id to font size. e.g. `{\"broad\": \"3rem\"}` applies at viewports at or above the broad breakpoint.",
          "default": ""
        },
        {
          "type": "select",
          "id": "weight",
          "label": "Weight",
          "default": "normal",
          "options": [
            {
              "value": "normal",
              "label": "Normal"
            },
            {
              "value": "medium",
              "label": "Medium"
            },
            {
              "value": "semibold",
              "label": "Semibold"
            },
            {
              "value": "bold",
              "label": "Bold"
            },
            {
              "value": "extrabold",
              "label": "Extra Bold"
            },
            {
              "value": "black",
              "label": "Black"
            }
          ]
        },
        {
          "type": "select",
          "id": "tracking",
          "label": "Tracking",
          "default": "normal",
          "options": [
            {
              "value": "tighter",
              "label": "Tighter"
            },
            {
              "value": "tight",
              "label": "Tight"
            },
            {
              "value": "normal",
              "label": "Normal"
            },
            {
              "value": "wide",
              "label": "Wide"
            },
            {
              "value": "wider",
              "label": "Wider"
            },
            {
              "value": "widest",
              "label": "Widest"
            },
            {
              "value": "ultra-wide",
              "label": "Ultra Wide"
            },
            {
              "value": "custom",
              "label": "Custom"
            }
          ]
        },
        {
          "type": "text",
          "id": "tracking_custom",
          "label": "Tracking (custom)",
          "info": "Arbitrary letter-spacing value (e.g. `-0.015em`, `0.04em`).",
          "conditional": "setting.tracking == 'custom'"
        },
        {
          "type": "select",
          "id": "leading",
          "label": "Leading",
          "default": "normal",
          "options": [
            {
              "value": "none",
              "label": "None (1)"
            },
            {
              "value": "tight",
              "label": "Tight (1.25)"
            },
            {
              "value": "snug",
              "label": "Snug (1.375)"
            },
            {
              "value": "normal",
              "label": "Normal (1.5)"
            },
            {
              "value": "relaxed",
              "label": "Relaxed (1.625)"
            },
            {
              "value": "loose",
              "label": "Loose (2)"
            },
            {
              "value": "custom",
              "label": "Custom"
            }
          ]
        },
        {
          "type": "text",
          "id": "leading_custom",
          "label": "Leading (custom)",
          "info": "Arbitrary line-height value (unitless ratio like `1.1` or `1.55`, or `<N>rem` / `<N>em`).",
          "conditional": "setting.leading == 'custom'"
        },
        {
          "type": "select",
          "id": "transform",
          "label": "Transform",
          "default": "none",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "uppercase",
              "label": "Uppercase"
            },
            {
              "value": "lowercase",
              "label": "Lowercase"
            },
            {
              "value": "capitalize",
              "label": "Capitalize"
            }
          ]
        }
      ]
    },
    {
      "name": "Container Scale",
      "type": "group",
      "id": "container_scale",
      "info": "Width tiers. `max_width` caps the element's width. `value` (optional) sets the width directly (`%`, `rem`, `auto`, ...); percentage values also act as flex-grow ratios, so siblings in a flex row share the available space in that ratio regardless of gap. `value_by_bp` (optional) overrides `value` per breakpoint.",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Container"
        },
        {
          "type": "text",
          "id": "max_width",
          "label": "Max Width",
          "info": "Any CSS max-width value: rem (e.g. 56rem), %, or \"none\" for unbounded.",
          "default": "56rem"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Width Value",
          "info": "Width value (e.g. `50%`, `100%`, `auto`, `10rem`). Percentage values also act as flex-grow ratios in flex-row parents.",
          "default": ""
        },
        {
          "type": "text",
          "id": "value_by_bp",
          "label": "Per-Breakpoint Width Overrides",
          "info": "JSON map of breakpoint_scale tier id to width value. e.g. `{\"read\": \"auto\"}` applies at viewports at or above the read breakpoint.",
          "default": ""
        }
      ]
    },
    {
      "name": "Breakpoint Scale",
      "type": "group",
      "id": "breakpoint_scale",
      "info": "Viewport breakpoints. Each tier's `max_width` (numeric rem) is the viewport width at which it activates. Other scales' `value_by_bp` and `font_size_by_bp` maps key off these tier ids.",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Breakpoint"
        },
        {
          "type": "number",
          "id": "max_width",
          "label": "Viewport Threshold (rem)",
          "info": "Viewport width in rem at which this breakpoint activates.",
          "default": 48
        }
      ]
    },
    {
      "name": "Height Scale",
      "type": "group",
      "id": "height_scale",
      "info": "Height tiers. `value` is any CSS length (rem, %, vh, ...). `floor` makes it a minimum height (the block can grow taller) instead of a fixed height. `floor_fill` additionally stretches the block to fill available height without shrinking below `value`. `value_by_bp` (optional) overrides `value` per breakpoint.",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Height"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "info": "Any CSS length: rem (e.g. `16rem`), %, vh (e.g. `100vh`), or `auto`.",
          "default": ""
        },
        {
          "type": "text",
          "id": "value_by_bp",
          "label": "Per-Breakpoint Overrides",
          "info": "JSON map of breakpoint_scale tier id to length. e.g. `{\"broad\": \"32rem\"}` applies at viewports at or above the broad breakpoint.",
          "default": ""
        },
        {
          "type": "checkbox",
          "id": "floor",
          "label": "Behaves as a floor (min-height)",
          "info": "When on, the tier sets a minimum height and the block can grow taller. When off (default), it sets a fixed height.",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "floor_fill",
          "label": "Floor + flex stretch",
          "info": "Like `floor`, but also stretches the block to fill available height while never shrinking below `value`. Useful for hero or section blocks.",
          "default": false
        }
      ]
    },
    {
      "name": "Space Scale",
      "type": "group",
      "id": "space_scale",
      "info": "Spacing tiers used for gap, padding, and margin. `value` is any CSS length. `value_by_bp` (optional) overrides `value` per breakpoint.",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Space"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "info": "Any CSS length: rem (e.g. `1rem`, `1.5rem`), em, or px.",
          "default": ""
        },
        {
          "type": "text",
          "id": "value_by_bp",
          "label": "Per-Breakpoint Overrides",
          "info": "JSON map of breakpoint_scale tier id to length. e.g. `{\"column\": \"3.5rem\"}` applies at viewports at or above the column breakpoint.",
          "default": ""
        }
      ]
    },
    {
      "name": "Brand Gradients",
      "type": "group",
      "id": "gradients",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Gradient"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Gradient",
          "info": "Any CSS gradient (linear-gradient, radial-gradient, conic-gradient).",
          "default": "linear-gradient(to bottom, #000, transparent)"
        }
      ]
    },
    {
      "name": "Preconnect Schemes",
      "type": "group",
      "id": "preconnect_schemes",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "New Preconnect URL"
        },
        {
          "type": "text",
          "id": "url",
          "label": "Preconnect URL"
        },
        {
          "type": "text",
          "id": "attributes",
          "label": "Additional Attributes"
        }
      ]
    }
  ],
