        },
        {
          "type": "color",
          "id": "background",
          "label": "Background"
        },
        {
          "type": "color",
          "id": "background_alt",
          "label": "Background (alt)"
        },
        {
          "type": "color",
          "id": "surface",
          "label": "Surface"
        },
        {
          "type": "color",
          "id": "surface_alt",
          "label": "Surface (alt)"
        },
        {
          "type": "color",
          "id": "accent_bg",
          "label": "Accent BG"
        },
        {
          "type": "color",
          "id": "button_bg",
          "label": "Button BG"
        },
        {
          "type": "color",
          "id": "control_bg",
          "label": "Control BG"
        },
        {
          "type": "header",
