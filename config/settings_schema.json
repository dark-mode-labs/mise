{
  "schema": [
    {
      "name": "Layout",
      "id": "layout",
      "settings": [
        {
          "type": "range",
          "id": "corner_radius",
          "label": "Global Corner Radius",
          "min": 0,
          "max": 40,
          "step": 4,
          "default": 0,
          "unit": "px",
          "info": "Affects buttons, cards, and media."
        }
      ]
    },
    {
      "name": "Social Media",
      "id": "social_media",
      "settings": [
        {
          "type": "header",
          "content": "Accounts"
        },
        {
          "type": "text",
          "id": "instagram_link",
          "label": "Instagram",
          "info": "https://instagram.com/@yourhandle"
        },
        {
          "type": "text",
          "id": "facebook_link",
          "label": "Facebook",
          "info": "https://facebook.com/yourpage"
        },
        {
          "type": "text",
          "id": "tiktok_link",
          "label": "TikTok",
          "info": "https://tiktok.com/@yourhandle"
        },
        {
          "type": "text",
          "id": "twitter_link",
          "label": "X (Twitter)",
