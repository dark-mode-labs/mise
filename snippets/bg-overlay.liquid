{% comment %}
  Renders an overlay layer. Inputs:
    role         — overlay_role: 'none' | scheme role | 'custom'
    alpha        — overlay_alpha (0..100). ONLY applied for scheme-role
                   overlays. When role == 'custom', the user-supplied
                   value (hex/rgba/gradient) already encodes its own
                   alpha; opacity stays 1.
    custom_color — overlay_role_custom string (hex / rgba / gradient)
    behind       — false: paints ON TOP (hero/grid/_slide media dim)
                   true:  paints BEHIND siblings as a bg layer
                          (footer/group/badge/_menu-card-full/carousel —
                           host must include `isolate`).
{% endcomment %}

{% assign overlay_z = '' %}
{% if behind %}
  {% assign overlay_z = ' -z-10' %}
{% endif %}

{% assign is_custom = false %}
{% if role == 'custom' %}{% assign is_custom = true %}{% endif %}

{% if is_custom and custom_color != blank %}
  <div
    class="rounded-global absolute inset-0 pointer-events-none{{ overlay_z }}"
    style="background: {{ custom_color }};"
  ></div>
{% elsif role and role != 'none' and role != 'custom' %}
  {% comment %}
    Scheme-role overlay: paint via `.bg-<role>` with
    opacity = alpha/100. Use 0..1 form for max browser
    compatibility. Default to 1 if alpha unset.
  {% endcomment %}
  {% assign overlay_alpha_value = 1 %}
  {% if alpha != blank and alpha != null %}
    {% assign overlay_alpha_value = alpha | divided_by: 100.0 %}
  {% endif %}
  <div
    class="rounded-global absolute inset-0 pointer-events-none{{ overlay_z }} bg-{{ role }}"
    style="opacity: {{ overlay_alpha_value }};"
  ></div>
{% endif %}
