{% assign dir = direction | default: 'left' %}
{% assign anim_class = 'animate-marquee' %}
{% assign size_class = size_class | default: 'text-sm' %}
{% assign case_class = 'uppercase tracking-widest' %}
{% unless uppercase %}
  {% assign case_class = '' %}
{% endunless %}
{% assign sep = separator | default: '•' %}

{% if dir == 'right' %}
  {% assign anim_class = 'animate-marquee-reverse' %}
{% endif %}

{% assign list = items | split: ',' %}

{%- capture sep_vars -%}
  --marquee-sep: "{{ sep }}";
  {%- if separator_color != blank %} --marquee-sep-color: {{ separator_color }}; --marquee-sep-opacity: 1;{% endif -%}
{%- endcapture -%}

{% assign copies = 4 %}
{% assign dur = speed | default: 15 | times: copies | divided_by: 2 %}

<div class='overflow-hidden'>
  <div
    class='marquee-track flex w-max {{ anim_class }}'
    style='animation-duration: {{ dur }}s; {{ sep_vars }}'
  >
    {% for i in (1..copies) %}
      <div
        class='flex gap-12 shrink-0 pr-12'
        {% if i > 1 %}
          aria-hidden='true'
        {% endif %}
      >
        {% for item in list %}
          <span class='marquee-item {{ size_class }} font-bold {{ case_class }} whitespace-nowrap'>{{ item }}</span>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>
