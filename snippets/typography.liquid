{% assign tag_el = tag | default: 'p' %}

{% comment %} --- Display Size & Font Family Defaults --- {% endcomment %}
{% assign size_class = 'text-base' %}

{% case display_size %}
  {% when 'display' %}
    {% assign size_class = 'fs-display' %}
    {% assign family = family | default: 'heading' %}
  {% when 'h1' %}
    {% assign size_class = 'fs-h1' %}
    {% assign family = family | default: 'heading' %}
  {% when 'h2' %}
    {% assign size_class = 'fs-h2' %}
    {% assign family = family | default: 'heading' %}
  {% when 'h3' %}
    {% assign size_class = 'fs-h3' %}
    {% assign family = family | default: 'heading' %}
  {% when 'h4' %}
    {% assign size_class = 'fs-h4' %}
    {% assign family = family | default: 'heading' %}
  {% when 'h5' %}
    {% assign size_class = 'fs-h5' %}
    {% assign family = family | default: 'heading' %}
  {% when 'h6' %}
    {% assign size_class = 'fs-h6' %}
    {% assign family = family | default: 'heading' %}
  {% when 'body' %}
    {% assign size_class = 'text-base' %}
    {% assign family = family | default: 'body' %}
  {% when 'caption' %}
    {% assign size_class = 'text-xs' %}
    {% assign family = family | default: 'body' %}
  {% when 'small' %}
    {% assign size_class = 'text-sm' %}
    {% assign family = family | default: 'body' %}
  {% when 'jumbo' %}
    {% assign size_class = 'fs-jumbo' %}
    {% assign family = family | default: 'heading' %}
{% endcase %}

{% comment %} --- Class Array Building --- {% endcomment %}
{% assign classes = blank | push: size_class %}

{% if family != blank %}
  {% assign family_class = 'font-' | append: family %}
  {% assign classes = classes | push: family_class %}
{% endif %}

{% case weight %}
  {% when 'normal' -%}
    {%- assign classes = classes | push: 'font-normal' %}
  {% when 'medium' -%}
    {%- assign classes = classes | push: 'font-medium' %}
  {% when 'bold' -%}
    {%- assign classes = classes | push: 'font-bold' %}
  {% when 'extrabold' -%}
    {%- assign classes = classes | push: 'font-extrabold' %}
  {% when 'black' -%}
    {%- assign classes = classes | push: 'font-black' %}
{% endcase %}

{% case tracking %}
  {% when 'tighter' -%}
    {%- assign classes = classes | push: 'tracking-tighter' %}
  {% when 'tight' -%}
    {%- assign classes = classes | push: 'tracking-tight' %}
  {% when 'wide' -%}
    {%- assign classes = classes | push: 'tracking-wide' %}
  {% when 'wider' -%}
    {%- assign classes = classes | push: 'tracking-wider' %}
  {% when 'widest' -%}
    {%- assign classes = classes | push: 'tracking-widest' %}
  {% when 'custom' -%}
    {%- assign classes = classes | push: 'tracking-custom' %}
  {% else -%}
    {%- assign classes = classes | push: 'tracking-normal' %}
{% endcase %}

{% case leading %}
  {% when 'none' -%}
    {%- assign classes = classes | push: 'leading-none' %}
  {% when 'tight' -%}
    {%- assign classes = classes | push: 'leading-tight' %}
  {% when 'snug' -%}
    {%- assign classes = classes | push: 'leading-snug' %}
  {% when 'relaxed' -%}
    {%- assign classes = classes | push: 'leading-relaxed' %}
  {% when 'loose' -%}
    {%- assign classes = classes | push: 'leading-loose' %}
  {% when 'custom' -%}
    {%- assign classes = classes | push: 'leading-custom' %}
  {% else -%}
    {%- assign classes = classes | push: 'leading-normal' %}
{% endcase %}

{% case color_role %}
  {% when 'secondary' -%}
    {%- assign classes = classes | push: 'text-secondary' %}
  {% when 'subtle' -%}
    {%- assign classes = classes | push: 'text-subtle' %}
  {% when 'accent' -%}
    {%- assign classes = classes | push: 'text-accent' %}
  {% when 'button' -%}
    {%- assign classes = classes | push: 'text-button' %}
  {% when 'control' -%}
    {%- assign classes = classes | push: 'text-control' %}
  {% else -%}
    {%- assign classes = classes | push: 'text-body' %}
{% endcase %}

{% if class != blank %}
  {% assign classes = classes | push: class %}
{% endif %}

{% assign block_classes = classes | join: ' ' %}

{% comment %} --- Component Render --- {% endcomment %}
<{{ tag_el }} class="{{ block_classes }}">
  {{ text }}
</{{ tag_el }}>
