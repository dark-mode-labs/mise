<style>
    {% capture stylesheet %}
    :root {
      --space-base: 1rem;
      --space-xs: 0.5rem;
      --space-sm: 1rem;
      --space-md: 1.5rem;

      --space-lg: clamp(2rem, 4vw, 2.5rem);
      --space-xl: clamp(2.5rem, 5vw, 4rem);
      --space-2xl: clamp(3.5rem, 7vw, 6rem);
      --space-3xl: clamp(4.5rem, 9vw, 8rem);

      --type-scale: {{ typography.type_scale | divided_by: 100.0 }};
      --radius-global: {{ layout.corner_radius }}px;

      {% for scheme in font_schemes %} --font-{{ scheme[0] }}: "{{ scheme[1].settings.name }}", sans-serif; {% endfor %}

      {% comment %}
        --- Brand palette tokens ---
        Each entry in the palette group emits a single CSS custom property at
        :root. Slot values inside surfaces reference these via @palette-id
        which the surface block below resolves to var(--palette-X).
      {% endcomment %}
      {% for token in palette %} --palette-{{ token[0] }}: {{ token[1].settings.value }}; {% endfor %}
    }

    {% comment %}
      --- Surfaces ---
      Each surface emits TWO variables per bg-family slot:
        --<slot>          (solid color, or `transparent` if the slot value is a gradient)
        --<slot>-image    (gradient `linear-gradient(...)`, or `none` if the slot value is solid)
      This split exists because `color-mix(in srgb, gradient, ...)` is invalid
      at computed-value-time — IACVT skips cascade fallback and the property
      goes to its initial value (transparent). Splitting solid vs image into
      two properties means both stay valid for any input.

      Slot values may be:
        @palette-id     → resolves to var(--palette-id)
        #aabbcc         → solid hex
        rgba(...)       → solid rgba
        linear-gradient → gradient image
        radial-gradient → gradient image
        ""              → unset (defaults to transparent / none)
    {% endcomment %}

    {% for surface in surfaces %}
      {%- assign s = surface[1].settings -%}
      .surface-{{ surface[0] }} {
        {%- comment -%} bg-family slots (each emits color + image vars) {%- endcomment -%}
         {% assign pairs = 'background|background_alt|surface|surface_alt|accent_bg|button_bg|control_bg' | split: '|' %}
        {%- for pair in pairs -%}
          {%- assign slot_id = pair -%}
          {%- assign slot_val = s[slot_id] | default: '' -%}
          {%- assign css_var = '--' | append: slot_id | replace: '_', '-' -%}
          {%- assign img_var = css_var | append: '-image' -%}
          {% assign first_slot_char = slot_val | slice: 0, 1 %}
          {%- if slot_val == blank -%}
            {{ css_var }}: transparent; {{ img_var }}: none;
          {%- elsif slot_val contains 'gradient' -%}
            {{ css_var }}: transparent; {{ img_var }}: {{ slot_val }};
          {%- elsif first_slot_char == '@' -%}
            {%- assign ref = slot_val | remove_first: '@' -%}
            {{ css_var }}: var(--palette-{{ ref }}); {{ img_var }}: none;
          {%- else -%}
            {{ css_var }}: {{ slot_val }}; {{ img_var }}: none;
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} text + border + shadow slots (single var each) {%- endcomment -%}
         {% assign child_pairs = 'text|text_secondary|text_subtle|text_emphasis|text_on_accent|text_on_button|text_on_control|border|border_emphasis|shadow' | split: '|' %}
        {%- for pair in child_pairs -%}
          {%- assign slot_id = pair -%}
          {%- assign slot_val = s[slot_id] | default: '' -%}
          {%- assign css_var = '--' | append: slot_id | replace: '_', '-' -%}
          {% assign first_slot_char = slot_val | slice: 0, 1 %}
          {%- if slot_val == blank -%}
            {{ css_var }}: transparent;
          {%- elsif first_slot_char == '@' -%}
            {%- assign ref = slot_val | remove_first: '@' -%}
            {{ css_var }}: var(--palette-{{ ref }});
          {%- else -%}
            {{ css_var }}: {{ slot_val }};
          {%- endif -%}
        {%- endfor -%}
      }
    {% endfor %}

    {% for scheme in width_schemes %}
      {% assign width = scheme[1].settings.width %}
      {% capture width_scheme %}
        {% case width %}
          {% when 'sm' %}
            --limit-width: 24rem;
          {% when 'md' %}
            --limit-width: 28rem;
          {% when 'lg' %}
            --limit-width: 32rem;
          {% when 'xl' %}
            --limit-width: 36rem;
          {% when '2xl' %}
            --limit-width: 42rem;
          {% when '3xl' %}
            --limit-width: 48rem;
          {% when '4xl' %}
            --limit-width: 56rem;
          {% when '5xl' %}
            --limit-width: 64rem;
          {% when '6xl' %}
            --limit-width: 72rem;
          {% when '7xl' %}
            --limit-width: 80rem;
          {% when 'fit' %}
            --limit-width: fit-content;
          {% when 'full' %}
            --limit-width: 100%;
          {% when 'half' %}
            --limit-width: 50%;
            flex: 0 0 50%;
          {% when 'third' %}
            --limit-width: 33.333%;
            flex: 0 0 33.333%;
          {% when 'custom' %}
            --limit-width: {{ scheme[1].settings.custom_width }}rem;
          {% when 'auto' %}
            --limit-width: auto;
          {% else %}
            --limit-width: {{ width }};
        {% endcase %}
      {% endcapture %}
      .width-{{ scheme[0] }} { {{ width_scheme }} }

      {% if width == 'half' or width == 'third' %}
        @media (max-width: 767px) {
          .width-{{ scheme[0] }} {
            --limit-width: 100%;
          }
        }
      {% endif %}

      {% if width == 'fit' %}
        @media (max-width: 767px) {
          .direction-responsive > .width-fit {
            --limit-width: 100%;
          }
        }
      {% endif %}
    {% endfor %}

    .font-heading { font-family: var(--font-{{ typography.heading_font_scheme }}); }
    .font-body    { font-family: var(--font-{{ typography.body_font_scheme }}); }
    .font-button  { font-family: var(--font-{{ typography.button_font_scheme }}); }
  {% endcapture %}
  {{ stylesheet | strip_newlines }}
</style>
