<style>
    {% capture stylesheet %}
    :root {
      --space-base: 1rem;
      --space-xs: 0.5rem;
      --space-sm: 1rem;
      --space-md: 1.5rem;

      --space-lg: clamp(2rem, 4vw, 2.5rem);
      --space-xl: clamp(2.5rem, 5vw, 4rem);
      --space-2xl: clamp(3.5rem, 7vw, 6rem);
      --space-3xl: clamp(4.5rem, 9vw, 8rem);

      --type-scale: {{ typography.type_scale | divided_by: 100.0 }};
      --radius-global: {{ layout.corner_radius }}px;

      {% for scheme in font_schemes %} --font-{{ scheme[0] }}: "{{ scheme[1].settings.name }}", sans-serif; {% endfor %}
    }

    {% for scheme in color_schemes %}
      {%- assign s_bg = scheme[1].settings.background -%}
      {%- assign s_surface = scheme[1].settings.surface -%}
      {%- assign s_accent = scheme[1].settings.accent -%}
      {%- assign s_btn_bg = scheme[1].settings.button_bg -%}
      {%- assign s_ui_bg = scheme[1].settings.ui_bg -%}
      {%- comment -%}
        For each bg-painting slot we emit TWO variables: a solid color (used by
        background-color via color-mix for runtime alpha control) and a
        gradient-or-none image (painted via background-image). When the scheme
        slot is a gradient, the color side becomes `transparent` (so color-mix
        is valid and the alpha control is a no-op) and the image side carries
        the gradient. Solids do the inverse.
      {%- endcomment -%}
      .color-{{ scheme[0] }} {
        {%- if s_bg contains 'gradient' -%}
          --color-bg: transparent;
          --color-bg-image: {{ s_bg }};
        {%- else -%}
          --color-bg: {{ s_bg }};
          --color-bg-image: none;
        {%- endif %}
        --color-text: {{ scheme[1].settings.text }};
        --color-text-secondary: {{ scheme[1].settings.text_secondary }};
        {%- if s_accent contains 'gradient' -%}
          --color-accent: transparent;
          --color-accent-image: {{ s_accent }};
        {%- else -%}
          --color-accent: {{ s_accent }};
          --color-accent-image: none;
        {%- endif %}
        {%- if s_surface contains 'gradient' -%}
          --color-surface: transparent;
          --color-surface-image: {{ s_surface }};
        {%- else -%}
          --color-surface: {{ s_surface }};
          --color-surface-image: none;
        {%- endif %}
        {%- if s_btn_bg contains 'gradient' -%}
          --color-btn-bg: transparent;
          --color-btn-bg-image: {{ s_btn_bg }};
        {%- else -%}
          --color-btn-bg: {{ s_btn_bg }};
          --color-btn-bg-image: none;
        {%- endif %}
        --color-btn-text: {{ scheme[1].settings.button_text }};
        --color-border: {{ scheme[1].settings.border }};
        --color-shadow: {{ scheme[1].settings.shadow }};
        {%- if s_ui_bg contains 'gradient' -%}
          --color-ui-bg: transparent;
          --color-ui-bg-image: {{ s_ui_bg }};
        {%- else -%}
          --color-ui-bg: {{ s_ui_bg }};
          --color-ui-bg-image: none;
        {%- endif %}
        --color-ui-text: {{ scheme[1].settings.ui_text }};
        --color-text-subtle: {{ scheme[1].settings.text_subtle }};
      }
    {% endfor %}

    {% for scheme in width_schemes %}
      {% assign width = scheme[1].settings.width %}
      {% capture width_scheme %}
        {% case width %}
          {% when 'sm' %}
            --limit-width: 24rem;
          {% when 'md' %}
            --limit-width: 28rem;
          {% when 'lg' %}
            --limit-width: 32rem;
          {% when 'xl' %}
            --limit-width: 36rem;
          {% when '2xl' %}
            --limit-width: 42rem;
          {% when '3xl' %}
            --limit-width: 48rem;
          {% when '4xl' %}
            --limit-width: 56rem;
          {% when '5xl' %}
            --limit-width: 64rem;
          {% when '6xl' %}
            --limit-width: 72rem;
          {% when '7xl' %}
            --limit-width: 80rem;
          {% when 'fit' %}
            --limit-width: fit-content;
          {% when 'full' %}
            --limit-width: 100%;
          {% when 'half' %}
            --limit-width: 50%;
            flex: 0 0 50%;
          {% when 'third' %}
            --limit-width: 33.333%;
            flex: 0 0 33.333%;
          {% when 'custom' %}
            --limit-width: {{ scheme[1].settings.custom_width }}rem;
          {% when 'auto' %}
            --limit-width: auto;
          {% else %}
            --limit-width: {{ width }};
        {% endcase %}
      {% endcapture %}
      .width-{{ scheme[0] }} { {{ width_scheme }} }

      {% if width == 'half' or width == 'third' %}
        @media (max-width: 767px) {
          .width-{{ scheme[0] }} {
            --limit-width: 100%;
          }
        }
      {% endif %}

      {% if width == 'fit' %}
        @media (max-width: 767px) {
          .direction-responsive > .width-fit {
            --limit-width: 100%;
          }
        }
      {% endif %}
    {% endfor %}

    .font-heading { font-family: var(--font-{{ typography.heading_font_scheme }}); }
    .font-body    { font-family: var(--font-{{ typography.body_font_scheme }}); }
    .font-button  { font-family: var(--font-{{ typography.button_font_scheme }}); }
  {% endcapture %}
  {{ stylesheet | strip_newlines }}
</style>
