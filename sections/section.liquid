{% assign s = section.settings %}

{% assign bg_color_value = blank %}
{% if s.bg_role == 'palette' and s.bg_role_palette != blank %}
  {% assign bg_color_value = 'var(--palette-{{ s.bg_role_palette }})' %}
{% elsif s.bg_role == 'custom' and s.bg_role_custom != blank %}
  {% assign bg_color_value = s.bg_role_custom %}
{% endif %}

{% comment %}
  --- 1. Surface scoping (CSS-var context) ---
  Sections always introduce a surface scope (they're the natural surface
  boundary in the layout tree). Defaults to `default` so descendants always
  inherit a usable set of CSS variables.
{% endcomment %}
{% assign surface_safe = s.surface_id | default: 'default' %}
{% assign surface_class = 'surface-' | append: surface_safe %}

{% comment %} --- 2. Background role (paints from active surface) --- {% endcomment %}
{% assign bg_role_safe = s.bg_role | default: 'body' %}
{% assign bg_class = '' %}
{% if bg_color_value == blank and bg_role_safe != 'none' %}
  {% assign bg_class = 'bg-' | append: bg_role_safe %}
{% endif %}

{% comment %} --- 3. Container Class Pipeline --- {% endcomment %}
{% assign container_classes = 'section-layout limit-width'
  | push: bg_class
  | push: 'width-{{ s.width }}'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
  | push: 'is-{{ s.height }}'
%}
{% assign container_class_str = container_classes | join: ' ' %}

{% comment %} --- 4. Style Pipeline (spacing + bg layer) --- {% endcomment %}
{% assign styles = blank %}

{% if s.padding_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}

{% if s.padding_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}

{% if s.height == 'custom' %}
  {% assign styles = styles | push: '--max-h: {{ s.height_custom }}vh' %}
{% endif %}

{% if bg_color_value != blank %}
  {% assign styles = styles | push: 'background: {{ bg_color_value }}' %}
{% endif %}
{% assign style_str = styles | join: ';' %}

{% comment %} --- 5. Inner Flex Pipeline --- {% endcomment %}
{% assign inner_classes = 'flex flex-auto gap-6'
  | push: 'flex-{{ s.flex_direction }}'
  | push: 'section-align-content-{{ s.content_align }}'
  | push: 'section-align-v-{{ s.vertical_align }}'
  | push: 'section-align-text-{{ s.text_align }}'
  | push_if: 'stagger-load', s.animate_stagger
%}
{% assign inner_class_str = inner_classes | join: ' ' %}

{% comment %} --- Component Render --- {% endcomment %}
<section
  class="{{ surface_class }}"
  {{ context.attached_attributes }}
>
  <div
    class="{{ container_class_str }}"
    style="{{ style_str }}"
  >
    <div class="{{ inner_class_str }}">
      {% content_for 'blocks' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Generic section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "width",
      "id": "width",
      "label": "Max Content Width",
      "default": "fill"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section Height",
      "options": [
        {
          "value": "auto",
          "label": "Auto (Fit Content)"
        },
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "lg",
          "label": "Large"
        },
        {
          "value": "xl",
          "label": "Fullscreen"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "height_custom",
      "label": "Custom Height",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 56,
      "unit": "vh",
      "conditional": "setting.height == 'custom'"
    },
    {
      "type": "select",
      "id": "flex_direction",
      "label": "Flex Direction",
      "options": [
        {
          "value": "col",
          "label": "Column"
        },
        {
          "value": "row",
          "label": "Row"
        }
      ],
      "default": "col"
    },
    {
      "type": "header",
      "content": "Alignment"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_align",
      "label": "Vertical Alignment",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "middle",
          "label": "Middle"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "middle"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "xs",
          "label": "Extra Small"
        },
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "lg",
          "label": "Large"
        },
        {
          "value": "xl",
          "label": "Extra Large"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "xs",
          "label": "Extra Small"
        },
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "lg",
          "label": "Large"
        },
        {
          "value": "xl",
          "label": "Extra Large"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "xs"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "checkbox",
      "id": "animate_stagger",
      "label": "Stagger",
      "default": false
    },
    {
      "type": "header",
      "content": "Theme"
    },
    {
      "type": "checkbox",
      "id": "surface_override",
      "label": "Override surface",
      "default": false,
      "info": "When enabled, this section introduces its own surface scope. Otherwise descendants inherit the surface from the parent (page default unless a surrounding section overrode it)."
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Surface",
      "default": "default",
      "conditional": "setting.surface_override == true"
    },
    {
      "type": "select",
      "id": "bg_role",
      "label": "Background",
      "default": "body",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "body",
          "label": "Body"
        },
        {
          "value": "body-alt",
          "label": "Body (alt)"
        },
        {
          "value": "surface",
          "label": "Surface"
        },
        {
          "value": "surface-alt",
          "label": "Surface (alt)"
        },
        {
          "value": "accent",
          "label": "Accent"
        },
        {
          "value": "button",
          "label": "Button"
        },
        {
          "value": "control",
          "label": "Control"
        },
        {
          "value": "palette",
          "label": "Base Palette"
        },
        {
          "value": "custom",
          "label": "Raw Color"
        }
      ]
    },
    {
      "type": "palette",
      "id": "bg_role_palette",
      "label": "Background Palette Token",
      "info": "Picks a named brand-palette token. Updates follow palette edits.",
      "default": "brand",
      "conditional": "setting.bg_role == 'palette'"
    },
    {
      "type": "color",
      "id": "bg_role_custom",
      "label": "Raw Background",
      "conditional": "setting.bg_role == 'custom'"
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "scroll-indicator"
    },
    {
      "type": "text"
    },
    {
      "type": "spacer"
    },
    {
      "type": "_marquee"
    },
    {
      "type": "media"
    },
    {
      "type": "group"
    },
    {
      "type": "button"
    }
  ],
  "presets": [
    {
      "name": "Rich Text",
      "settings": {
        "text_align": "text-center items-center"
      },
      "blocks": {
        "heading": {
          "type": "text",
          "settings": {
            "content": "Our Story",
            "display_size": "h2",
            "tag": "h2",
            "font_weight": "bold"
          }
        },
        "body": {
          "type": "text",
          "settings": {
            "content": "Founded in 2025, we believe in honest ingredients and good vibes.",
            "display_size": "body"
          }
        },
        "btn": {
          "type": "button",
          "settings": {
            "label": "Learn More",
            "style": "link"
          }
        }
      },
      "block_order": [
        "heading",
        "body",
        "btn"
      ]
    }
  ]
}
{% endschema %}
