{% assign s = section.settings %}

{% assign bg_color_value = blank %}
{% if s.bg_role == 'palette' and s.bg_role_palette != blank %}
  {% assign bg_color_value = 'var(--palette-{{ s.bg_role_palette }})' %}
{% elsif s.bg_role == 'gradient' and s.bg_role_gradient != blank %}
  {% assign bg_color_value = 'var(--gradient-{{ s.bg_role_gradient }})' %}
{% elsif s.bg_role == 'custom' and s.bg_role_custom != blank %}
  {% assign bg_color_value = s.bg_role_custom %}
{% endif %}

{% comment %} --- Background class + styles (unified bg primitive) --- {% endcomment %}
{% assign bg_role_safe = s.bg_role | default: 'body' %}
{% assign bg_class = 'bg-' | append: bg_role_safe %}
{% if bg_color_value != blank %}{% assign bg_class = '' %}{% endif %}

{% assign styles = blank %}
{% if bg_color_value != blank %}
  {% assign styles = styles | push: 'background: {{ bg_color_value }}' %}
{% endif %}
{% assign style_str = styles | join: ';' %}

<section
  class='section-slideshow surface-{{ s.surface_id | default: 'default' }} {{ bg_class }} height-{{ s.height }}'
  style='{{ style_str }}'
  {{ context.attached_attributes }}
>
  <div
    class='relative width-{{ s.width }} limit-width  group select-none h-full'
    data-behavior='slideshow'
    data-autoplay='{{ s.autoplay }}'
    data-speed='{{ s.autoplay_speed }}'
    data-infinite='{{ s.infinite_scroll }}'
    style='
      --slide-width: {{ s.slide_width_mobile }}%;
      --slide-width-md: {{ s.slide_width }}%;
      --slide-gap: {{ s.slide_gap }}rem;
    '
  >
    <div class='slideshow-track flex h-full overflow-x-auto snap-x snap-mandatory scroll-smooth scrollbar-hide cursor-grab active:cursor-grabbing gap-[var(--slide-gap)]'>
      {% content_for 'blocks' %}
    </div>

    {% if s.show_arrows %}
      {% assign arrow_pos_class = 'absolute top-1/2 -translate-y-1/2 z-floating px-4 w-full flex justify-between pointer-events-none' %}
      {% if s.nav_position == 'bottom_right' %}
        {% assign arrow_pos_class = 'absolute bottom-8 right-8 z-floating flex gap-2' %}
      {% endif %}

      <div class='slideshow-nav {{ arrow_pos_class }}' style='display: none'>
        <button
          type='button'
          class='slideshow-prev pointer-events-auto p-3 rounded-full btn-nav'
          aria-label='Previous'
        >
          {% render 'icon', name: s.arrow_icon, class: 'w-5 h-5' %}
        </button>

        <button type='button' class='slideshow-next pointer-events-auto p-3 rounded-full btn-nav' aria-label='Next'>
          {% assign icon_name = s.arrow_icon | replace: '-left', '-right' %}
          {% render 'icon', name: icon_name, class: 'w-5 h-5' %}
        </button>
      </div>
    {% endif %}

    {% if s.show_dots %}
      {% assign nav_pos_class = 'absolute bottom-6 left-1/2 -translate-x-1/2' %}
      {% if s.nav_position == 'bottom_left' %} {% assign nav_pos_class = 'absolute bottom-8 left-8' %} {% endif %}
      {% if s.nav_position == 'bottom_right' %} {% assign nav_pos_class = 'absolute bottom-8 right-8' %} {% endif %}

      <div
        class='slideshow-dots {{ nav_pos_class }} z-floating flex items-center gap-3'
        data-dot-style='{{ s.dot_style }}'
        style='display: none'
      ></div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Slideshow",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "width",
      "id": "width",
      "label": "Max Content Width",
      "default": "fill"
    },
    {
      "type": "height",
      "id": "height",
      "label": "Image Height",
      "default": "feature"
    },
    {
      "type": "range",
      "id": "slide_gap",
      "label": "Gap between slides",
      "min": 0,
      "max": 2.5,
      "step": 0.125,
      "default": 0,
      "unit": "rem"
    },
    {
      "type": "header",
      "content": "Peeking / Sizing"
    },
    {
      "type": "range",
      "id": "slide_width",
      "label": "Slide Width (Desktop)",
      "min": 80,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "%",
      "info": "Set to < 100% to show part of the next slide."
    },
    {
      "type": "range",
      "id": "slide_width_mobile",
      "label": "Slide Width (Mobile)",
      "min": 80,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Controls"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Pagination",
      "default": true
    },
    {
      "type": "select",
      "id": "dot_style",
      "label": "Pagination Style",
      "options": [
        {
          "value": "dots",
          "label": "Dots"
        },
        {
          "value": "bars",
          "label": "Bars"
        },
        {
          "value": "numbers",
          "label": "Numbers"
        }
      ],
      "default": "dots",
      "conditional": "setting.show_dots"
    },
    {
      "type": "select",
      "id": "arrow_icon",
      "label": "Arrow Style",
      "options": [
        {
          "value": "chevron-left",
          "label": "Chevron"
        },
        {
          "value": "arrow-left",
          "label": "Arrow"
        }
      ],
      "default": "chevron-left",
      "conditional": "setting.show_arrows",
      "info": "Controls are middle sides."
    },
    {
      "type": "select",
      "id": "nav_position",
      "label": "Controls Position",
      "options": [
        {
          "value": "bottom_center",
          "label": "Bottom Center"
        },
        {
          "value": "bottom_left",
          "label": "Bottom Left"
        },
        {
          "value": "bottom_right",
          "label": "Bottom Right"
        }
      ],
      "default": "bottom_center",
      "conditional": "setting.show_dots"
    },
    {
      "type": "header",
      "content": "Theme"
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Color Scheme",
      "default": "default",
      "info": "Controls the color of arrows and dots."
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "checkbox",
      "id": "infinite_scroll",
      "label": "Infinite Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Speed (seconds)",
      "min": 3,
      "max": 10,
      "default": 5,
      "conditional": "setting.autoplay == true"
    },
    {
      "type": "select",
      "id": "bg_role",
      "label": "Background",
      "default": "body",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "body",
          "label": "Body"
        },
        {
          "value": "body-alt",
          "label": "Body (alt)"
        },
        {
          "value": "surface",
          "label": "Surface"
        },
        {
          "value": "surface-alt",
          "label": "Surface (alt)"
        },
        {
          "value": "accent",
          "label": "Accent"
        },
        {
          "value": "button",
          "label": "Button"
        },
        {
          "value": "control",
          "label": "Control"
        },
        {
          "value": "palette",
          "label": "Base Palette"
        },
        {
          "value": "custom",
          "label": "Raw Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        }
      ]
    },
    {
      "type": "palette",
      "id": "bg_role_palette",
      "label": "Background Palette Token",
      "default": "brand",
      "conditional": "setting.bg_role == 'palette'"
    },
    {
      "type": "color",
      "id": "bg_role_custom",
      "label": "Raw Background",
      "conditional": "setting.bg_role == 'custom'"
    },
    {
      "type": "gradient",
      "id": "bg_role_gradient",
      "label": "Background Gradient",
      "conditional": "setting.bg_role == 'gradient'"
    }
  ],
  "blocks": [
    {
      "type": "_slide"
    }
  ],
  "presets": [
    {
      "name": "Slideshow (Gallery)",
      "settings": {
        "height": "viewport-mid",
        "show_arrows": true,
        "show_dots": true
      },
      "blocks": {
        "slide_1": {
          "type": "_slide",
          "blocks": {
            "heading": {
              "type": "text",
              "settings": {
                "content": "Welcome",
                "tag": "h1",
                "type_style": "display-1"
              }
            },
            "btn": {
              "type": "button",
              "settings": {
                "label": "View Menu",
                "style": "primary"
              }
            }
          },
          "block_order": ["heading", "btn"]
        }
      },
      "block_order": ["slide_1"]
    }
  ]
}
{% endschema %}
