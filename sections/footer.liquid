{% assign s = section.settings %}

{% comment %} --- Section Container Classes --- {% endcomment %}
{% assign container_classes = 'width-{{ s.width_scheme }} limit-width'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
%}

{% assign container_class_str = container_classes | join: ' ' %}

{% comment %} --- Section Spacing Styles --- {% endcomment %}
{% assign spacing_styles = blank %}

{% if s.padding_vertical == 'custom' %}
  {% assign spacing_styles = spacing_styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}px'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}px'
  %}
{% endif %}

{% if s.padding_horizontal == 'custom' %}
  {% assign spacing_styles = spacing_styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}px'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}px'
  %}
{% endif %}

{% assign spacing_style_str = spacing_styles | join: ';' %}

{% comment %} --- Background class + styles (unified bg primitive) --- {% endcomment %}
{% assign bg_role_safe = s.bg_role | default: 'body' %}
{% assign bg_class = 'bg-' | append: bg_role_safe %}
{% if s.bg_color_override and s.bg_color != blank %}{% assign bg_class = '' %}{% endif %}

{% assign styles = blank %}
{% if s.bg_color_override and s.bg_color != blank %}
  {% assign styles = styles | push: 'background: {{ s.bg_color }}' %}
{% elsif s.bg_alpha and s.bg_alpha != 100 %}
  {% assign styles = styles | push: '--bg-alpha: {{ s.bg_alpha | divided_by: 100.0 }}' %}
{% endif %}
{% assign style_str = styles | join: ';' %}

{% comment %} --- Component Render --- {% endcomment %}
<footer
  class="section-footer color-{{ s.color_scheme | default: 'none' }} {{ bg_class }} text-body relative isolate"
  style="{{ style_str }}"
  {{ context.attached_attributes }}
>
  {% render 'bg-overlay',
       role: s.overlay_role,
       alpha: s.overlay_alpha,
       use_custom: s.overlay_color_override,
       custom_color: s.overlay_color,
       behind: true
  %}
  <div
    class="{{ container_class_str }} relative"
    style="{{ spacing_style_str }}"
  >
    <div class="flex flex-auto flex-col md:flex-row justify-content-{{ s.justify_content }}">
      {% content_for 'blocks' %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "restriction": { "groups": ["footer"] },
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "justify_content",
      "label": "Alignment",
      "options": [
        { "value": "start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "end", "label": "Right" },
        { "value": "between", "label": "Space Between" }
      ],
      "default": "center"
    },
    {
      "type": "width_scheme",
      "id": "width_scheme",
      "label": "Content Width",
      "default": "standard"
    },
    { "type": "header", "content": "Section Spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "Extra Small" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "sm"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 128,
      "step": 4,
      "default": 0,
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 128,
      "step": 4,
      "default": 0,
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "Extra Small" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "xs"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 128,
      "step": 4,
      "default": 0,
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 128,
      "step": 4,
      "default": 0,
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    { "type": "header", "content": "Bottom Bar" },
    { "type": "textarea", "id": "copyright_text", "label": "Copyright Text", "default": "{{ shop.name }}" },
    { "type": "checkbox", "id": "show_policy", "label": "Show Policy Links", "default": true },
    { "type": "checkbox", "id": "show_payment", "label": "Show Payment Icons", "default": true },

    { "type": "header", "content": "Theme" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "default" },
    {
      "type": "select",
      "id": "bg_role",
      "label": "Background",
      "default": "body",
      "options": [
        { "value": "none",    "label": "None" },
        { "value": "body",    "label": "Body" },
        { "value": "surface", "label": "Surface" },
        { "value": "accent",  "label": "Accent" },
        { "value": "button",  "label": "Button" },
        { "value": "nav",     "label": "Control" }
      ]
    },
    {
      "type": "range",
      "id": "bg_alpha",
      "label": "Background Opacity",
      "min": 0, "max": 100, "step": 5, "default": 100, "unit": "%",
      "conditional": "setting.bg_role != 'none'"
    },
    {
      "type": "checkbox",
      "id": "bg_color_override",
      "label": "Custom Background (free hex/gradient)",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Custom Background Color",
      "conditional": "setting.bg_color_override"
    },
    {
      "type": "select",
      "id": "overlay_role",
      "label": "Overlay",
      "default": "none",
      "options": [
        { "value": "none",    "label": "None" },
        { "value": "body",    "label": "Body" },
        { "value": "surface", "label": "Surface" },
        { "value": "accent",  "label": "Accent" },
        { "value": "button",  "label": "Button" },
        { "value": "nav",     "label": "Control" }
      ]
    },
    {
      "type": "range",
      "id": "overlay_alpha",
      "label": "Overlay Opacity",
      "min": 0, "max": 100, "step": 5, "default": 50, "unit": "%",
      "conditional": "setting.overlay_role != 'none' or setting.overlay_color_override"
    },
    {
      "type": "checkbox",
      "id": "overlay_color_override",
      "label": "Custom Overlay (free hex/gradient)",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Custom Overlay Color",
      "conditional": "setting.overlay_color_override"
    }
  ],
  "blocks": [{ "type": "group" }, { "type": "_footer-nav" }, { "type": "_footer-newsletter" }]
}
{% endschema %}
