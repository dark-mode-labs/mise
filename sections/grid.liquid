{% assign s = section.settings %}

{% assign bg_color_value = blank %}
{% if s.bg_role == 'palette' and s.bg_role_palette != blank %}
  {% assign bg_color_value = 'var(--palette-{{ s.bg_role_palette }})' %}
{% elsif s.bg_role == 'custom' and s.bg_role_custom != blank %}
  {% assign bg_color_value = s.bg_role_custom %}
{% endif %}
{% assign overlay_color_value = blank %}
{% if s.overlay_role == 'palette' and s.overlay_role_palette != blank %}
  {% assign overlay_color_value = 'var(--palette-{{ s.overlay_role_palette }})' %}
{% elsif s.overlay_role == 'custom' and s.overlay_role_custom != blank %}
  {% assign overlay_color_value = s.overlay_role_custom %}
{% endif %}

{% comment %} --- 1. Section Spacing & Dimensions --- {% endcomment %}
{% assign container_classes = 'grid-layout-overlay limit-width'
  | push: 'width-{{ s.width }}'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
  | push: 'is-{{ s.height }}'
%}

{% assign spacing_styles = blank %}
{% if s.padding_vertical == 'custom' %}
  {% assign spacing_styles = spacing_styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}
{% if s.padding_horizontal == 'custom' %}
  {% assign spacing_styles = spacing_styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}
{% if s.height == 'custom' %}
  {% assign spacing_styles = spacing_styles | push: '--max-h: {{ s.height_custom }}vh' %}
{% endif %}

{% assign container_class_str = container_classes | join: ' ' %}
{% assign spacing_style_str = spacing_styles | join: ';' %}

{% comment %} --- 2. Background class + styles (unified bg primitive) --- {% endcomment %}
{% assign bg_role_safe = s.bg_role | default: 'body' %}
{% assign bg_class = 'bg-' | append: bg_role_safe %}
{% if bg_color_value != blank %}{% assign bg_class = '' %}{% endif %}

{% assign styles = blank %}
{% if bg_color_value != blank %}
  {% assign styles = styles | push: 'background: {{ bg_color_value }}' %}
{% endif %}
{% assign style_str = styles | join: ';' %}

{% assign has_overlay = false %}
{% if s.overlay_role and s.overlay_role != 'none' %}{% assign has_overlay = true %}{% endif %}
{% if overlay_color_value != blank %}{% assign has_overlay = true %}{% endif %}

{% comment %} --- 3. Flex Grid Logic --- {% endcomment %}
{% assign flex_classes = 'flex flex-wrap -mx-4'
  | push: 'justify-content-{{ s.justify_content }}'
  | push_if: 'stagger-load', s.animate_stagger
%}

{% assign flex_styles = blank %}
{% if s.card_padding == 'custom' %}
  {% assign flex_styles = flex_styles | push: 'row-gap: {{ s.card_padding_custom }}rem' %}
{% else %}
  {% assign flex_styles = flex_styles | push: 'row-gap: var(--space-{{ s.card_padding }})' %}
{% endif %}

{% assign flex_class_str = flex_classes | join: ' ' %}
{% assign flex_style_str = flex_styles | join: ';' %}

{% comment %} --- Component Render --- {% endcomment %}
<section
  class="section-flex surface-{{ s.surface_id | default: 'default' }} {{ bg_class }}"
  style="{{ style_str }}"
  {{ context.attached_attributes }}
>
  {% comment %} Background Media / Overlay Layer {% endcomment %}
  {% if s.bg_image != blank or has_overlay %}
    <div
      class="grid-media-overlay width-{{ s.width_bg }} limit-width overflow-hidden"
      {% if s.bg_image != blank %}
        style="clip: rect(0, auto, auto, 0);"
      {% endif %}
    >
      <div class="grid-media-inner">
        {% if s.bg_image != blank %}
          {% render 'media',
            src: s.bg_image,
            src_mobile: s.bg_image_mobile,
            fit: 'cover',
            loading: 'lazy',
            curtain_reveal_parallax: s.enable_curtain_parallax
          %}
        {% endif %}

        {% render 'bg-overlay',
          role: s.overlay_role,
          alpha: s.overlay_alpha,
          palette_token: s.overlay_role_palette,
          custom_color: s.overlay_role_custom
        %}
      </div>
    </div>
  {% endif %}

  {% comment %} Content Layer {% endcomment %}
  <div
    class="{{ container_class_str }}"
    style="{{ spacing_style_str }}"
  >
    <div class="grid-content-overlay">
      <div
        class="{{ flex_class_str }}"
        style="{{ flex_style_str }}"
      >
        {% content_for 'blocks' %}
      </div>
    </div>
  </div>
</section>

