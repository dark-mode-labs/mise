{% assign s = section.settings %}

{% comment %} --- 1. Section Spacing & Dimensions --- {% endcomment %}
{% assign container_classes = 'grid-layout-overlay limit-width'
  | push: 'width-{{ s.width_scheme }}'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
  | push: 'is-{{ s.height }}'
%}

{% assign spacing_styles = blank %}
{% if s.padding_vertical == 'custom' %}
  {% assign spacing_styles = spacing_styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}
{% if s.padding_horizontal == 'custom' %}
  {% assign spacing_styles = spacing_styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}
{% if s.height == 'custom' %}
  {% assign spacing_styles = spacing_styles | push: '--max-h: {{ s.height_custom }}vh' %}
{% endif %}

{% assign container_class_str = container_classes | join: ' ' %}
{% assign spacing_style_str = spacing_styles | join: ';' %}

{% comment %} --- 2. Overlay & Background Logic --- {% endcomment %}
{% assign overlay_styles = blank %}
{% if s.enable_overlay and s.overlay_color != blank %}
  {% assign overlay_styles = overlay_styles
    | push: 'background: {{ s.overlay_color }}'
    | push: 'opacity: {{ s.overlay_opacity | divided_by: 100.0 }}'
  %}
{% endif %}

{% assign overlay_style_str = overlay_styles | join: ';' %}

{% comment %} --- 3. Flex Grid Logic --- {% endcomment %}
{% assign flex_classes = 'flex flex-wrap -mx-4'
  | push: 'justify-content-{{ s.justify_content }}'
  | push_if: 'stagger-load', s.animate_stagger
%}

{% assign flex_styles = blank %}
{% if s.card_padding == 'custom' %}
  {% assign flex_styles = flex_styles | push: 'row-gap: {{ s.card_padding_custom }}rem' %}
{% else %}
  {% assign flex_styles = flex_styles | push: 'row-gap: var(--space-{{ s.card_padding }})' %}
{% endif %}

{% assign flex_class_str = flex_classes | join: ' ' %}
{% assign flex_style_str = flex_styles | join: ';' %}

{% comment %} --- Component Render --- {% endcomment %}
<section
  class="section-flex color-{{ s.color_scheme | default: 'none' }} bg-body"
  {{ context.attached_attributes }}
>
  {% comment %} Background Media / Overlay Layer {% endcomment %}
  {% if s.bg_image != blank or s.enable_overlay %}
    <div
      class="grid-media-overlay width-{{ s.width_bg }} limit-width overflow-hidden"
      {% if s.bg_image != blank %}
        style="clip: rect(0, auto, auto, 0);"
      {% endif %}
    >
      <div class="grid-media-inner">
        {% if s.bg_image != blank %}
          {% render 'media',
            src: s.bg_image,
            src_mobile: s.bg_image_mobile,
            fit: 'cover',
            loading: 'lazy',
            curtain_reveal_parallax: s.enable_curtain_parallax
          %}
        {% endif %}

        {% if s.enable_overlay and s.overlay_color != blank %}
          <div
            class="absolute inset-0 pointer-events-none"
            style="{{ overlay_style_str }}"
          ></div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% comment %} Content Layer {% endcomment %}
  <div
    class="{{ container_class_str }}"
    style="{{ spacing_style_str }}"
  >
    <div class="grid-content-overlay">
      <div
        class="{{ flex_class_str }}"
        style="{{ flex_style_str }}"
      >
        {% content_for 'blocks' %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Flex Container",
  "settings": [
    {
      "type": "header",
      "content": "Overlay Style"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "Use Overlay",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Tint / Background Color",
      "default": "",
      "conditional": "setting.enable_overlay == true"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacity",
      "min": 0,
      "max": 100,
      "default": 100,
      "conditional": "setting.enable_overlay == true"
    },
    { "type": "image_picker", "id": "bg_image", "label": "Background Image" },
    { "type": "image_picker", "id": "bg_image_mobile", "label": "Mobile Background" },
    {
      "type": "checkbox",
      "id": "enable_curtain_parallax",
      "label": "Curtain Reveal Parallax",
      "conditional": "setting.bg_image != blank"
    },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "justify_content",
      "label": "Alignment",
      "options": [
        { "value": "start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "end", "label": "Right" },
        { "value": "between", "label": "Space Between" }
      ],
      "default": "center"
    },
    {
      "type": "width_scheme",
      "id": "width_bg",
      "label": "Background Width",
      "default": "full"
    },
    {
      "type": "width_scheme",
      "id": "width_scheme",
      "label": "Content Width",
      "default": "standard"
    },

    { "type": "header", "content": "Spacing" },
    {
      "type": "select",
      "id": "height",
      "label": "Section Height",
      "options": [
        { "value": "auto", "label": "Auto (Fit Content)" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Fullscreen" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "height_custom",
      "label": "Custom Height",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "vh",
      "conditional": "setting.height == 'custom'"
    },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "Extra Small" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "Extra Small" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    { "type": "checkbox", "id": "animate_stagger", "label": "Stagger", "default": false },
    { "type": "header", "content": "Theme" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "default" },

    { "type": "header", "content": "Gap & Cards" },
    { "type": "checkbox", "id": "enable_cards_global", "label": "Enable Cards for All Columns", "default": false },
    {
      "type": "select",
      "id": "card_padding",
      "label": "Gap / Card Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "Extra Small" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none",
      "conditional": "setting.enable_cards_global == true"
    },
    {
      "type": "range",
      "id": "card_padding_custom",
      "label": "Custom Gap",
      "min": 0,
      "max": 6,
      "step": 0.25,
      "default": 1.5,
      "unit": "rem",
      "conditional": "setting.enable_cards_global == true and setting.card_padding == 'custom'"
    }
  ],
  "blocks": [{ "type": "group" }],
  "presets": [
    {
      "name": "Multi-Column",
      "settings": {},
      "blocks": {
        "group": {
          "type": "group",
          "blocks": {
            "grp_1": {
              "type": "group",
              "blocks": {
                "title": {
                  "type": "text",
                  "settings": {
                    "content": "Sourcing"
                  }
                }
              },
              "block_order": ["title"],
              "settings": {}
            },
            "grp_2": {
              "type": "group",
              "blocks": {
                "title": {
                  "type": "text",
                  "settings": {
                    "content": "Prep"
                  }
                }
              },
              "block_order": ["title"],
              "settings": {}
            },
            "grp_3": {
              "type": "group",
              "blocks": {
                "title": {
                  "type": "text",
                  "settings": {
                    "content": "Plating"
                  }
                }
              },
              "block_order": ["title"],
              "settings": {}
            }
          },
          "block_order": ["grp_1", "grp_2", "grp_3"],
          "settings": {
            "content_align": "center",
            "direction": "row"
          }
        }
      },
      "block_order": ["group"]
    }
  ]
}
{% endschema %}
