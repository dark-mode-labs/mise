{% assign s = section.settings %}

{% comment %} --- 1. Layout & Animation Logic --- {% endcomment %}
{% assign container_classes = 'width-{{ s.width_scheme }} limit-width overflow-hidden'
  | push: 'is-{{ s.height }}'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
%}

{% if s.desktop_layout == 'image_left' %}
  {% assign container_classes = container_classes | push: 'media-layout-left' %}
{% else %}
  {% assign container_classes = container_classes | push: 'media-layout-right' %}
{% endif %}

{% comment %} --- Background class (unified bg primitive) --- {% endcomment %}
{% assign bg_role_safe = s.bg_role | default: 'body' %}
{% assign bg_class = 'bg-' | append: bg_role_safe %}
{% if s.bg_role == 'custom' and s.bg_role_custom != blank %}{% assign bg_class = '' %}{% endif %}

{% assign content_classes = 'media-content-split gap-6 transition-all'
  | push: bg_class
  | push: 'section-align-content-{{ s.content_align }}'
  | push: 'section-align-v-{{ s.vertical_align }}'
  | push: 'section-align-text-{{ s.text_align }}'
  | push_if: 'stagger-load', s.animate_stagger
%}

{% if s.mobile_layout == 'text_first' %}
  {% assign content_classes = content_classes | push: 'order-first md:order-last' %}
{% endif %}

{% assign container_class_str = container_classes | join: ' ' %}
{% assign content_class_str = content_classes | join: ' ' %}

{% comment %} --- 2. Spacing Style Pipeline --- {% endcomment %}
{% assign spacing_styles = blank %}

{% if s.padding_vertical == 'custom' %}
  {% assign spacing_styles = spacing_styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}
{% if s.padding_horizontal == 'custom' %}
  {% assign spacing_styles = spacing_styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}
{% if s.height == 'custom' %}
  {% assign spacing_styles = spacing_styles | push: '--max-h: {{ s.height_custom }}vh' %}
{% endif %}

{% comment %} bg layer styles into the same list (unified bg primitive) {% endcomment %}
{% if s.bg_role == 'custom' and s.bg_role_custom != blank %}
  {% assign spacing_styles = spacing_styles | push: 'background: {{ s.bg_role_custom }}' %}
{% endif %}

{% assign spacing_style_str = spacing_styles | join: ';' %}

{% assign placeholder_name = '' %}
{% if s.show_placeholder %}{% assign placeholder_name = 'scene-2' %}{% endif %}

{% comment %} --- Component Render --- {% endcomment %}
<section
  class="section-feature surface-{{ s.surface_id | default: 'default' }}"
  {{ context.attached_attributes }}
>
  <div
    class="{{ container_class_str }}"
    style="{{ spacing_style_str }}"
  >
    <div class="media-media-split">
      {% render 'media',
        src: s.image,
        src_mobile: s.mobile_image,
        video: s.video_url,
        fit: 'cover',
        placeholder: placeholder_name,
        animate: s.enable_zoom
      %}
    </div>

    <div class="{{ content_class_str }}">
      {% content_for 'blocks' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Media with content",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "width_scheme",
      "id": "width_scheme",
      "label": "Max Content Width",
      "default": "standard"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Image Height",
      "options": [
        { "value": "auto", "label": "Auto (Fit Content)" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Fullscreen" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "height_custom",
      "label": "Custom Height",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 56,
      "unit": "vh",
      "conditional": "setting.height == 'custom'"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Desktop Stacking",
      "options": [
        { "value": "image_left", "label": "Media Left" },
        { "value": "image_right", "label": "Media Right" }
      ],
      "default": "image_left"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile Stacking",
      "options": [
        { "value": "image_first", "label": "Media First" },
        { "value": "text_first", "label": "Text First" }
      ],
      "default": "image_first"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_align",
      "label": "Vertical Alignment",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "middle"
    },
    { "type": "header", "content": "Section Spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "Extra Small" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "Extra Small" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    { "type": "header", "content": "Media" },
    { "type": "image_picker", "id": "image", "label": "Feature Image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Feature Image (Mobile)" },
    { "type": "text", "id": "video_url", "label": "Feature Video" },
    {
      "type": "checkbox",
      "id": "show_placeholder",
      "label": "Show Placeholder",
      "default": true,
      "info": "Show a pattern when no image is selected."
    },
    {
      "type": "header",
      "content": "Animation"
    },
    { "type": "checkbox", "id": "animate_stagger", "label": "Stagger", "default": false },
    { "type": "checkbox", "id": "enable_zoom", "label": "Enable Ken Burns Effect", "default": false },
    { "type": "header", "content": "Visuals" },
    { "type": "surface", "id": "surface_id", "label": "Color Scheme", "default": "default" },
    {
      "type": "select",
      "id": "bg_role",
      "label": "Background",
      "default": "body",
      "options": [
        { "value": "none",        "label": "None" },
        { "value": "body",        "label": "Body" },
        { "value": "body-alt",    "label": "Body (alt)" },
        { "value": "surface",     "label": "Surface" },
        { "value": "surface-alt", "label": "Surface (alt)" },
        { "value": "accent",      "label": "Accent" },
        { "value": "button",      "label": "Button" },
        { "value": "control",     "label": "Control" },
        { "value": "custom",      "label": "Custom (free hex/gradient)" }
      ]
    },
    {
      "type": "color",
      "id": "bg_role_custom",
      "label": "Custom Bg",
      "info": "Free hex or CSS gradient. Used only when Bg role = Custom.",
      "conditional": "setting.bg_role == 'custom'"
    }
        ],
  "blocks": [{ "type": "text" }, { "type": "button" }, { "type": "logo" }, { "type": "spacer" }, { "type": "@theme" }],
  "presets": [
    {
      "name": "Feature (Chef Profile)",
      "settings": {
        "desktop_layout": "image_left",
        "surface_id": "default",
        "enable_animation": true
      },
      "blocks": {
        "chef_heading": {
          "type": "text",
          "settings": {
            "content": "Our Philosophy",
            "tag": "h2",
            "display_size": "h2",
            "font_weight": "bold"
          }
        },
        "chef_bio": {
          "type": "text",
          "settings": {
            "content": "We believe in honest food, sourced from farmers we know by name.",
            "display_size": "body"
          }
        },
        "chef_cta": {
          "type": "button",
          "settings": {
            "label": "Read Our Story",
            "style": "link"
          }
        }
      },
      "block_order": ["chef_heading", "chef_bio", "chef_cta"]
    }
  ]
}
{% endschema %}
