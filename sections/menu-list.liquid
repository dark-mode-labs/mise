{% assign s = section.settings %}

{% comment %} --- Color tokens --- {% endcomment %}
{% assign bg_color_value = blank %}
{% if s.bg_role == 'palette' and s.bg_role_palette != blank %}
  {% assign bg_color_value = 'var(--palette-{{ s.bg_role_palette }})' %}
{% elsif s.bg_role == 'gradient' and s.bg_role_gradient != blank %}
  {% assign bg_color_value = 'var(--gradient-{{ s.bg_role_gradient }})' %}
{% elsif s.bg_role == 'custom' and s.bg_role_custom != blank %}
  {% assign bg_color_value = s.bg_role_custom %}
{% endif %}

{% comment %} --- Wrapper class/styles (mirrors grid.liquid) --- {% endcomment %}
{% assign bg_role_safe = s.bg_role | default: 'body' %}
{% assign bg_class = 'bg-' | append: bg_role_safe %}
{% if bg_color_value != blank %}{% assign bg_class = '' %}{% endif %}

{% assign section_styles = blank %}
{% if bg_color_value != blank %}
  {% assign section_styles = section_styles | push: 'background: {{ bg_color_value }}' %}
{% endif %}
{% assign section_style_str = section_styles | join: ';' %}

{% assign container_classes = 'menu-list-layout limit-width'
  | push: 'width-{{ s.width }}'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
  | push: 'height-{{ s.height }}'
%}
{% assign container_class_str = container_classes | join: ' ' %}

{% assign spacing_styles = blank %}
{% if s.padding_vertical == 'custom' %}
  {% assign spacing_styles = spacing_styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}
{% if s.padding_horizontal == 'custom' %}
  {% assign spacing_styles = spacing_styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}
{% assign spacing_style_str = spacing_styles | join: ';' %}

<section
  class='menu-list surface-{{ s.surface_id | default: 'default' }} {{ bg_class }}'
  style='{{ section_style_str }}'
  data-behavior='menu-spy'
  data-spy-scope
  data-filter-scope
  {{ context.attached_attributes }}
>
  <div
    class='{{ container_class_str }}'
    style='{{ spacing_style_str }}'
  >
    {% content_for 'blocks', closest.menu: s.menu %}
  </div>
</section>

{% schema %}
{
  "name": "Menu View",
  "settings": [
    {
      "type": "header",
      "content": "Data Source"
    },
    {
      "type": "collection",
      "id": "menu",
      "label": "Select Menu"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "width",
      "id": "width",
      "label": "Content Width",
      "default": "fill"
    },
    {
      "type": "height",
      "id": "height",
      "label": "Section Height",
      "default": "auto"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "space",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "space",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "header",
      "content": "Theme"
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Color Scheme",
      "default": "default"
    },
    {
      "type": "select",
      "id": "bg_role",
      "label": "Background",
      "default": "body",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "body", "label": "Body" },
        { "value": "body-alt", "label": "Body (alt)" },
        { "value": "surface", "label": "Surface" },
        { "value": "surface-alt", "label": "Surface (alt)" },
        { "value": "accent", "label": "Accent" },
        { "value": "button", "label": "Button" },
        { "value": "control", "label": "Control" },
        { "value": "palette", "label": "Base Palette" },
        { "value": "custom", "label": "Raw Color" },
        { "value": "gradient", "label": "Gradient" }
      ]
    },
    {
      "type": "palette",
      "id": "bg_role_palette",
      "label": "Background Palette Token",
      "default": "brand",
      "conditional": "setting.bg_role == 'palette'"
    },
    {
      "type": "color",
      "id": "bg_role_custom",
      "label": "Raw Background",
      "conditional": "setting.bg_role == 'custom'"
    },
    {
      "type": "gradient",
      "id": "bg_role_gradient",
      "label": "Background Gradient",
      "conditional": "setting.bg_role == 'gradient'"
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    }
  ],
  "presets": [
    {
      "name": "Menu — Chip Tabs (Scroll Spy)",
      "settings": {},
      "blocks": {
        "chips-nav": {
          "type": "group",
          "name": "Chips Nav",
          "settings": {
            "direction": "row",
            "gap": "xs",
            "width": "fill",
            "padding_vertical": "sm",
            "padding_horizontal": "none",
            "margin_vertical": "none"
          },
          "blocks": {
            "chips-loop": {
              "type": "repeater",
              "name": "Collections → Chips",
              "settings": {
                "data_source_type": "menu_collections"
              },
              "blocks": {
                "chip": {
                  "type": "_tab-head",
                  "name": "Chip",
                  "settings": {
                    "tab_id": "{{ context.item.uuid }}",
                    "mode": "spy",
                    "border_mode": "full",
                    "border_role": "default",
                    "border_size": "xxs",
                    "border_mode_inactive": "full",
                    "border_size_inactive": "xxs",
                    "text_role": "on-accent",
                    "text_role_inactive": "primary",
                    "enable_overlay": true,
                    "overlay_role": "accent",
                    "border_radius_override": true,
                    "border_radius": 999
                  },
                  "blocks": {
                    "chip-label": {
                      "type": "text",
                      "name": "Label",
                      "settings": {
                        "content": "{{ context.item.name }}",
                        "tag": "span",
                        "type_style": "body",
                        "padding_vertical": "xs",
                        "padding_horizontal": "md"
                      }
                    }
                  },
                  "block_order": ["chip-label"]
                }
              },
              "block_order": ["chip"]
            }
          },
          "block_order": ["chips-loop"]
        },
        "content-loop": {
          "type": "repeater",
          "name": "Collections → Content Panes",
          "settings": {
            "data_source_type": "menu_collections"
          },
          "blocks": {
            "pane": {
              "type": "_tab-content",
              "name": "Pane",
              "settings": {
                "tab_id": "{{ context.item.uuid }}",
                "mode": "spy"
              },
              "blocks": {
                "pane-content": {
                  "type": "group",
                  "name": "Pane Content",
                  "settings": {
                    "direction": "col",
                    "gap": "md",
                    "width": "fill",
                    "padding_vertical": "lg",
                    "padding_horizontal": "none"
                  },
                  "blocks": {
                    "heading": {
                      "type": "text",
                      "name": "Collection Heading",
                      "settings": {
                        "content": "{{ context.item.name }}",
                        "tag": "h2",
                        "type_style": "heading-1",
                        "text_align": "left"
                      }
                    },
                    "items-loop": {
                      "type": "repeater",
                      "name": "Items → Cards",
                      "settings": {
                        "data_source_type": "item_collection",
                        "item_collection": "{{ context.item.uuid }}"
                      },
                      "blocks": {
                        "card": {
                          "type": "_menu-card-full",
                          "name": "Item Card",
                          "settings": {
                            "gap": "none",
                            "shadow": true
                          },
                          "blocks": {
                            "menu-card-header": {
                              "type": "group",
                              "name": "Heading",
                              "static": true,
                              "settings": {
                                "gap": "none",
                                "padding_vertical": "none",
                                "padding_horizontal": "none"
                              },
                              "blocks": {
                                "img": {
                                  "type": "media",
                                  "settings": {
                                    "image": "{{ context.item.asset.url }}",
                                    "object_fit": "cover",
                                    "aspect_ratio": "landscape"
                                  }
                                }
                              },
                              "block_order": ["img"]
                            },
                            "menu-card-content": {
                              "type": "group",
                              "name": "Content",
                              "static": true,
                              "settings": {
                                "gap": "sm",
                                "padding_vertical": "xs",
                                "padding_horizontal": "md",
                                "grow_content": true
                              },
                              "blocks": {
                                "info": {
                                  "type": "group",
                                  "blocks": {
                                    "title": {
                                      "type": "text",
                                      "settings": {
                                        "tag": "h3",
                                        "content": "{{ context.item.name }}",
                                        "text_wrap": "balance",
                                        "text_align": "left",
                                        "type_style": "body"
                                      }
                                    },
                                    "price": {
                                      "type": "text",
                                      "settings": {
                                        "tag": "span",
                                        "content": "{{ context.item.amount | money }}",
                                        "text_align": "right",
                                        "type_style": "body"
                                      }
                                    }
                                  },
                                  "settings": {
                                    "gap": "xs",
                                    "width": "full",
                                    "direction": "row",
                                    "content_align": "between",
                                    "vertical_align": "top",
                                    "padding_vertical": "xs",
                                    "padding_horizontal": "none"
                                  },
                                  "block_order": ["title", "price"]
                                },
                                "desc": {
                                  "type": "text",
                                  "settings": {
                                    "content": "{{ context.item.description }}",
                                    "text_align": "left",
                                    "type_style": "caption"
                                  }
                                }
                              },
                              "block_order": ["info", "desc"]
                            },
                            "menu-card-footer": {
                              "type": "group",
                              "name": "Footer",
                              "static": true,
                              "settings": {
                                "gap": "xs",
                                "padding_vertical": "xs",
                                "padding_horizontal": "md"
                              },
                              "blocks": {
                                "btn": {
                                  "type": "button",
                                  "settings": {
                                    "label": "Order Now",
                                    "width": "full",
                                    "content_align": "center",
                                    "trigger": "action",
                                    "action": "add-item"
                                  }
                                }
                              },
                              "block_order": ["btn"]
                            }
                          }
                        }
                      },
                      "block_order": ["card"]
                    }
                  },
                  "block_order": ["heading", "items-loop"]
                }
              },
              "block_order": ["pane-content"]
            }
          },
          "block_order": ["pane"]
        }
      },
      "block_order": ["chips-nav", "content-loop"]
    },
    {
      "name": "Menu — Dropdown",
      "settings": {},
      "blocks": {
        "select-nav": {
          "type": "select",
          "name": "Collection Picker",
          "settings": {
            "aria_label": "Select a collection",
            "trigger": "action",
            "action": "tab-switch",
            "action_group": "{{ section.id }}",
            "width": "fit",
            "margin_vertical": "sm"
          },
          "blocks": {
            "options-loop": {
              "type": "repeater",
              "name": "Collections → Options",
              "settings": {
                "data_source_type": "menu_collections"
              },
              "blocks": {
                "option": {
                  "type": "_option",
                  "settings": {
                    "label": "{{ context.item.name }}",
                    "value": "{{ context.item.uuid }}"
                  }
                }
              },
              "block_order": ["option"]
            }
          },
          "block_order": ["options-loop"]
        },
        "content-loop": {
          "type": "repeater",
          "name": "Collections → Content Panes",
          "settings": {
            "data_source_type": "menu_collections"
          },
          "blocks": {
            "pane": {
              "type": "_tab-content",
              "name": "Pane",
              "settings": {
                "tab_id": "{{ context.item.uuid }}",
                "mode": "tab"
              },
              "blocks": {
                "pane-content": {
                  "type": "group",
                  "settings": {
                    "direction": "col",
                    "gap": "md",
                    "width": "fill",
                    "padding_vertical": "lg",
                    "padding_horizontal": "none"
                  },
                  "blocks": {
                    "heading": {
                      "type": "text",
                      "settings": {
                        "content": "{{ context.item.name }}",
                        "tag": "h2",
                        "type_style": "heading-1",
                        "text_align": "left"
                      }
                    },
                    "items-loop": {
                      "type": "repeater",
                      "settings": {
                        "data_source_type": "item_collection",
                        "item_collection": "{{ context.item.uuid }}"
                      },
                      "blocks": {
                        "card": {
                          "type": "_menu-card-full",
                          "settings": {
                            "gap": "none",
                            "shadow": true
                          },
                          "blocks": {
                            "menu-card-header": {
                              "type": "group",
                              "name": "Heading",
                              "static": true,
                              "settings": {
                                "gap": "none",
                                "padding_vertical": "none",
                                "padding_horizontal": "none"
                              },
                              "blocks": {
                                "img": {
                                  "type": "media",
                                  "settings": {
                                    "image": "{{ context.item.asset.url }}",
                                    "object_fit": "cover",
                                    "aspect_ratio": "landscape"
                                  }
                                }
                              },
                              "block_order": ["img"]
                            },
                            "menu-card-content": {
                              "type": "group",
                              "name": "Content",
                              "static": true,
                              "settings": {
                                "gap": "sm",
                                "padding_vertical": "xs",
                                "padding_horizontal": "md",
                                "grow_content": true
                              },
                              "blocks": {
                                "info": {
                                  "type": "group",
                                  "blocks": {
                                    "title": {
                                      "type": "text",
                                      "settings": {
                                        "tag": "h3",
                                        "content": "{{ context.item.name }}",
                                        "text_wrap": "balance",
                                        "text_align": "left",
                                        "type_style": "body"
                                      }
                                    },
                                    "price": {
                                      "type": "text",
                                      "settings": {
                                        "tag": "span",
                                        "content": "{{ context.item.amount | money }}",
                                        "text_align": "right",
                                        "type_style": "body"
                                      }
                                    }
                                  },
                                  "settings": {
                                    "gap": "xs",
                                    "width": "full",
                                    "direction": "row",
                                    "content_align": "between",
                                    "vertical_align": "top",
                                    "padding_vertical": "xs",
                                    "padding_horizontal": "none"
                                  },
                                  "block_order": ["title", "price"]
                                },
                                "desc": {
                                  "type": "text",
                                  "settings": {
                                    "content": "{{ context.item.description }}",
                                    "text_align": "left",
                                    "type_style": "caption"
                                  }
                                }
                              },
                              "block_order": ["info", "desc"]
                            },
                            "menu-card-footer": {
                              "type": "group",
                              "name": "Footer",
                              "static": true,
                              "settings": {
                                "gap": "xs",
                                "padding_vertical": "xs",
                                "padding_horizontal": "md"
                              },
                              "blocks": {
                                "btn": {
                                  "type": "button",
                                  "settings": {
                                    "label": "Order Now",
                                    "width": "full",
                                    "content_align": "center",
                                    "trigger": "action",
                                    "action": "add-item"
                                  }
                                }
                              },
                              "block_order": ["btn"]
                            }
                          }
                        }
                      },
                      "block_order": ["card"]
                    }
                  },
                  "block_order": ["heading", "items-loop"]
                }
              },
              "block_order": ["pane-content"]
            }
          },
          "block_order": ["pane"]
        }
      },
      "block_order": ["select-nav", "content-loop"]
    }
  ]
}
{% endschema %}
