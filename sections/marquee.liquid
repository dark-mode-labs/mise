{% assign s = section.settings %}

{% assign bg_color_value = blank %}
{% if s.bg_role == 'palette' and s.bg_role_palette != blank %}
  {% assign bg_color_value = 'var(--palette-{{ s.bg_role_palette }})' %}
{% elsif s.bg_role == 'gradient' and s.bg_role_gradient != blank %}
  {% assign bg_color_value = 'var(--gradient-{{ s.bg_role_gradient }})' %}
{% elsif s.bg_role == 'custom' and s.bg_role_custom != blank %}
  {% assign bg_color_value = s.bg_role_custom %}
{% endif %}

{% comment %} --- Background class (unified bg primitive) --- {% endcomment %}
{% assign bg_role_safe = s.bg_role | default: 'body' %}
{% assign bg_class = 'bg-' | append: bg_role_safe %}
{% if bg_color_value != blank %}{% assign bg_class = '' %}{% endif %}

{% assign separator_color = blank %}
{% if s.separator_role == 'palette' and s.separator_role_palette != blank %}
  {% assign separator_color = 'var(--palette-{{ s.separator_role_palette }})' %}
{% elsif s.separator_role == 'custom' and s.separator_role_custom != blank %}
  {% assign separator_color = s.separator_role_custom %}
{% endif %}

{% assign border_color_value = blank %}
{% if s.border_role == 'palette' and s.border_role_palette != blank %}
  {% assign border_color_value = 'var(--palette-{{ s.border_role_palette }})' %}
{% elsif s.border_role == 'gradient' and s.border_role_gradient != blank %}
  {% assign border_color_value = 'var(--gradient-{{ s.border_role_gradient }})' %}
{% elsif s.border_role == 'custom' and s.border_role_custom != blank %}
  {% assign border_color_value = s.border_role_custom %}
{% endif %}

{% assign container_classes = 'text-primary limit-width'
  | push: bg_class
  | push: 'width-{{ s.width }}'
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
%}
{% unless s.border_mode == 'none' %}
  {% assign container_classes = container_classes
    | push: 'group-border-{{ s.border_mode }}'
    | push: 'group-border-size-{{ s.border_size }}'
  %}
  {% if s.border_role
    and s.border_role != 'none'
    and s.border_role != 'custom'
    and s.border_role != 'palette'
    and s.border_role != 'gradient'
  %}
    {% assign container_classes = container_classes | push: 'border-{{ s.border_role }}' %}
  {% endif %}
  {% if s.border_mode == 'custom' %}
    {% assign container_classes = container_classes
      | push_if: 'group-border-custom-left', s.border_custom_left
      | push_if: 'group-border-custom-right', s.border_custom_right
      | push_if: 'group-border-custom-top', s.border_custom_top
      | push_if: 'group-border-custom-bottom', s.border_custom_bottom
    %}
  {% endif %}
{% endunless %}

{% assign container_class_str = container_classes | join: ' ' %}

{% assign styles = blank %}
{% if s.padding_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}
{% if s.padding_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}
{% if bg_color_value != blank %}
  {% assign styles = styles | push: 'background: {{ bg_color_value }}' %}
{% endif %}
{% unless s.border_mode == 'none' %}
  {% assign styles = styles | push: '--border-style: {{ s.border_style }}' %}
  {% if border_color_value != blank %}
    {% assign styles = styles | push: '--border: {{ border_color_value }}' %}
  {% endif %}
{% endunless %}
{% assign style_str = styles | join: ';' %}

{% assign mq_size_class = 'text-size-{{ s.text_size }}' %}
{% assign mq_uppercase = s.uppercase %}
{% if s.type_style != blank %}
  {% assign mq_size_class = 'ts-{{ s.type_style }}' %}
  {% assign mq_uppercase = false %}
{% endif %}

<section
  class='section-marquee surface-{{ s.surface_id | default: 'default' }}'
  {{ context.attached_attributes }}
>
  <div
    class='{{ container_class_str }}'
    style='{{ style_str }}'
  >
    {% render 'marquee',
      items: s.text_list,
      speed: s.speed,
      direction: s.direction,
      size_class: mq_size_class,
      uppercase: mq_uppercase,
      separator: s.separator,
      separator_color: separator_color
    %}
  </div>
</section>

{% schema %}
{
  "name": "Scrolling Text",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "width",
      "id": "width",
      "label": "Max Content Width",
      "default": "fill"
    },
    {
      "type": "text",
      "id": "text_list",
      "label": "Text",
      "default": "Reserve Now, Open Daily, Fresh Ingredients",
      "info": "Comma separated"
    },
    {
      "type": "select",
      "id": "text_size",
      "label": "Text Size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "xl",
          "label": "Extra Large"
        },
        {
          "value": "display",
          "label": "Display"
        }
      ],
      "default": "small"
    },
    {
      "type": "type_style",
      "id": "type_style",
      "label": "Type Style",
      "default": ""
    },
    {
      "type": "checkbox",
      "id": "uppercase",
      "label": "Uppercase",
      "default": true
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Speed",
      "min": 5,
      "max": 60,
      "default": 20
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Separator"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "•",
      "info": "Glyph shown between items."
    },
    {
      "type": "select",
      "id": "separator_role",
      "label": "Separator Color",
      "default": "custom",
      "options": [
        { "value": "palette", "label": "Base Palette" },
        { "value": "custom", "label": "Raw Color" }
      ]
    },
    {
      "type": "palette",
      "id": "separator_role_palette",
      "label": "Separator Palette Token",
      "default": "brand",
      "conditional": "setting.separator_role == 'palette'"
    },
    {
      "type": "color",
      "id": "separator_role_custom",
      "label": "Separator Raw Color",
      "conditional": "setting.separator_role == 'custom'"
    },
    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "select",
      "id": "border_mode",
      "label": "Border",
      "default": "none",
      "options": [
        { "value": "custom", "label": "Custom" },
        { "value": "full", "label": "Full" },
        { "value": "none", "label": "None" }
      ]
    },
    {
      "type": "checkbox",
      "id": "border_custom_top",
      "label": "Top Border",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_bottom",
      "label": "Bottom Border",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_left",
      "label": "Left Border",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "checkbox",
      "id": "border_custom_right",
      "label": "Right Border",
      "default": false,
      "conditional": "setting.border_mode == 'custom'"
    },
    {
      "type": "select",
      "id": "border_size",
      "label": "Border Width",
      "default": "xxs",
      "options": [
        { "value": "xxs", "label": "Hairline" },
        { "value": "xs", "label": "Thin" },
        { "value": "sm", "label": "Medium" },
        { "value": "md", "label": "Thick" },
        { "value": "lg", "label": "Heavy" }
      ],
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "select",
      "id": "border_role",
      "label": "Border Color",
      "default": "default",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "default", "label": "Default" },
        { "value": "emphasis", "label": "Emphasis" },
        { "value": "palette", "label": "Base Palette" },
        { "value": "custom", "label": "Raw Color" },
        { "value": "gradient", "label": "Gradient" }
      ],
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "palette",
      "id": "border_role_palette",
      "label": "Border Palette Token",
      "default": "brand",
      "conditional": "setting.border_role == 'palette' and setting.border_mode != 'none'"
    },
    {
      "type": "color",
      "id": "border_role_custom",
      "label": "Raw Border",
      "conditional": "setting.border_role == 'custom' and setting.border_mode != 'none'"
    },
    {
      "type": "gradient",
      "id": "border_role_gradient",
      "label": "Border Gradient",
      "conditional": "setting.border_role == 'gradient'"
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border Style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "dotted", "label": "Dotted" },
        { "value": "double", "label": "Double" }
      ],
      "conditional": "setting.border_mode != 'none'"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "space",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "space",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "default": "xs"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Color Scheme",
      "default": "default"
    },
    {
      "type": "select",
      "id": "bg_role",
      "label": "Background",
      "default": "body",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "body",
          "label": "Body"
        },
        {
          "value": "body-alt",
          "label": "Body (alt)"
        },
        {
          "value": "surface",
          "label": "Surface"
        },
        {
          "value": "surface-alt",
          "label": "Surface (alt)"
        },
        {
          "value": "accent",
          "label": "Accent"
        },
        {
          "value": "button",
          "label": "Button"
        },
        {
          "value": "control",
          "label": "Control"
        },
        {
          "value": "palette",
          "label": "Base Palette"
        },
        {
          "value": "custom",
          "label": "Raw Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        }
      ]
    },
    {
      "type": "palette",
      "id": "bg_role_palette",
      "label": "Background Palette Token",
      "default": "brand",
      "conditional": "setting.bg_role == 'palette'"
    },
    {
      "type": "color",
      "id": "bg_role_custom",
      "label": "Raw Background",
      "conditional": "setting.bg_role == 'custom'"
    },
    {
      "type": "gradient",
      "id": "bg_role_gradient",
      "label": "Background Gradient",
      "conditional": "setting.bg_role == 'gradient'"
    }
  ],
  "presets": [
    {
      "name": "Scrolling Text"
    }
  ]
}
{% endschema %}
