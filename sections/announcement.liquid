{% assign s = section.settings %}

{% comment %} --- Background class + styles (unified bg primitive) --- {% endcomment %}
{% assign bg_role_safe = s.bg_role | default: 'body' %}
{% assign bg_class = 'bg-' | append: bg_role_safe %}
{% if s.bg_color_override and s.bg_color != blank %}{% assign bg_class = '' %}{% endif %}

{% assign styles = blank %}
{% if s.bg_color_override and s.bg_color != blank %}
  {% assign styles = styles | push: 'background: {{ s.bg_color }}' %}
{% elsif s.bg_alpha and s.bg_alpha != 100 %}
  {% assign styles = styles | push: '--bg-alpha: {{ s.bg_alpha | divided_by: 100.0 }}' %}
{% endif %}
{% assign style_str = styles | join: ';' %}

<section
  class="section-announcement surface-{{ s.surface_id | default: 'default' }} {{ bg_class }} z-header-top text-xs md:text-sm font-bold tracking-wide uppercase group select-none border-b border-std"
  style="{{ style_str }}"
  data-behavior="slideshow"
  data-autoplay="{{ s.autoplay }}"
  data-speed="{{ s.autoplay_speed }}"
  data-infinite="true"
  {{ context.attached_attributes }}
>
  <div class="width-{{ s.width_scheme }} limit-width">
    <div class="slideshow-track flex w-full overflow-x-auto snap-x snap-mandatory scroll-smooth scrollbar-hide cursor-grab active:cursor-grabbing">
      {% content_for 'blocks' %}
    </div>

    {% if section.blocks.size > 1 and s.show_arrows %}
      <div class="absolute inset-0 pointer-events-none flex items-center justify-between px-4 opacity-0 group-hover:opacity-100 transition-opacity">
        <button type="button" class="slideshow-prev pointer-events-auto p-1 btn-nav" aria-label="Previous">
          {% render 'icon', name: 'chevron-left', class: 'w-3 h-3' %}
        </button>
        <button type="button" class="slideshow-next pointer-events-auto p-1 btn-nav" aria-label="Next">
          {% render 'icon', name: 'chevron-right', class: 'w-3 h-3' %}
        </button>
      </div>
    {% endif %}

    {% if s.show_close %}
      <button
        type="button"
        class="absolute right-2 top-1/2 -translate-y-1/2 p-2 hover:opacity-60 z-floating"
        onclick="this.closest('.section-announcement').remove()"
        aria-label="Dismiss"
      >
        {% render 'icon', name: 'close', class: 'w-3 h-3' %}
      </button>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Announcement Bar",
  "restriction": { "groups": ["header"] },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "width_scheme",
      "id": "width_scheme",
      "label": "Max Content Width",
      "default": "full"
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay", "default": true },
    { "type": "range", "id": "autoplay_speed", "label": "Speed (s)", "min": 3, "max": 10, "default": 5 },
    { "type": "checkbox", "id": "show_arrows", "label": "Show Arrows on Hover", "default": true },
    { "type": "checkbox", "id": "show_close", "label": "Show Close Button", "default": false },

    {
      "type": "header",
      "content": "Theme"
    },
    { "type": "surface", "id": "surface_id", "label": "Color Scheme", "default": "default" },
    {
      "type": "select",
      "id": "bg_role",
      "label": "Background",
      "default": "body",
      "options": [
        { "value": "none",    "label": "None" },
        { "value": "body",    "label": "Body" },
        { "value": "surface", "label": "Surface" },
        { "value": "accent",  "label": "Accent" },
        { "value": "button",  "label": "Button" },
        { "value": "nav",     "label": "Control" }
      ]
    },
    {
      "type": "range",
      "id": "bg_alpha",
      "label": "Background Opacity",
      "min": 0, "max": 100, "step": 5, "default": 100, "unit": "%",
      "conditional": "setting.bg_role != 'none'"
    },
    {
      "type": "checkbox",
      "id": "bg_color_override",
      "label": "Custom Background (free hex/gradient)",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Custom Background Color",
      "conditional": "setting.bg_color_override"
    }
  ],
  "blocks": [{ "type": "_announcement" }],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": {
        "msg1": { "type": "_announcement", "settings": { "text": "Reserve Now" } },
        "msg2": { "type": "_announcement", "settings": { "text": "Live Music Friday" } }
      },
      "block_order": ["msg1", "msg2"]
    }
  ]
}
{% endschema %}
