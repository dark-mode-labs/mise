{% assign s = section.settings %}

{% comment %} --- Background class + styles (unified bg primitive) --- {% endcomment %}
{% assign bg_role_safe = s.bg_role | default: 'body' %}
{% assign bg_class = 'bg-' | append: bg_role_safe %}
{% if s.bg_role == 'custom' and s.bg_role_custom != blank %}{% assign bg_class = '' %}{% endif %}

{% assign styles = blank | push: '--max-h: {{ s.divider_height }}rem' %}
{% if s.bg_role == 'custom' and s.bg_role_custom != blank %}
  {% assign styles = styles | push: 'background: {{ s.bg_role_custom }}' %}
{% endif %}
{% assign style_str = styles | join: ';' %}

<section
  class="section-divider"
  {{ context.attached_attributes }}
>
  <div
    class="flex flex-auto items-center justify-center surface-{{ s.surface_id | default: 'default' }} width-{{ s.width_scheme }} {{ bg_class }} text-primary limit-width h-[var(--max-h)]"
    style="{{ style_str }}"
  >
    <div class="relative flex items-center justify-center w-full">
      {% if s.show_line %}
        <div class="absolute inset-0 flex items-center" aria-hidden="true">
          <div class="w-full border-t border-default opacity-50"></div>
        </div>
      {% endif %}

      {% if s.show_icon %}
        <div class="relative {{ bg_class }} px-4">
          {% render 'icon', name: s.icon_select, class: 'w-6 h-6 text-secondary' %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Divider",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "width_scheme",
      "id": "width_scheme",
      "label": "Max Content Width",
      "default": "full"
    },
    {
      "type": "header",
      "content": "Visuals"
    },
    {
      "type": "checkbox",
      "id": "show_line",
      "label": "Show Line",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show Icon",
      "default": true
    },
    {
      "type": "select",
      "id": "icon_select",
      "label": "Icon",
      "options": [
        { "value": "star", "label": "Star" },
        { "value": "chevron-down", "label": "Diamond/Arrow" },
        { "value": "menu", "label": "Utensils" }
      ],
      "default": "star",
      "conditional": "setting.show_icon"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "divider_height",
      "label": "Height",
      "min": 0,
      "max": 40,
      "step": 0.5,
      "default": 2,
      "unit": "rem"
    },
    {
      "type": "header",
      "content": "Theme"
    },
    {
      "type": "surface",
      "id": "surface_id",
      "label": "Color Scheme",
      "default": "default"
    },
    {
      "type": "select",
      "id": "bg_role",
      "label": "Background",
      "default": "body",
      "options": [
        { "value": "none",        "label": "None" },
        { "value": "body",        "label": "Body" },
        { "value": "body-alt",    "label": "Body (alt)" },
        { "value": "surface",     "label": "Surface" },
        { "value": "surface-alt", "label": "Surface (alt)" },
        { "value": "accent",      "label": "Accent" },
        { "value": "button",      "label": "Button" },
        { "value": "control",     "label": "Control" },
        { "value": "custom",      "label": "Custom (free hex/gradient)" }
      ]
    },
    {
      "type": "color",
      "id": "bg_role_custom",
      "label": "Custom Bg",
      "info": "Free hex or CSS gradient. Used only when Bg role = Custom.",
      "conditional": "setting.bg_role == 'custom'"
    }
        ],
  "presets": [{ "name": "Divider" }]
}
{% endschema %}
