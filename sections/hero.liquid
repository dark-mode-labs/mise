{% assign s = section.settings %}

{% comment %} --- 1. Layout & Media Logic --- {% endcomment %}
{% assign has_media_2 = false %}
{% if s.bg_image_2 != blank or s.video_url_2 != blank %}
  {% assign has_media_2 = true %}
{% endif %}

{% comment %} Background class (unified bg primitive) {% endcomment %}
{% assign bg_role_safe = s.bg_role | default: 'body' %}
{% assign bg_class = 'bg-' | append: bg_role_safe %}
{% if s.bg_role == 'custom' and s.bg_role_custom != blank %}{% assign bg_class = '' %}{% endif %}

{% assign layout_classes = 'overflow-hidden' | push: bg_class | push: 'is-{{ s.height }}' %}
{% case s.layout_mode %}
  {% when 'split_right' %}
    {% assign layout_classes = layout_classes | push: 'hero-layout-split-right' %}
    {% assign media_classes = 'hero-media-split' %}
    {% assign content_classes = 'hero-content-split' %}
  {% when 'split_left' %}
    {% assign layout_classes = layout_classes | push: 'hero-layout-split-left' %}
    {% assign media_classes = 'hero-media-split' %}
    {% assign content_classes = 'hero-content-split' %}
  {% else %}
    {% assign layout_classes = layout_classes | push: 'hero-layout-overlay' %}
    {% assign media_classes = 'hero-media-overlay' %}
    {% assign content_classes = 'hero-content-overlay' %}
{% endcase %}

{% comment %} --- 2. Spacing & Container Pipeline --- {% endcomment %}
{% assign layout_classes = layout_classes
  | push: 'padding-py-{{ s.padding_vertical }}'
  | push: 'padding-px-{{ s.padding_horizontal }}'
%}

{% assign styles = blank %}
{% if s.padding_vertical == 'custom' %}
  {% assign styles = styles
    | push: '--space-pt: {{ s.padding_vertical_custom_top }}rem'
    | push: '--space-pb: {{ s.padding_vertical_custom_bottom }}rem'
  %}
{% endif %}
{% if s.padding_horizontal == 'custom' %}
  {% assign styles = styles
    | push: '--space-pl: {{ s.padding_horizontal_custom_left }}rem'
    | push: '--space-pr: {{ s.padding_horizontal_custom_right }}rem'
  %}
{% endif %}
{% if s.height == 'custom' %}
  {% assign styles = styles | push: '--max-h: {{ s.height_custom }}vh' %}
{% endif %}
{% if s.bg_role == 'custom' and s.bg_role_custom != blank %}
  {% assign styles = styles | push: 'background: {{ s.bg_role_custom }}' %}
{% endif %}

{% assign layout_class_str = layout_classes | join: ' ' %}
{% assign style_str = styles | join: ';' %}

{% comment %} --- 3. Content Pipeline --- {% endcomment %}
{% assign content_pipeline = content_classes
  | push: 'width-{{ s.width_scheme }}'
  | push: 'limit-width gap-6 transition-all'
  | push: 'section-align-content-{{ s.content_align }}'
  | push: 'section-align-v-{{ s.vertical_align }}'
  | push: 'section-align-text-{{ s.text_align }}'
  | push_if: 'stagger-load', s.animate_stagger
%}

{% assign content_class_str = content_pipeline | join: ' ' %}

{% assign placeholder_name = '' %}
{% if s.show_placeholder %}{% assign placeholder_name = 'scene-3' %}{% endif %}

{% comment %} --- Hero Render --- {% endcomment %}
<section
  class="section-hero surface-{{ s.surface_id | default: 'default' }}"
  {{ context.attached_attributes }}
>
  <div
    class="{{ layout_class_str }}"
    style="{{ style_str }}"
  >
    {% comment %} Media Layer {% endcomment %}
    <div class="{{ media_classes }} width-{{ s.width_bg }} limit-width">
      {% comment %} Primary Media Slot {% endcomment %}
      {% assign media_1_classes = 'hero-media-inner absolute inset-0' %}
      {% if has_media_2 -%}
        {%- assign media_1_classes = media_1_classes | append: ' w-1/2 border-r border-default' -%}
      {%- endif %}

      <div class="{{ media_1_classes }}">
        {% render 'media',
          src: s.bg_image,
          src_mobile: s.mobile_image,
          video: s.video_url,
          fit: 'cover',
          loading: 'eager',
          placeholder: placeholder_name,
          animate: s.enable_zoom
        %}

        {% render 'bg-overlay',
             role: s.overlay_role,
             alpha: s.overlay_alpha,
             use_custom: s.overlay_role == 'custom',
             custom_color: s.overlay_role_custom
        %}
      </div>

      {% comment %} Secondary Media Slot {% endcomment %}
      {% if has_media_2 %}
        <div class="hero-media-inner w-1/2">
          {% render 'media',
            src: s.bg_image_2,
            src_mobile: s.mobile_image_2,
            video: s.video_url_2,
            fit: 'cover',
            loading: 'eager',
            placeholder: placeholder_name,
            animate: s.enable_zoom
          %}
          {% render 'bg-overlay',
               role: s.overlay_role,
               alpha: s.overlay_alpha,
               use_custom: s.overlay_role == 'custom',
               custom_color: s.overlay_role_custom
          %}
        </div>
      {% endif %}
    </div>

    {% comment %} Content Layer {% endcomment %}
    <div class="{{ content_class_str }}">
      {% content_for 'blocks' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "width_scheme",
      "id": "width_bg",
      "label": "Background Width",
      "default": "full"
    },
    {
      "type": "width_scheme",
      "id": "width_scheme",
      "label": "Content Width",
      "default": "standard"
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Layout Style",
      "options": [
        { "value": "overlay", "label": "Overlay (Classic)" },
        { "value": "split_left", "label": "Split (Media Left)" },
        { "value": "split_right", "label": "Split (Media Right)" }
      ],
      "default": "overlay"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Image Height",
      "options": [
        { "value": "auto", "label": "Auto (Fit Content)" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Fullscreen" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "height_custom",
      "label": "Custom Height",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 56,
      "unit": "vh",
      "conditional": "setting.height == 'custom'"
    },
    { "type": "header", "content": "Section Spacing" },
    {
      "type": "select",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "Extra Small" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_top",
      "label": "Custom Top Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_vertical_custom_bottom",
      "label": "Custom Bottom Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_vertical == 'custom'"
    },
    {
      "type": "select",
      "id": "padding_horizontal",
      "label": "Horizontal Padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "Extra Small" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra Large" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_left",
      "label": "Custom Left Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    {
      "type": "range",
      "id": "padding_horizontal_custom_right",
      "label": "Custom Right Padding",
      "min": 0,
      "max": 8,
      "step": 0.25,
      "default": 0,
      "unit": "rem",
      "conditional": "setting.padding_horizontal == 'custom'"
    },
    { "type": "header", "content": "Primary Media" },
    { "type": "image_picker", "id": "bg_image", "label": "Image 1 (Desktop)" },
    { "type": "image_picker", "id": "mobile_image", "label": "Image 1 (Mobile)" },
    { "type": "text", "id": "video_url", "label": "Video 1 (MP4)" },

    { "type": "header", "content": "Secondary Media" },
    { "type": "image_picker", "id": "bg_image_2", "label": "Image 2 (Desktop)" },
    { "type": "image_picker", "id": "mobile_image_2", "label": "Image 2 (Mobile)" },
    { "type": "text", "id": "video_url_2", "label": "Video 2 (MP4)" },
    {
      "type": "checkbox",
      "id": "show_placeholder",
      "label": "Show Placeholder",
      "default": true,
      "info": "Show a pattern when no image is selected.",
      "conditional": "setting.bg_image == blank and setting.bg_image_2 == blank"
    },
    { "type": "header", "content": "Alignment" },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_align",
      "label": "Vertical Alignment",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "middle"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    { "type": "checkbox", "id": "animate_stagger", "label": "Stagger", "default": false },
    { "type": "checkbox", "id": "enable_zoom", "label": "Enable Ken Burns Effect", "default": false },
    { "type": "header", "content": "Theme" },
    { "type": "surface", "id": "surface_id", "label": "Color Scheme", "default": "default" },
    {
      "type": "select",
      "id": "bg_role",
      "label": "Background",
      "default": "body",
      "options": [
        { "value": "none",        "label": "None" },
        { "value": "body",        "label": "Body" },
        { "value": "body-alt",    "label": "Body (alt)" },
        { "value": "surface",     "label": "Surface" },
        { "value": "surface-alt", "label": "Surface (alt)" },
        { "value": "accent",      "label": "Accent" },
        { "value": "button",      "label": "Button" },
        { "value": "control",     "label": "Control" },
        { "value": "custom",      "label": "Custom (free hex/gradient)" }
      ]
    },
    {
      "type": "color",
      "id": "bg_role_custom",
      "label": "Custom Bg",
      "info": "Free hex or CSS gradient. Used only when Bg role = Custom.",
      "conditional": "setting.bg_role == 'custom'"
    },
        {
      "type": "select",
      "id": "overlay_role",
      "label": "Overlay",
      "default": "none",
      "options": [
        { "value": "none",        "label": "None" },
        { "value": "body",        "label": "Body" },
        { "value": "body-alt",    "label": "Body (alt)" },
        { "value": "surface",     "label": "Surface" },
        { "value": "surface-alt", "label": "Surface (alt)" },
        { "value": "accent",      "label": "Accent" },
        { "value": "button",      "label": "Button" },
        { "value": "control",     "label": "Control" },
        { "value": "custom",      "label": "Custom (free hex/gradient)" }
      ]
    },
    {
      "type": "color",
      "id": "overlay_role_custom",
      "label": "Custom Overlay",
      "info": "Free hex or CSS gradient. Used only when Overlay role = Custom.",
      "conditional": "setting.overlay_role == 'custom'"
    },
    {
      "type": "range",
      "id": "overlay_alpha",
      "label": "Overlay Opacity",
      "min": 0, "max": 100, "step": 5, "default": 50, "unit": "%",
      "conditional": "setting.overlay_role != 'none' and setting.overlay_role != 'custom'"
    }
    ],
  "blocks": [
    { "type": "@theme" },
    { "type": "scroll-indicator" },
    { "type": "text" },
    { "type": "spacer" },
    { "type": "_marquee" },
    { "type": "media" },
    { "type": "group" },
    { "type": "button" }
  ],
  "presets": [
    {
      "name": "Hero (Fine Dining)",
      "settings": {
        "layout_mode": "overlay",
        "surface_id": "default"
      },
      "blocks": {
        "hero_heading": {
          "type": "text",
          "settings": { "content": "Taste the Season", "display_size": "display", "tag": "h1", "font_weight": "bold" }
        },
        "hero_subtext": {
          "type": "text",
          "settings": { "content": "Locally sourced ingredients.", "display_size": "body" }
        },
        "hero_cta": {
          "type": "button",
          "settings": { "label": "Reserve Table", "style": "primary" }
        }
      },
      "block_order": ["hero_heading", "hero_subtext", "hero_cta"]
    }
  ]
}
{% endschema %}
